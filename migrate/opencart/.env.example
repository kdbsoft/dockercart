# ── Source (old OpenCart) database ───────────────────────────────────────────
SOURCE_HOST=192.168.1.100
SOURCE_PORT=3306
SOURCE_USER=opencart
SOURCE_PASSWORD=secret
SOURCE_DATABASE=opencart_db
# Leave empty for automatic table-prefix detection
SOURCE_PREFIX=

# ── Migration options ─────────────────────────────────────────────────────────
# Comma-separated list of entities (available: categories, products, manufacturers, information, article)
ENTITIES=categories,products,manufacturers,information,article

# Language ID mapping: SRC_ID:DST_ID or code:ID, e.g. "1:1" or "en-gb:1,uk-ua:2"
# Leave empty to be prompted interactively (requires `docker run -it`)
LANGUAGE_MAP=1:1

# Set to true to preview migration steps without committing any changes
DRY_RUN=false
