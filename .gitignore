# Build artifacts
build/
dist/

# OS / editor
.DS_Store
/.vscode/
node_modules/
/.zed/

# Config and Htaccess Files
/upload/.htaccess
/upload/config.php
/upload/admin/config.php

# Backup htaccess files
.htaccess.bak*
/upload/.htaccess.bak*

# Export YML files (generated by store exports)
# Export YML files (generated by store exports)
# Match files like export-yml-1-en-gb.xml or export-yml-10-uk-ua.xml
export-yml-[0-9]*-*.xml
/upload/export-yml-[0-9]*-*.xml

# Image File
!/upload/image/no_image.jpg
!/upload/image/catalog/cart.png

# Robots.txt
/upload/robots.txt

# Image Cache Files
/upload/image/cache/*
!/upload/image/cache/index.html
/upload/image/catalog/dockercart_import_yml/*

#Sync Files
/upload/image/sync/*
/upload/image/blog/journal/*

# Legacy storage (migrated to ./storage/)
/upload/system/storage/

# Templates Files
/upload/image/templates/*
/upload/image/templates/default.jpg

# Ignore all other files under /upload/image (keep currently tracked files).
# Preserve the demo directory and its contents for tracking.
/upload/image/catalog/*
!/upload/image/catalog/demo/
!/upload/image/catalog/demo/**
!/upload/image/catalog/social/
!/upload/image/catalog/social/**

# Flags
# remove sharp char if you want to add flags to gitignore
# /upload/flags/*

# If you want to ignore backup installer artifacts in development mode:
# /upload/backup.install/*

# PHPUnit cache
.phpunit.cache/
.php-cs-fixer.cache

# IDE Project files
/.idea
/upload/.idea
/.cache/cache
/tools/*
!/tools/phpstan/
!/tools/phpstan/*.php
.env

/storage
build-extension.sh
.bmad/
.github/
!/.github/
/.github/*
!/.github/workflows/
!/.github/workflows/**

/docker/nginx/cache/
/docker/nginx/cache/**

*.backup
/docker/mysql/*.bak*
/docker/mysql/*.tmp
/docker/mysql/*.tmp*

# SSL / certificate artifacts (self-signed and Let's Encrypt)
# Ignore generated self-signed certificates and private keys
/docker/ssl/
/docker/ssl/**
# Ignore Let's Encrypt/ACME storage
/docker/acme/
/docker/acme/**
# Ensure acme.json (contains private keys) is not committed
/docker/acme/acme.json

# Ignore generated Let's Encrypt certificates and keys
/docker/letsencrypt/certs/
/docker/letsencrypt/keys/

# Ignore Let's Encrypt runtime data (contains private keys and account data)
/docker/letsencrypt/accounts/
/docker/letsencrypt/archive/
/docker/letsencrypt/live/*
/docker/letsencrypt/renewal/
/docker/letsencrypt/renewal-hooks/
/docker/letsencrypt/www/
/docker/letsencrypt/*.log
/docker/letsencrypt/*.lock


# Ignore custom local Dockercart prefixed artifacts
**/dockercart_custom_*
**/dc_custom_*
**/custom_*

backups/
sitemap.xml
google-base*.xml


/.cache/
.omo/
