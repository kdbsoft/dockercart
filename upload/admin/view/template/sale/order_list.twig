  <script type="text/javascript"><!--
// Order status change
$('.order-status-select').on('change', function() {
	var element = this;
	var orderId = $(element).data('order-id');
	var statusId = $(element).val();
	var notify = $(element).closest('td').find('.order-notify-check').prop('checked') ? 1 : 0;

	$.ajax({
		url: '{{ catalog }}index.php?route=api/order/history&api_token={{ api_token }}&store_id={{ store_id }}&order_id=' + orderId,
		type: 'post',
		dataType: 'json',
		data: 'order_status_id=' + encodeURIComponent(statusId) + '&notify=' + notify + '&comment=',
		beforeSend: function() {
			$(element).prop('disabled', true);
		},
		complete: function() {
			$(element).prop('disabled', false);
		},
		success: function(json) {
			$('.alert-dismissible').remove();

			if (json['error']) {
				$('#content > .container-fluid').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json['error'] + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
			}

			if (json['success']) {
				$('#content > .container-fluid').prepend('<div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> ' + json['success'] + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
			}
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
});
//--></script>
  <script type="text/javascript"><!--
// Tracking number quick-edit
$(document).on('click', '.btn-quick-edit-tracking', function() {
	var element = this;
	var orderId = $(element).data('order-id');
	var currentValue = $(element).data('value');
	var $span = $('#tracking-' + orderId);

	$span.replaceWith('<input type="text" class="form-control input-sm tracking-input" data-order-id="' + orderId + '" value="' + $('<div>').text(currentValue).html() + '" style="display:inline-block; width: 150px;" />');
	$(element).hide();

	var $input = $('.tracking-input[data-order-id="' + orderId + '"]');
	$input.focus().select();

	function saveTracking() {
		var newValue = $input.val();

		$.ajax({
			url: 'index.php?route=sale/order/quickEdit&user_token={{ user_token }}&order_id=' + orderId,
			type: 'post',
			dataType: 'json',
			data: 'field=tracking_number&value=' + encodeURIComponent(newValue),
			success: function(json) {
				if (json['success']) {
					$input.replaceWith('<span class="tracking-value" id="tracking-' + orderId + '">' + (json['value_html'] || newValue) + '</span>');
					$(element).data('value', newValue).show();
				} else {
					$input.replaceWith('<span class="tracking-value" id="tracking-' + orderId + '">' + $('<div>').text(currentValue).html() + '</span>');
					$(element).show();
				}
			},
			error: function() {
				$input.replaceWith('<span class="tracking-value" id="tracking-' + orderId + '">' + $('<div>').text(currentValue).html() + '</span>');
				$(element).show();
			}
		});
	}

	$input.on('blur', function() {
		saveTracking();
	}).on('keydown', function(e) {
		if (e.which === 13) {
			e.preventDefault();
			saveTracking();
		} else if (e.which === 27) {
			$input.replaceWith('<span class="tracking-value" id="tracking-' + orderId + '">' + $('<div>').text(currentValue).html() + '</span>');
			$(element).show();
		}
	});
});
//--></script></div>
