<!DOCTYPE html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
<meta charset="UTF-8" />
<title>{{ title }}</title>
<base href="{{ base }}" />
{% if description %}
<meta name="description" content="{{ description }}" />
{% endif %}
{% if keywords %}
<meta name="keywords" content="{{ keywords }}" />
{% endif %}
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
<script type="text/javascript" src="view/javascript/jquery/jquery-3.7.1.min.js"></script>
<script type="text/javascript" src="view/javascript/bootstrap/js/bootstrap.min.js"></script>
<script src="view/javascript/lucide.min.js"></script>
<script src="view/javascript/chart.min.js"></script>
<link href="view/stylesheet/bootstrap.css" type="text/css" rel="stylesheet" />
<link href="view/javascript/font-awesome/css/font-awesome.min.css" type="text/css" rel="stylesheet" />
<script src="view/javascript/jquery/datetimepicker/moment/moment.min.js" type="text/javascript"></script>
<script src="view/javascript/jquery/datetimepicker/moment/moment-with-locales.min.js" type="text/javascript"></script>
<script src="view/javascript/jquery/datetimepicker/bootstrap-datetimepicker.min.js" type="text/javascript"></script>
<link href="view/javascript/jquery/datetimepicker/bootstrap-datetimepicker.min.css" type="text/css" rel="stylesheet" media="screen" />
<link type="text/css" href="view/stylesheet/dockercart_column.css?v={{ dockercart_version }}" rel="stylesheet" media="screen" />
<link type="text/css" href="view/stylesheet/stylesheet.css?v={{ dockercart_version }}" rel="stylesheet" media="screen" />
{% for style in styles %}
<link type="text/css" href="{{ style.href }}{% if style.href|slice(0,4) != 'http' and style.href|slice(0,2) != '//' %}?v={{ dockercart_version }}{% endif %}" rel="{{ style.rel }}" media="{{ style.media }}" />
{% endfor %}
{% for link in links %}
<link href="{{ link.href }}" rel="{{ link.rel }}" />
{% endfor %}
<script src="view/javascript/common.js?v={{ dockercart_version }}" type="text/javascript"></script>
<script src="view/javascript/tinymce/tinymce.min.js" type="text/javascript"></script>
{% for script in scripts %}
<script type="text/javascript" src="{{ script }}{% if script|slice(0,4) != 'http' and script|slice(0,2) != '//' %}?v={{ dockercart_version }}{% endif %}"></script>
{% endfor %}
</head>
<body data-user-token="{{ user_token }}">
<div id="container">
<header id="header" class="navbar navbar-static-top">
  <div class="container-fluid">
    <div id="header-logo" class="navbar-header"><a href="{{ home }}" class="navbar-brand"><img src="view/image/logo.png" alt="{{ heading_title }}" title="{{ heading_title }}" /></a></div>
    {% if logged %}<a href="#" id="button-menu" class="hidden-md hidden-lg"><span class="fa fa-bars"></span></a>
    <ul class="nav navbar-nav navbar-right">
      <li class="dropdown"><a href="#" class="dropdown-toggle" data-toggle="dropdown"><i data-lucide="globe-2" width="14" height="14" style="vertical-align: middle;"></i> <b>{{ (current_language_code|split('-'))|first|upper }}</b> <i class="fa fa-caret-down fa-fw"></i></a>
        <ul class="dropdown-menu dropdown-menu-right">
          {% for language in languages %}
          <li{% if language.code == current_language_code %} class="active"{% endif %}><a href="{{ language.href }}">{{ language.name }}</a></li>
          {% endfor %}
        </ul>
      </li>
      <li class="dropdown"><a href="#" class="dropdown-toggle" data-toggle="dropdown"><img src="{{ image }}" alt="{{ firstname }} {{ lastname }}" title="{{ username }}" id="user-profile" class="img-circle" />{{ firstname }} {{ lastname }} <i class="fa fa-caret-down fa-fw"></i></a>
        <ul class="dropdown-menu dropdown-menu-right">
          <li><a href="{{ profile }}"><i class="fa fa-user-circle-o fa-fw"></i> {{ text_profile }}</a></li>
          <li role="separator" class="divider"></li>
          <li class="dropdown-header">{{ text_store }}</li>
          {% for store in stores %}
          <li><a href="{{ store.href }}" target="_blank">{{ store.name }}</a></li>
          {% endfor %}
          <li role="separator" class="divider"></li>
          <li class="dropdown-header">{{ text_help }}</li>
          <li><a href="https://dockercart.net" target="_blank"><i class="fa fa-cube fa-fw"></i> {{ text_homepage }}</a></li>
          <li><a href="https://dockercart.net/docs" target="_blank"><i class="fa fa-file-text-o fa-fw"></i> {{ text_documentation }}</a></li>
          <li><a href="https://dockercart.net" target="_blank"><i class="fa fa-comments-o fa-fw"></i> {{ text_support }}</a></li>
        </ul>
      </li>
      <li><a href="{{ logout }}"><i class="fa fa-sign-out"></i> <span class="hidden-xs hidden-sm hidden-md">{{ text_logout }}</span></a></li>
    </ul>
    <div class="admin-search-wrap">
      <div class="admin-search-box">
        <input type="text" class="admin-search-input" placeholder="{{ text_search_placeholder }}" autocomplete="off" data-suggest-url="{{ admin_search_suggest_url }}" data-search-url="{{ admin_search_url }}">
        <i class="fa fa-search admin-search-icon"></i>
      </div>
      <ul class="admin-search-dropdown"></ul>
    </div>
    {% endif %} </div>
</header>
<script type="text/javascript">
document.addEventListener('DOMContentLoaded', function() {
  if (window.lucide && typeof window.lucide.createIcons === 'function') {
    window.lucide.createIcons();
  }

  // Admin search autocomplete
  var searchInput = document.querySelector('.admin-search-input');
  var dropdown = document.querySelector('.admin-search-dropdown');
  var suggestTimer = null;
  var userToken = document.body.dataset.userToken;

  if (searchInput && dropdown && searchInput.dataset.suggestUrl) {
    searchInput.addEventListener('input', function() {
      clearTimeout(suggestTimer);
      var query = this.value.trim();

      if (query.length < 2) {
        dropdown.style.display = 'none';
        return;
      }

      suggestTimer = setTimeout(function() {
        var url = searchInput.dataset.suggestUrl + '&search=' + encodeURIComponent(query);

        fetch(url)
          .then(function(response) { return response.json(); })
          .then(function(data) {
            dropdown.innerHTML = '';

            if (data.length === 0) {
              dropdown.style.display = 'none';
              return;
            }

            var grouped = {};
            data.forEach(function(item) {
              if (!grouped[item.type]) {
                grouped[item.type] = [];
              }
              grouped[item.type].push(item);
            });

            for (var type in grouped) {
              var header = document.createElement('li');
              header.className = 'admin-search-group-header';
              header.textContent = grouped[type][0].type_label;
              dropdown.appendChild(header);

              grouped[type].forEach(function(item) {
                var li = document.createElement('li');
                var a = document.createElement('a');
                a.href = item.href;

                var content = '<div class="admin-search-item">';
                if (item.image) {
                  content += '<img src="' + item.image + '" alt="" class="admin-search-item-image">';
                } else {
                  content += '<div class="admin-search-item-icon"><i class="fa ' + getIconClass(item.type) + '"></i></div>';
                }
                content += '<div class="admin-search-item-info">';
                content += '<div class="admin-search-item-name">' + escapeHtml(item.name) + '</div>';
                if (item.subtitle) {
                  content += '<div class="admin-search-item-subtitle">' + escapeHtml(item.subtitle) + '</div>';
                }
                content += '</div>';
                content += '</div>';

                a.innerHTML = content;
                li.appendChild(a);
                dropdown.appendChild(li);
              });
            }

            var divider = document.createElement('li');
            divider.className = 'admin-search-divider';
            dropdown.appendChild(divider);

            var viewAll = document.createElement('li');
            var viewAllLink = document.createElement('a');
            viewAllLink.href = 'index.php?route=common/admin_search&user_token=' + userToken + '&search=' + encodeURIComponent(query);
            viewAllLink.className = 'admin-search-view-all';
            viewAllLink.innerHTML = '<i class="fa fa-search"></i> {{ text_view_all_results|default('View all results') }}';
            viewAll.appendChild(viewAllLink);
            dropdown.appendChild(viewAll);

            dropdown.style.display = 'block';
          })
          .catch(function(error) {
            console.error('Search error:', error);
            dropdown.style.display = 'none';
          });
      }, 300);
    });

    searchInput.addEventListener('blur', function() {
      setTimeout(function() {
        dropdown.style.display = 'none';
      }, 200);
    });

    searchInput.addEventListener('focus', function() {
      if (this.value.trim().length >= 2 && dropdown.innerHTML) {
        dropdown.style.display = 'block';
      }
    });

    searchInput.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        dropdown.style.display = 'none';
      } else if (e.key === 'Enter') {
        e.preventDefault();
        var query = this.value.trim();
        if (query) {
          window.location.href = 'index.php?route=common/admin_search&user_token=' + userToken + '&search=' + encodeURIComponent(query);
        }
      }
    });
  }

  function getIconClass(type) {
    var icons = {
      'product': 'fa-tag',
      'category': 'fa-folder',
      'manufacturer': 'fa-industry',
      'information': 'fa-file-text-o',
      'order': 'fa-shopping-cart',
      'customer': 'fa-user'
    };
    return icons[type] || 'fa-circle';
  }

  function escapeHtml(text) {
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
});
</script>
