<!DOCTYPE html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
<meta charset="UTF-8" />
<title>{{ title }}</title>
<base href="{{ base }}" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link href="https://fonts.googleapis.com/css?family=Inter:400,500,600,700,800&subset=latin,cyrillic-ext" rel="stylesheet" />
<link rel="icon" type="image/png" href="../image/catalog/cart.png" />
<link href="view/stylesheet/dockercart_login.css?v={{ dockercart_version }}" type="text/css" rel="stylesheet" />
<script src="view/javascript/lucide.min.js"></script>
</head>
<body>
<div class="login-wrapper">
	<div class="login-card">
		<div class="login-logo">
			<img src="view/image/logo.png" alt="{{ heading_title }}" />
		</div>
		<div class="login-title">{{ heading_title }}</div>
		<div class="instruction-text">{{ text_email }}</div>

		{% if error_warning %}
		<div class="alert alert-danger">
			<i data-lucide="alert-circle"></i>
			<span>{{ error_warning }}</span>
		</div>
		{% endif %}

		<form action="{{ action }}" method="post" enctype="multipart/form-data" autocomplete="off">
			<div class="form-group">
				<label class="form-label" for="input-email">{{ entry_email }}</label>
				<div class="input-wrap">
					<i data-lucide="mail" class="input-icon"></i>
					<input type="text" name="email" value="{{ email }}" placeholder="{{ entry_email }}" id="input-email" class="form-control" autocomplete="email" />
				</div>
			</div>
			<div class="form-actions">
				<a href="{{ cancel }}" class="btn-secondary">
					<i data-lucide="arrow-left"></i>
					{{ button_cancel }}
				</a>
				<button type="submit" class="btn-primary"><i data-lucide="refresh-cw"></i>{{ button_reset }}</button>
			</div>
		</form>
	</div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
	if (window.lucide) {
		lucide.createIcons();
	}
});
</script>
</body>
</html>
