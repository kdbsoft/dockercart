<footer id="footer">{{ text_footer }}<br/>{{ text_version }}</footer></div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const userToken = document.body.getAttribute('data-user-token');
    if (!userToken) return;

    for (const input of document.querySelectorAll('input[name*="_seo_url"]')) {
        if (input.dataset.dcgProcessed) continue;
        input.dataset.dcgProcessed = '1';

        const group = input.closest('.input-group');
        if (!group) continue;

        const wrap = document.createElement('span');
        wrap.className = 'input-group-btn';

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'btn btn-default btn-xs';
        btn.innerHTML = '<i class="fa fa-magic"></i>';
        btn.title = 'Generate SEO URL from name';

        wrap.append(btn);
        group.append(wrap);

        btn.addEventListener('click', async () => {
            const match = input.name.match(/^(\w+)_seo_url\[\d+\]\[(\d+)\]$/);
            if (!match) return;

            const langId = match[2];
            const nameInput =
                document.getElementById(`input-name${langId}`) ||
                document.getElementById(`input-title${langId}`) ||
                document.getElementById('input-name');

            const name = nameInput?.value.trim();
            if (!name) {
                alert('Enter a name/title first');
                return;
            }

            try {
                const resp = await fetch(`index.php?route=extension/module/dockercart_seo_generator/generateSeoUrlAjax&user_token=${userToken}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ name })
                });
                const json = await resp.json();
                if (json.error) { alert(json.error); return; }
                input.value = json.keyword;
            } catch {
                alert('AJAX error');
            }
        });
    }
});
</script>
</body></html>
