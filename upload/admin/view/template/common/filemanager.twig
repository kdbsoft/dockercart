{% macro tree(children, active) %}
{% for node in children %}
<li{% if node.path == active %} class="active"{% endif %} data-path="{{ node.path }}">
	<div class="tree-item{% if node.path == active %} active{% endif %}" data-directory="{{ node.path }}">
		{% if node.children %}
		<i class="fa fa-chevron-right tree-toggle"></i>
		{% else %}
		<span class="tree-toggle-placeholder"></span>
		{% endif %}
		<i class="fa fa-folder tree-folder-icon"></i>
		<span class="tree-link">{{ node.name }}</span>
	</div>
	{% if node.children %}
	<ul>
		{{ _self.tree(node.children, active) }}
	</ul>
	{% endif %}
</li>
{% endfor %}
{% endmacro %}

<div id="filemanager" class="modal-dialog modal-lg">
  <div class="modal-content">
    <div class="modal-header">
      <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
      <h4 class="modal-title">{{ heading_title }}</h4>
    </div>
    <div class="modal-body">
      <div class="filemanager-layout">
        <div class="filemanager-sidebar">
          <div class="sidebar-header">
            <i class="fa fa-folder-open"></i> {{ text_navigation }}
          </div>
          <div class="sidebar-tree">
            <ul>
              {{ _self.tree(directory_tree, directory) }}
            </ul>
          </div>
        </div>
        <div class="filemanager-main" id="filemanager-main">
          <div class="row fm-toolbar">
            <div class="col-sm-7">
              <a href="{{ parent }}" data-toggle="tooltip" title="{{ button_parent }}" id="button-parent" class="btn btn-default"><i class="fa fa-level-up"></i></a>
              <a href="{{ refresh }}" data-toggle="tooltip" title="{{ button_refresh }}" id="button-refresh" class="btn btn-default"><i class="fa fa-refresh"></i></a>
              <button type="button" data-toggle="tooltip" title="{{ button_upload }}" id="button-upload" class="btn btn-primary"><i class="fa fa-upload"></i></button>
              <button type="button" data-toggle="tooltip" title="{{ button_folder }}" id="button-folder" class="btn btn-default"><i class="fa fa-folder"></i></button>
              <button type="button" data-toggle="tooltip" title="{{ button_delete }}" id="button-delete" class="btn btn-danger"><i class="fa fa-trash-o"></i></button>
            </div>
            <div class="col-sm-5">
              <div class="input-group">
                <input type="text" name="search" value="{{ filter_name }}" placeholder="{{ entry_search }}" class="form-control">
                <span class="input-group-btn">
                <button type="button" data-toggle="tooltip" title="{{ button_search }}" id="button-search" class="btn btn-primary"><i class="fa fa-search"></i></button>
                </span>
              </div>
            </div>
          </div>
          <div class="fm-size-control">
            <span class="fm-size-label">{{ text_size }}:</span>
            <input type="range" class="fm-size-slider" min="60" max="200" value="100" step="10">
            <span class="fm-size-btns">
              <button type="button" class="btn btn-sm btn-default fm-size-preset" data-size="60">{{ text_size_small }}</button>
              <button type="button" class="btn btn-sm btn-default fm-size-preset active" data-size="100">{{ text_size_medium }}</button>
              <button type="button" class="btn btn-sm btn-default fm-size-preset" data-size="180">{{ text_size_large }}</button>
            </span>
          </div>
          <div class="filemanager-grid" style="--thumb-size: 100px">
            {% for image in images %}
            <div class="filemanager-item text-center">
              {% if image.type == 'directory' %}
              <div class="filemanager-thumb"><a href="{{ image.href }}" class="directory"><i class="fa fa-folder fa-5x"></i></a></div>
              <label>
                <input type="checkbox" name="path[]" value="{{ image.path }}" />
                {{ image.name }}</label>
              {% endif %}
              {% if image.type == 'image' %}
              <div class="filemanager-thumb"><a href="{{ image.href }}" class="thumbnail"><img src="{{ image.thumb }}" alt="{{ image.name }}" title="{{ image.name }}" /></a></div>
              <label>
                <input type="checkbox" name="path[]" value="{{ image.path }}" />
                {{ image.name }}</label>
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">{{ pagination }}</div>
  </div>
</div>
<script type="text/javascript"><!--
var fmUserToken = '{{ user_token|escape('js') }}';
var fmType = '{{ type|escape('js') }}';
var fmCurrentDirectory = '{{ directory|e('js') }}';
{% if thumb %}
var fmThumb = '{{ thumb|escape('js') }}';
{% endif %}
{% if target %}
var fmTarget = '{{ target|escape('js') }}';
{% endif %}

function fmBuildUrl(directory, filter_name) {
	var url = 'index.php?route=common/filemanager&user_token=' + fmUserToken;
	if (directory) url += '&directory=' + encodeURIComponent(directory);
	if (filter_name) url += '&filter_name=' + encodeURIComponent(filter_name);
	{% if thumb %}if (fmThumb) url += '&thumb=' + fmThumb;{% endif %}
	{% if target %}if (fmTarget) url += '&target=' + fmTarget;{% endif %}
	url += '&type=' + fmType;
	return url;
}

function fmUpdateActiveTree(directory) {
	// Reset old active branch icons to closed
	$('.sidebar-tree li.active').each(function() {
		var $li = $(this);
		$li.removeClass('expanded');
		$li.find('> .tree-item .tree-toggle').removeClass('fa-chevron-down').addClass('fa-chevron-right');
		$li.find('> .tree-item .tree-folder-icon').removeClass('fa-folder-open').addClass('fa-folder');
	});
	$('.sidebar-tree .tree-item').removeClass('active');
	$('.sidebar-tree li').removeClass('active');
	if (directory) {
		var $li = $('.sidebar-tree li[data-path="' + directory.replace(/"/g, '\\"') + '"]');
		if ($li.length) {
			$li.addClass('active');
			$li.children('.tree-item').addClass('active');
			$li.addClass('expanded');
			$li.find('> .tree-item .tree-toggle').removeClass('fa-chevron-right').addClass('fa-chevron-down');
			$li.find('> .tree-item .tree-folder-icon').removeClass('fa-folder').addClass('fa-folder-open');
			$li.parents('li').addClass('expanded');
			$li.parents('li').children('.tree-item').find('.tree-toggle').removeClass('fa-chevron-right').addClass('fa-chevron-down');
			$li.parents('li').children('.tree-item').find('.tree-folder-icon').removeClass('fa-folder').addClass('fa-folder-open');
		}
	}
}

function fmBindEvents() {
	{% if target %}
	$('#filemanager-main a.thumbnail').on('click', function(e) {
		e.preventDefault();
		$('#{{ thumb|escape('js') }}').find('img').attr('src', $(this).find('img').attr('src'));
		$('#{{ target|escape('js') }}').val($(this).closest('.filemanager-item').find('input').val());
		$('#modal-image').modal('hide');
	});
	{% endif %}

	$('#filemanager-main a.directory').on('click', function(e) {
		e.preventDefault();
		fmLoadMain($(this).attr('href'));
	});

	$('#filemanager-main .pagination a').on('click', function(e) {
		e.preventDefault();
		fmLoadMain($(this).attr('href'));
	});

	$('#filemanager-main input[name=\'search\']').on('keydown', function(e) {
		if (e.which == 13) {
			$('#button-search').trigger('click');
		}
	});

	$('#filemanager-main #button-search').on('click', function(e) {
		var filter_name = $('input[name=\'search\']').val();
		var url = fmBuildUrl(fmCurrentDirectory, filter_name);
		fmLoadMain(url);
	});

	// Upload button
	$('#button-upload').off('click').on('click', function() {
		$('#form-upload').remove();
		$('body').prepend('<form enctype="multipart/form-data" id="form-upload" style="display: none;"><input type="file" name="file[]" value="" multiple="multiple" /></form>');
		$('#form-upload input[name=\'file[]\']').trigger('click');

		if (typeof timer != 'undefined') {
			clearInterval(timer);
		}

		timer = setInterval(function() {
			if ($('#form-upload input[name=\'file[]\']').val() != '') {
				clearInterval(timer);

				$.ajax({
					url: 'index.php?route=common/filemanager/upload&user_token={{ user_token }}&directory=' + encodeURIComponent(fmCurrentDirectory) + '&type={{ type }}',
					type: 'post',
					dataType: 'json',
					data: new FormData($('#form-upload')[0]),
					cache: false,
					contentType: false,
					processData: false,
					beforeSend: function() {
						$('#button-upload i').replaceWith('<i class="fa fa-circle-o-notch fa-spin"></i>');
						$('#button-upload').prop('disabled', true);
					},
					complete: function() {
						$('#button-upload i').replaceWith('<i class="fa fa-upload"></i>');
						$('#button-upload').prop('disabled', false);
					},
					success: function(json) {
						if (json['error']) {
							alert(json['error']);
						}
						if (json['success']) {
							alert(json['success']);
							$('#button-refresh').trigger('click');
						}
					},
					error: function(xhr, ajaxOptions, thrownError) {
						alert('Error: File upload failed. Please check the file and try again.');
					}
				});
			}
		}, 500);
	});

	// Folder create popover
	$('#button-folder').popover('destroy');
	$('#button-folder').popover({
		html: true,
		sanitize: false,
		placement: 'bottom',
		trigger: 'click',
		title: '{{ entry_folder }}',
		content: function() {
			html  = '<div class="input-group">';
			html += '  <input type="text" name="folder" value="" placeholder="{{ entry_folder }}" class="form-control">';
			html += '  <span class="input-group-btn"><button type="button" title="{{ button_folder }}" id="button-create" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></span>';
			html += '</div>';
			return html;
		}
	});
	$('#button-folder').off('shown.bs.popover').on('shown.bs.popover', function() {
		$('#button-create').off('click').on('click', function() {
			$.ajax({
				url: 'index.php?route=common/filemanager/folder&user_token={{ user_token }}&directory=' + encodeURIComponent(fmCurrentDirectory),
				type: 'post',
				dataType: 'json',
				data: 'folder=' + encodeURIComponent($('input[name=\'folder\']').val()),
				beforeSend: function() {
					$('#button-create').prop('disabled', true);
				},
				complete: function() {
					$('#button-create').prop('disabled', false);
				},
				success: function(json) {
					if (json['error']) {
						alert(json['error']);
					}
					if (json['success']) {
						alert(json['success']);
						$('#button-refresh').trigger('click');
					}
				},
				error: function(xhr, ajaxOptions, thrownError) {
					alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
				}
			});
		});
	});
}

function fmLoadMain(url) {
	var match = url.match(/[?&]directory=([^&]*)/);
	fmCurrentDirectory = match ? decodeURIComponent(match[1]) : '';

	$.get(url, function(html) {
		var $doc = $($.parseHTML(html));
		$('#filemanager-main').html($doc.find('#filemanager-main').html());
		$('.modal-footer').html($doc.find('.modal-footer').html());
		fmUpdateActiveTree(fmCurrentDirectory);
		fmBindEvents();
		fmApplySize();
	});
}

function fmReloadFull(url) {
	$('#modal-image').load(url, function() {
		fmApplySize();
	});
}

$(document).ready(function() {
	fmBindEvents();
});

$('#button-parent').on('click', function(e) {
	e.preventDefault();
	fmLoadMain($(this).attr('href'));
});

$('#button-refresh').on('click', function(e) {
	e.preventDefault();
	fmReloadFull($(this).attr('href'));
});
//--></script>
<script type="text/javascript"><!--
$('#modal-image #button-delete').on('click', function(e) {
	if (confirm('{{ text_confirm }}')) {
		$.ajax({
			url: 'index.php?route=common/filemanager/delete&user_token={{ user_token }}',
			type: 'post',
			dataType: 'json',
			data: $('input[name^=\'path\']:checked'),
			beforeSend: function() {
				$('#button-delete').prop('disabled', true);
			},
			complete: function() {
				$('#button-delete').prop('disabled', false);
			},
			success: function(json) {
				if (json['error']) {
					alert(json['error']);
				}

				if (json['success']) {
					alert(json['success']);
					$('#button-refresh').trigger('click');
				}
			},
			error: function(xhr, ajaxOptions, thrownError) {
				alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
			}
		});
	}
});
//--></script>
<script type="text/javascript"><!--
// Directory tree: expand/collapse (delegated — sidebar stays across partial loads)
function fmToggleBranch($el) {
	var $li = $el.closest('li');
	if (!$li.find('> ul').length) return;
	$li.toggleClass('expanded');
	$li.find('> .tree-item .tree-toggle').toggleClass('fa-chevron-right fa-chevron-down');
	$li.find('> .tree-item .tree-folder-icon').toggleClass('fa-folder fa-folder-open');
}

$('.sidebar-tree').on('click', '.tree-toggle, .tree-folder-icon', function(e) {
	e.preventDefault();
	e.stopPropagation();
	fmToggleBranch($(this));
});

// Directory tree: navigate on row click (entire .tree-item is clickable)
$('.sidebar-tree').on('click', '.tree-item', function(e) {
	if ($(e.target).closest('.tree-toggle, .tree-folder-icon').length) return;
	e.preventDefault();
	fmLoadMain(fmBuildUrl($(this).data('directory') || '', ''));
});

// Thumbnail size slider (delegated on #modal-image so it survives partial content replacement)
function fmApplySize() {
	try {
		var size = sessionStorage.getItem('fm_thumb_size');
		if (!size) size = 100;
		$('.filemanager-grid').css('--thumb-size', size + 'px');
		$('.fm-size-slider').val(size);
		$('.fm-size-preset').removeClass('active');
		$('.fm-size-preset[data-size="' + size + '"]').addClass('active');
	} catch(e) {}
}

$('#modal-image').on('input', '.fm-size-slider', function() {
	var size = parseInt($(this).val());
	$('.filemanager-grid').css('--thumb-size', size + 'px');
	$('.fm-size-preset').removeClass('active');
	$('.fm-size-preset[data-size="' + size + '"]').addClass('active');
	try { sessionStorage.setItem('fm_thumb_size', size); } catch(e) {}
});

$('#modal-image').on('click', '.fm-size-preset', function() {
	var size = parseInt($(this).data('size'));
	$('.filemanager-grid').css('--thumb-size', size + 'px');
	$('.fm-size-slider').val(size);
	$('.fm-size-preset').removeClass('active');
	$(this).addClass('active');
	try { sessionStorage.setItem('fm_thumb_size', size); } catch(e) {}
});

// Restore saved size on initial load
fmApplySize();
//--></script>
