{{ header }}
<style>
  .category-row.hidden-row {
    display: none;
  }

  .category-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
    align-items: center;
    justify-content: space-between;
  }

  .category-toolbar-actions {
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }

  .category-search-wrap {
    min-width: 240px;
    max-width: 360px;
    width: 100%;
  }

  .category-search-wrap .form-control {
    height: 34px;
  }

  #category-tree-table td {
    vertical-align: middle;
  }

  .category-name-cell {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 8px;
  }

  .category-name-text {
    display: inline-block;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
    white-space: normal;
    line-height: 1.35;
  }
  .category-sub-prefix {
    color: #6c757d;
    font-weight: 600;
  }

  .category-toggle {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #d6d8db;
    border-radius: 3px;
    background: #fff;
    color: #5c6670;
    padding: 0;
    cursor: pointer;
    flex: 0 0 auto;
  }

  .category-toggle .fa {
    font-size: 10px;
    transition: transform .15s ease;
  }

  .category-toggle[aria-expanded="true"] .fa {
    transform: rotate(90deg);
  }

  .category-toggle-spacer {
    width: 16px;
    height: 16px;
    display: inline-block;
    flex: 0 0 auto;
  }

  .category-depth-badge {
    display: inline-block;
    font-size: 10px;
    line-height: 1;
    color: #6c757d;
    background: #f1f3f5;
    border: 1px solid #e2e5e8;
    border-radius: 10px;
    padding: 3px 6px;
    flex: 0 0 auto;
  }
</style>
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right"><a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus"></i></a> <a href="{{ repair }}" data-toggle="tooltip" title="{{ button_rebuild }}" class="btn btn-default"><i class="fa fa-refresh"></i></a>
        <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-category').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
  <div class="panel-heading__icon"><i class="fa fa-list"></i></div>
  <div>
    <h3 class="panel-title">{{ text_list }}</h3>
    <div class="panel-heading__subtitle">{{ text_list_subtitle }}</div>
  </div>
</div>
      <div class="panel-body">
        <div class="category-toolbar">
          <div class="category-toolbar-actions">
            <button type="button" class="btn btn-default btn-sm" id="expand-all-categories"><i class="fa fa-plus-square-o"></i> {{ button_expand_all }}</button>
            <button type="button" class="btn btn-default btn-sm" id="collapse-all-categories"><i class="fa fa-minus-square-o"></i> {{ button_collapse_all }}</button>
          </div>
          <div class="category-search-wrap">
            <input type="search" id="category-tree-search" class="form-control" placeholder="{{ text_quick_find }}" autocomplete="off" />
          </div>
        </div>
        <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-category">
          <div class="table-responsive">
            <table class="table table-bordered table-hover" id="category-tree-table">
              <thead>
                <tr>
                  <td style="width: 32px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                  <td style="width: 120px;" class="text-center">{{ column_image }}</td>
                  <td class="text-left">{% if sort == 'name' %}
                    <a href="{{ sort_name }}" class="{{ order|lower }}">{{ column_name }}</a>
                    {% else %}
                    <a href="{{ sort_name }}">{{ column_name }}</a>
                    {% endif %}</td>
                  <td class="text-right">{% if sort == 'sort_order' %}
                    <a href="{{ sort_sort_order }}" class="{{ order|lower }}">{{ column_sort_order }}</a>
                    {% else %}
                    <a href="{{ sort_sort_order }}">{{ column_sort_order }}</a>
                    {% endif %}</td>
                  <td class="text-right">{{ column_action }}</td>
                </tr>
              </thead>
              <tbody>
                {% if categories %}
                {% for category in categories %}
                <tr class="category-row{% if category.level > 0 %} hidden-row{% endif %}" data-category-id="{{ category.category_id }}" data-parent-id="{{ category.parent_id }}" data-level="{{ category.level }}">
                  <td class="text-center">{% if category.category_id in selected %}
                    <input type="checkbox" name="selected[]" value="{{ category.category_id }}" checked="checked" />
                    {% else %}
                    <input type="checkbox" name="selected[]" value="{{ category.category_id }}" />
                    {% endif %}</td>
                  <td class="text-center"><input type="hidden" id="input-image-{{ category.category_id }}" value="{{ category.image_path }}" /><a href="javascript:void(0);" class="category-image-edit" id="thumb-image-{{ category.category_id }}" data-category-id="{{ category.category_id }}">{% if category.image %} <img src="{{ category.image }}" alt="{{ category.name }}" class="img-thumbnail" /> {% else %} <span class="img-thumbnail list"><i class="fa fa-camera fa-2x"></i></span> {% endif %}</a></td>
                  <td class="text-left">
                    <div class="category-name-cell" style="padding-left: {{ category.indent }}px;">
                      {% if category.has_children %}
                      <button type="button" class="category-toggle" data-category-toggle="{{ category.category_id }}" aria-label="Toggle subcategories" aria-expanded="false">
                        <i class="fa fa-chevron-right" aria-hidden="true"></i>
                      </button>
                      {% else %}
                      <span class="category-toggle-spacer" aria-hidden="true"></span>
                      {% endif %}
                      {% if category.level > 0 %}<span class="category-depth-badge">L{{ category.level }}</span>{% endif %}
                      <span class="category-name-text">
                        <span class="inline-edit" data-category-id="{{ category.category_id }}" data-field="name" data-value="{{ category.name_raw }}">{{ category.name }}<i class="fa fa-pencil-square-o inline-edit-icon"></i></span>
                      </span>
                    </div>
                  </td>
                  <td class="text-right">
                    <span class="inline-edit" data-category-id="{{ category.category_id }}" data-field="sort_order" data-value="{{ category.sort_order_raw }}">{{ category.sort_order }}<i class="fa fa-pencil-square-o inline-edit-icon"></i></span>
                  </td>
                  <td class="text-right"><a href="{{ category.edit }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a></td>
                </tr>
                {% endfor %}
                {% else %}
                <tr>
                  <td class="text-center" colspan="5">{{ text_no_results }}</td>
                </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
        <div class="row">
          <div class="col-sm-6 text-left">{{ pagination }}</div>
          <div class="col-sm-6 text-right">{{ results }}</div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
(function() {
  var rows = Array.prototype.slice.call(document.querySelectorAll('#category-tree-table .category-row'));
  var storageKey = 'dockercart.admin.category_tree_expanded.v1';

  if (!rows.length) {
    return;
  }

  var rowById = {};
  var childrenByParent = {};

  rows.forEach(function(row) {
    var id = row.getAttribute('data-category-id');
    var parentId = row.getAttribute('data-parent-id');

    rowById[id] = row;

    if (!childrenByParent[parentId]) {
      childrenByParent[parentId] = [];
    }

    childrenByParent[parentId].push(row);
  });

  var getDirectChildren = function(categoryId) {
    return childrenByParent[String(categoryId)] || [];
  };

  var getToggle = function(categoryId) {
    return document.querySelector('[data-category-toggle="' + categoryId + '"]');
  };

  var readExpandedState = function() {
    try {
      var raw = window.localStorage.getItem(storageKey);

      if (!raw) {
        return [];
      }

      var parsed = JSON.parse(raw);

      return Array.isArray(parsed) ? parsed.map(String) : [];
    } catch (error) {
      return [];
    }
  };

  var writeExpandedState = function(ids) {
    try {
      window.localStorage.setItem(storageKey, JSON.stringify(ids));
    } catch (error) {
      // ignore storage quota / privacy mode errors
    }
  };

  var collectExpandedIds = function() {
    return Array.prototype.map.call(document.querySelectorAll('.category-toggle[aria-expanded="true"]'), function(toggle) {
      return String(toggle.getAttribute('data-category-toggle'));
    });
  };

  var persistExpandedState = function() {
    if (searchInput && searchInput.value && searchInput.value.trim() !== '') {
      return;
    }

    writeExpandedState(collectExpandedIds());
  };

  var setRowVisible = function(row, visible) {
    row.classList.toggle('hidden-row', !visible);
  };

  var hideBranch = function(categoryId) {
    getDirectChildren(categoryId).forEach(function(childRow) {
      setRowVisible(childRow, false);

      var childId = childRow.getAttribute('data-category-id');
      var childToggle = getToggle(childId);

      if (childToggle) {
        childToggle.setAttribute('aria-expanded', 'false');
      }

      hideBranch(childId);
    });
  };

  var showDirectChildren = function(categoryId) {
    getDirectChildren(categoryId).forEach(function(childRow) {
      setRowVisible(childRow, true);
    });
  };

  var toggleBranch = function(categoryId, forceExpand) {
    var toggle = getToggle(categoryId);

    if (!toggle) {
      return;
    }

    var shouldExpand = (typeof forceExpand === 'boolean') ? forceExpand : (toggle.getAttribute('aria-expanded') !== 'true');

    toggle.setAttribute('aria-expanded', shouldExpand ? 'true' : 'false');

    if (shouldExpand) {
      showDirectChildren(categoryId);
    } else {
      hideBranch(categoryId);
    }

    persistExpandedState();
  };

  var expandAll = function(skipPersist) {
    rows.forEach(function(row) {
      setRowVisible(row, true);
    });

    Array.prototype.forEach.call(document.querySelectorAll('.category-toggle'), function(toggle) {
      toggle.setAttribute('aria-expanded', 'true');
    });

    if (!skipPersist) {
      persistExpandedState();
    }
  };

  var collapseAll = function(skipPersist) {
    rows.forEach(function(row) {
      var level = parseInt(row.getAttribute('data-level') || '0', 10);
      setRowVisible(row, level === 0);
    });

    Array.prototype.forEach.call(document.querySelectorAll('.category-toggle'), function(toggle) {
      toggle.setAttribute('aria-expanded', 'false');
    });

    if (!skipPersist) {
      persistExpandedState();
    }
  };

  var restoreExpandedState = function() {
    var expandedIds = readExpandedState();

    collapseAll(true);

    if (!expandedIds.length) {
      return;
    }

    expandedIds.sort(function(a, b) {
      var rowA = rowById[a];
      var rowB = rowById[b];
      var levelA = rowA ? parseInt(rowA.getAttribute('data-level') || '0', 10) : 0;
      var levelB = rowB ? parseInt(rowB.getAttribute('data-level') || '0', 10) : 0;

      return levelA - levelB;
    });

    expandedIds.forEach(function(categoryId) {
      var row = rowById[String(categoryId)];

      if (!row) {
        return;
      }

      var currentParentId = row.getAttribute('data-parent-id');

      while (currentParentId && currentParentId !== '0') {
        var parentRow = rowById[currentParentId];
        var parentToggle = getToggle(currentParentId);

        if (!parentRow || !parentToggle) {
          break;
        }

        parentToggle.setAttribute('aria-expanded', 'true');
        showDirectChildren(currentParentId);
        setRowVisible(parentRow, true);

        currentParentId = parentRow.getAttribute('data-parent-id');
      }

      var toggle = getToggle(categoryId);

      if (toggle) {
        toggle.setAttribute('aria-expanded', 'true');
        showDirectChildren(categoryId);
      }
    });
  };

  Array.prototype.forEach.call(document.querySelectorAll('.category-toggle'), function(toggle) {
    toggle.addEventListener('click', function(event) {
      event.preventDefault();
      var categoryId = toggle.getAttribute('data-category-toggle');
      toggleBranch(categoryId);
    });
  });

  var expandAllButton = document.getElementById('expand-all-categories');
  var collapseAllButton = document.getElementById('collapse-all-categories');
  var searchInput = document.getElementById('category-tree-search');

  if (expandAllButton) {
    expandAllButton.addEventListener('click', function() {
      expandAll();
    });
  }

  if (collapseAllButton) {
    collapseAllButton.addEventListener('click', function() {
      collapseAll();
      if (searchInput) {
        searchInput.value = '';
      }
    });
  }

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      var query = (searchInput.value || '').toLowerCase().trim();

      if (!query) {
        restoreExpandedState();
        return;
      }

      var visibleIds = {};

      rows.forEach(function(row) {
        var nameCell = row.querySelector('.category-name-text');
        var nameText = nameCell ? nameCell.textContent.toLowerCase() : '';

        if (nameText.indexOf(query) !== -1) {
          var current = row;

          while (current) {
            var currentId = current.getAttribute('data-category-id');
            var parentId = current.getAttribute('data-parent-id');

            visibleIds[currentId] = true;

            if (!parentId || parentId === '0') {
              break;
            }

            current = rowById[parentId] || null;
          }
        }
      });

      rows.forEach(function(row) {
        var id = row.getAttribute('data-category-id');
        setRowVisible(row, !!visibleIds[id]);
      });

      Array.prototype.forEach.call(document.querySelectorAll('.category-toggle'), function(toggle) {
        var categoryId = toggle.getAttribute('data-category-toggle');
        var hasVisibleChild = getDirectChildren(categoryId).some(function(childRow) {
          return !childRow.classList.contains('hidden-row');
        });

        toggle.setAttribute('aria-expanded', hasVisibleChild ? 'true' : 'false');
      });
    });
  }

  restoreExpandedState();
})();
</script>
<script type="text/javascript"><!--
$(document).on('click', '.category-image-edit', function(e) {
	e.preventDefault();

	var $link = $(this);
	var categoryId = $link.data('category-id');

	$('#modal-image').remove();

	$.ajax({
		url: 'index.php?route=common/filemanager&user_token={{ user_token }}',
		dataType: 'html',
		success: function(html) {
			$('body').append('<div id="modal-image" class="modal">' + html + '</div>');

			$('#modal-image').on('click', 'a.thumbnail', function(e) {
				e.preventDefault();

				var imagePath = $(this).closest('.filemanager-item').find('input[name^=\'path\']').val();
				var thumbSrc = $(this).find('img').attr('src');

				var $img = $link.find('img');
				if ($img.length) {
					$img.attr('src', thumbSrc);
				} else {
					$link.html('<img src="' + thumbSrc + '" alt="" class="img-thumbnail" />');
				}

				$.ajax({
					url: 'index.php?route=catalog/category/updateImage&user_token={{ user_token }}',
					type: 'post',
					dataType: 'json',
					data: { category_id: categoryId, image: imagePath }
				});

				$('#modal-image').modal('hide');
			});

			$('#modal-image').modal('show');
		}
	});
});
//--></script>
<style>
.inline-edit { cursor: default; }
.inline-edit .inline-edit-icon { margin-left: 4px; font-size: 13px; opacity: 0.3; cursor: pointer; }
.inline-edit:hover .inline-edit-icon { opacity: 0.8; }
.inline-edit-input { width: 80px; text-align: right; display: inline-block !important; height: 28px; padding: 3px 8px; }
.inline-edit-name-input { width: 200px; display: inline-block !important; height: 28px; padding: 3px 8px; }
.inline-edit-error { margin-left: 4px; font-size: 11px; white-space: nowrap; }
</style>
<script type="text/javascript"><!--
$(document).on('click', '.inline-edit-icon', function(e) {
	e.stopPropagation();

	var $span = $(this).closest('.inline-edit');
	if ($span.find('input, select').length) return;

	var field = $span.data('field');
	var rawValue = $span.data('value');
	var categoryId = $span.data('category-id');

	$span.data('display', $span.html());

	if (field === 'name') {
		$.ajax({
			url: 'index.php?route=catalog/category/getName&user_token={{ user_token }}&category_id=' + categoryId,
			dataType: 'json',
			success: function(json) {
				if (json['error']) {
					$span.html($span.data('display') + ' <span class="text-danger inline-edit-error">' + json['error'] + '</span>');
					setTimeout(function() { $span.html($span.data('display')); }, 3000);
					return;
				}

				var html = '<div class="inline-edit-names" style="white-space:nowrap;">';
				$.each(json['languages'], function(i, lang) {
					var val = json['names'][lang.language_id] || '';
					html += '<div style="margin-bottom:2px;">';
					html += '<span style="font-weight:bold;font-size:11px;margin-right:4px;">' + lang.name + ':</span>';
					html += '<input type="text" class="form-control input-sm inline-edit-name-input" data-lang-id="' + lang.language_id + '" value="' + val.replace(/"/g, '&quot;') + '" style="width:200px;display:inline-block;">';
					html += '</div>';
				});
				html += '<div style="margin-top:4px;"><button type="button" class="btn btn-primary btn-xs inline-edit-name-save">{{ button_save }}</button></div>';
				html += '</div>';

				$span.html(html);
				$span.find('input').first().focus();

				var reverted = false;

				$span.on('click', '.inline-edit-name-save', function() {
					var names = {};
					$span.find('.inline-edit-name-input').each(function() {
						names[$(this).data('lang-id')] = $(this).val();
					});

					$.ajax({
						url: 'index.php?route=catalog/category/updateNames&user_token={{ user_token }}',
						type: 'post',
						dataType: 'json',
						data: { category_id: categoryId, names: names },
						success: function(res) {
							if (res['error']) {
								$span.append(' <span class="text-danger inline-edit-error">' + res['error'] + '</span>');
								setTimeout(function() { $span.find('.inline-edit-error').remove(); }, 3000);
							} else {
								reverted = true;
								$span.data('value', res['value_html']);
								$span.html(res['value_html'] + '<i class="fa fa-pencil-square-o inline-edit-icon"></i>');
							}
						},
						error: function() {
							$span.html($span.data('display'));
						}
					});
				});

				$span.find('.inline-edit-name-input').on('keydown', function(e) {
					if (e.which === 27) {
						reverted = true;
						$span.html($span.data('display'));
					}
				});

				$(document).one('click', function(e) {
					if (!$(e.target).closest('.inline-edit-names').length && !reverted) {
						$span.html($span.data('display'));
					}
				});
			},
			error: function() {
				$span.html($span.data('display'));
			}
		});
	} else {
		var currentDisplay = $span.clone().children('.inline-edit-icon').remove().end().text().trim();

		$span.html('<input type="text" class="form-control input-sm inline-edit-input" value="' + rawValue + '">');
		var $input = $span.find('input');
		$input.focus().select();

		function revert() {
			$span.html($span.data('display'));
		}

		function save() {
			var newValue = $input.val();

			$.ajax({
				url: 'index.php?route=catalog/category/updateField&user_token={{ user_token }}',
				type: 'post',
				dataType: 'json',
				data: { category_id: categoryId, field: field, value: newValue },
				success: function(json) {
					if (json['error']) {
						$span.html($span.data('display') + ' <span class="text-danger inline-edit-error">' + json['error'] + '</span>');
						setTimeout(function() { $span.html($span.data('display')); }, 3000);
					} else {
						$span.data('value', newValue);
						$span.html(json['value_html'] + '<i class="fa fa-pencil-square-o inline-edit-icon"></i>');
					}
				},
				error: function() {
					revert();
				}
			});
		}

		$input.on('blur', save);
		$input.on('keydown', function(e) {
			if (e.which === 13) { e.preventDefault(); $input.trigger('blur'); }
			if (e.which === 27) { revert(); }
		});
	}
});
//--></script>
