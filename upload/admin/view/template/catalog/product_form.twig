  <script type="text/javascript"><!--
  var attribute_row = {{ attribute_row }};

  function addAttribute() {
	  html = '<tr id="attribute-row' + attribute_row + '" class="attribute-row">';
	  html += '  <td class="text-left"><input type="text" name="product_attribute[' + attribute_row + '][name]" value="" placeholder="{{ entry_attribute }}" class="form-control attribute-name-input" style="position:relative;" /><input type="hidden" name="product_attribute[' + attribute_row + '][attribute_id]" value="" /></td>';
