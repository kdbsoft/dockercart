      $div.append(document.createTextNode(path));
      $div.append('<input type="hidden" name="product_category[]" value="' + id + '" />');
      $well.append($div);

      selectedCategories.push({category_id: id, name: path});
    });

    $('#category-tree-modal').modal('hide');
  });

  $('#product-category').delegate('.fa-minus-circle', 'click', function() {
