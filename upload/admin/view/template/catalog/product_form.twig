  <script type="text/javascript"><!--
  function dcUpdateBadges(el) {
	  var $card = $(el).closest('.dc-opt-card');
	  var qty = $card.find('input[name$="[quantity]"]').val();
	  var price = $card.find('input[name$="[price]"]').not('[name*="customer_group"]').val();
	  var price_prefix = $card.find('select[name$="[price_prefix]"]').not('[name*="customer_group"]').val();

	  var $qtyBadge = $card.find('[data-badge="qty"]');
	  $qtyBadge.text(qty + ' {{ text_qty_short|e('js') }}');
	  $qtyBadge.removeClass('dc-opt-badge--qty-ok dc-opt-badge--qty-zero');
	  $qtyBadge.addClass(parseFloat(qty) > 0 ? 'dc-opt-badge--qty-ok' : 'dc-opt-badge--qty-zero');

	  var $priceBadge = $card.find('[data-badge="price"]');
	  if (parseFloat(price) != 0) {
		  $priceBadge.text(price_prefix + price).show();
	  } else {
		  $priceBadge.hide();
	  }
  }

  function dcUpdateCardTitle(sel) {
	  var name = $(sel).find('option:selected').text();
	  $(sel).closest('.dc-opt-card').find('.dc-opt-card__title').text(name);
  }

  function dcUpdateHitBadge(cb) {
	  var $card = $(cb).closest('.dc-opt-card');
	  var $badges = $card.find('.dc-opt-card__badges');
	  if (cb.checked) {
		  if (!$badges.find('.dc-opt-badge--hit').length) {
			  $badges.prepend('<span class="dc-opt-badge dc-opt-badge--hit">{{ entry_hit|e("js") }}</span>');
		  }
	  } else {
		  $badges.find('.dc-opt-badge--hit').remove();
	  }
  }

  function dcRefreshColorImagePickers() {
	  var $pickers = $('.dc-color-img-picker');
	  if (!$pickers.length) return;

	  var imgs = [];
	  var $mainImg = $('input[name="image"]');
	  if ($mainImg.length && $mainImg.val()) {
		  imgs.push({ path: $mainImg.val(), thumb: $('#thumb-image img').attr('src') || '{{ placeholder|e("js") }}' });
	  }
	  $('.product-images').each(function() {
		  $(this).find('.dc-img-card').each(function() {
			  var $inp = $(this).find('input[name$="[image]"]');
			  if ($inp.length && $inp.val()) {
				  var $thumbImg = $(this).find('.dc-img-link img');
				  imgs.push({ path: $inp.val(), thumb: $thumbImg.attr('src') || '{{ placeholder|e("js") }}' });
			  }
		  });
	  });

	  $pickers.each(function() {
		  var $picker = $(this);
		  var selected = [];
		  try {
			  selected = JSON.parse($picker.attr('data-selected'));
		  } catch(e) { selected = []; }
		  if (!Array.isArray(selected)) selected = [];

		  var html = '';

		  if (!imgs.length) {
			  html = '<span class="text-muted" style="font-size:11px;">{{ text_color_images_empty|e("js") }}</span>';
		  } else {
			  html = '<div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:4px;">';

			  for (var i = 0; i < imgs.length; i++) {
				  var isSel = selected.indexOf(imgs[i].path) !== -1;
				  html += '<div class="dc-color-img-thumb' + (isSel ? ' dc-color-img-thumb--sel' : '') + '" data-img="' + imgs[i].path + '" style="width:48px;height:48px;border:2px solid ' + (isSel ? '#2563eb' : '#e5e7eb') + ';border-radius:6px;overflow:hidden;cursor:pointer;position:relative;" onclick="dcToggleColorImage(this)">';
				  html += '<img src="' + imgs[i].thumb + '" style="width:100%;height:100%;object-fit:cover;" />';
				  if (isSel) {
					  html += '<span style="position:absolute;top:2px;right:2px;width:14px;height:14px;background:#2563eb;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;color:#fff;">&#10003;</span>';
				  }
				  html += '</div>';
			  }

			  html += '</div>';
		  }

		  var optRow = $picker.attr('data-opt-row');
		  var ovRow = $picker.attr('data-ov-row');

		  var hiddenHtml = '';
		  for (var s = 0; s < selected.length; s++) {
			  hiddenHtml += '<input type="hidden" name="product_option[' + optRow + '][product_option_value][' + ovRow + '][color_images][]" value="' + selected[s] + '" />';
		  }

		  $picker.html(html + hiddenHtml);
	  });
  }

  function dcToggleColorImage(el) {
	  var $el = $(el);
	  var img = $el.attr('data-img');
	  var $picker = $el.closest('.dc-color-img-picker');
	  var $thumb = $el;

	  var isSel = $thumb.hasClass('dc-color-img-thumb--sel');

	  if (isSel) {
		  $thumb.removeClass('dc-color-img-thumb--sel');
		  $thumb.css('border-color', '#e5e7eb');
		  $thumb.find('span').remove();
	  } else {
		  $thumb.addClass('dc-color-img-thumb--sel');
		  $thumb.css('border-color', '#2563eb');
		  if (!$thumb.find('span').length) {
			  $thumb.append('<span style="position:absolute;top:2px;right:2px;width:14px;height:14px;background:#2563eb;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;color:#fff;">&#10003;</span>');
		  }
	  }

	  var selected = [];
	  $picker.find('.dc-color-img-thumb--sel').each(function() {
		  selected.push($(this).attr('data-img'));
	  });

	  $picker.attr('data-selected', JSON.stringify(selected));
	  $picker.find('input[name$="[color_images][]"]').remove();

	  var optRow = $picker.attr('data-opt-row');
	  var ovRow = $picker.attr('data-ov-row');

	  for (var s = 0; s < selected.length; s++) {
		  $picker.append('<input type="hidden" name="product_option[' + optRow + '][product_option_value][' + ovRow + '][color_images][]" value="' + selected[s] + '" />');
	  }
  }

