  <script type="text/javascript"><!--
  var articlesVisible = false;
  $('#toggle-articles').on('click', function() {
    articlesVisible = !articlesVisible;
    if (articlesVisible) {
      $('.dc-article-extra').show();
      $('#toggle-articles-text').text('{{ button_hide_articles }}');
      $(this).find('i').removeClass('fa-toggle-off').addClass('fa-toggle-on');
    } else {
      $('.dc-article-extra').hide();
      $('#toggle-articles-text').text('{{ button_show_articles }}');
      $(this).find('i').removeClass('fa-toggle-on').addClass('fa-toggle-off');
    }
  });
  //--></script>

