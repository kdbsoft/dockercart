                <span id="dc-option-mode-label" class="label {% if is_configurable %}label-primary{% else %}label-default{% endif %}" style="font-size:13px">
                  <i class="fa fa-circle"></i> {% if is_configurable %}{{ text_mode_combined }}{% else %}{{ text_mode_simple }}{% endif %}
                </span>
                <button type="button" id="dc-toggle-mode-btn" class="btn btn-sm btn-default">
                  {% if is_configurable %}
                    <i class="fa fa-arrow-left"></i> {{ text_switch_to_simple }}
                  {% else %}
                    {{ text_switch_to_combined }} <i class="fa fa-arrow-right"></i>
                  {% endif %}
                </button>
                <span id="dc-mode-saved" style="color:green;display:none;font-size:12px"><i class="fa fa-check"></i> {{ text_success_mode }}</span>
