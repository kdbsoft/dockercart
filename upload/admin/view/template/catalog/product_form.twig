                          <a href="javascript:void(0)" onclick="dcScrollToOption('option-section{{ option_row }}')">
                            <i class="fa fa-circle"></i> {{ product_option.name }}{% if product_option.required %} <span class="dc-opt-sidebar__required">*</span>{% endif %}
                            <small class="text-muted">({{ product_option.type }})</small>
                          </a>
                          <button type="button" class="dc-opt-sidebar__remove" onclick="dcRemoveOption('{{ option_row }}')" title="{{ button_remove }}">&times;</button>
                        </li>
                        {% set option_row = option_row + 1 %}
                      {% endfor %}
                    </ul>
                    <div class="dc-opt-sidebar__add">
                      <input type="text" name="option" value="" placeholder="{{ entry_option }}" id="input-option" class="form-control input-sm"/>
                    </div>
                  </div>
