		  'source': function(request, response) {
			  $.ajax({
				  url: 'index.php?route=catalog/attribute/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
				  dataType: 'json',
				  success: function(json) {
					  response($.map(json, function(item) {
						  return {
							  category: item.attribute_group,
							  label: item.name,
							  value: item.attribute_id
						  }
					  }));
				  }
			  });
		  },
		  'select': function(item) {
			  $('input[name=\'product_attribute[' + attribute_row + '][name]\']').val(item['label']);
			  $('input[name=\'product_attribute[' + attribute_row + '][attribute_id]\']').val(item['value']);
		  }
	  });
  }

  $('#attribute tbody tr.attribute-row').each(function(index, element) {
	  attributeautocomplete(index);
  });
  //--></script>
  <script type="text/javascript"><!--
  var option_row = {{ option_row }};
  var dcOptionMode = {{ is_configurable ? "'combined'" : "'simple'" }};
  var dcAxisOptionIds = {{ axis_option_ids|json_encode|raw }};

  $(document).ready(function() {
    if (dcOptionMode === 'combined') {
      loadVariantMatrix();
    }

    $('#dc-toggle-mode-btn').on('click', function() {
      var newMode = (dcOptionMode === 'simple') ? 'combined' : 'simple';

      if (newMode === 'simple') {
        if (!confirm('{{ text_confirm_switch_to_simple|e("js") }}')) {
          return;
        }
      }

      var productId = getDcProductId();

      if (!productId || productId == '0') {
        alert('{{ text_save_product_first|e("js") }}');
        return;
      }

      $.ajax({
        url: 'index.php?route=catalog/product_configurable/setMode&user_token={{ user_token }}',
        type: 'POST',
        data: {product_id: productId, mode: newMode},
        dataType: 'json',
        success: function(json) {
          if (json.error) {
            alert(json.error);
            return;
          }

          dcOptionMode = newMode;

          var $simpleOptions = $('#tab-option .row:first');
          var $axes = $('.dc-option-axis', $simpleOptions);

          if (newMode === 'simple') {
            $simpleOptions.removeClass('dc-opts-axis-hidden');
            $axes.find(':input').prop('disabled', false);
            $('#dc-variants-section').hide();
          } else {
            $simpleOptions.addClass('dc-opts-axis-hidden');
            $axes.find(':input').prop('disabled', true);
            $('#dc-variants-section').show();
            loadVariantMatrix();
          }

          $('#dc-mode-saved').fadeIn(200).delay(1500).fadeOut(400);

          var newLabel = newMode === 'combined' ? '{{ text_mode_combined }}' : '{{ text_mode_simple }}';
          var newBtnHtml = newMode === 'combined'
            ? '<i class="fa fa-arrow-left"></i> {{ text_switch_to_simple }}'
            : '{{ text_switch_to_combined }} <i class="fa fa-arrow-right"></i>';
          var newSpanClass = newMode === 'combined' ? 'label-primary' : 'label-default';

          $('#dc-toggle-mode-btn').html(newBtnHtml);
          $('#dc-option-mode-label').removeClass('label-primary label-default').addClass(newSpanClass).html('<i class="fa fa-circle"></i> ' + newLabel);
        }
      });
    });

    $('a[href="#tab-option"]').on('shown.bs.tab', function() {
      if (dcOptionMode === 'combined') {
        loadVariantMatrix();
      }
    });
  });

  function dcScrollToOption(sectionId) {
	  var el = document.getElementById(sectionId);
	  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function dcRemoveOption(option_row) {
	  $('#option-section' + option_row).remove();
	  $('#option-sidebar-list li[data-target="option-section' + option_row + '"]').remove();
  }

  $('input[name=\'option\']').autocomplete({
	  'source': function(request, response) {
		  $.ajax({
			  url: 'index.php?route=catalog/option/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
			  dataType: 'json',
			  success: function(json) {
				  response($.map(json, function(item) {
					  return {
						  category: item['category'],
						  label: item['name'],
						  value: item['option_id'],
						  type: item['type'],
						  option_value: item['option_value']
					  }
				  }));
			  }
		  });
	  },
	  'select': function(item) {
		  var html = '';
		  html += '<div class="dc-option-section" id="option-section' + option_row + '">';
		  html += '  <div class="dc-option-section__header">';
		  html += '    <span class="dc-option-section__title">' + item['label'] + '</span>';
		  html += '    <span class="dc-option-section__type">(' + item['type'] + ')</span>';
		  html += '    <div class="dc-option-section__controls">';
		  html += '      <label class="dc-option-section__required">';
		  html += '        <span>{{ entry_required|e('js') }}:</span>';
		  html += '        <select name="product_option[' + option_row + '][required]" class="form-control input-sm">';
		  html += '          <option value="1">{{ text_yes|e('js') }}</option>';
		  html += '          <option value="0">{{ text_no|e('js') }}</option>';
		  html += '        </select>';
		  html += '      </label>';
		  html += '      <button type="button" class="btn btn-danger btn-sm" onclick="dcRemoveOption(\'' + option_row + '\');">';
		  html += '        <i class="fa fa-trash"></i> {{ button_remove|e('js') }}';
		  html += '      </button>';
		  html += '    </div>';
		  html += '  </div>';
		  html += '  <div class="dc-option-section__body">';
		  html += '    <input type="hidden" name="product_option[' + option_row + '][product_option_id]" value="" />';
		  html += '    <input type="hidden" name="product_option[' + option_row + '][name]" value="' + item['label'] + '" />';
		  html += '    <input type="hidden" name="product_option[' + option_row + '][option_id]" value="' + item['value'] + '" />';
		  html += '    <input type="hidden" name="product_option[' + option_row + '][type]" value="' + item['type'] + '" />';

		  if (item['type'] == 'text') {
			  html += '    <div class="form-group">';
			  html += '      <label class="col-sm-2 control-label" for="input-value' + option_row + '">{{ entry_option_value|e('js') }}</label>';
			  html += '      <div class="col-sm-10"><input type="text" name="product_option[' + option_row + '][value]" value="" placeholder="{{ entry_option_value|e('js') }}" id="input-value' + option_row + '" class="form-control" /></div>';
			  html += '    </div>';
		  }

		  if (item['type'] == 'textarea') {
			  html += '    <div class="form-group">';
			  html += '      <label class="col-sm-2 control-label" for="input-value' + option_row + '">{{ entry_option_value|e('js') }}</label>';
			  html += '      <div class="col-sm-10"><textarea name="product_option[' + option_row + '][value]" rows="5" placeholder="{{ entry_option_value|e('js') }}" id="input-value' + option_row + '" class="form-control"></textarea></div>';
			  html += '    </div>';
		  }

		  if (item['type'] == 'file') {
			  html += '    <div class="form-group" style="display: none;">';
			  html += '      <label class="col-sm-2 control-label" for="input-value' + option_row + '">{{ entry_option_value|e('js') }}</label>';
			  html += '      <div class="col-sm-10"><input type="text" name="product_option[' + option_row + '][value]" value="" placeholder="{{ entry_option_value|e('js') }}" id="input-value' + option_row + '" class="form-control" /></div>';
			  html += '    </div>';
		  }

		  if (item['type'] == 'date') {
			  html += '    <div class="form-group">';
			  html += '      <label class="col-sm-2 control-label" for="input-value' + option_row + '">{{ entry_option_value|e('js') }}</label>';
			  html += '      <div class="col-sm-3"><div class="input-group date"><input type="text" name="product_option[' + option_row + '][value]" value="" placeholder="{{ entry_option_value|e('js') }}" data-date-format="YYYY-MM-DD" id="input-value' + option_row + '" class="form-control" /><span class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></span></div></div>';
			  html += '    </div>';
		  }

		  if (item['type'] == 'time') {
			  html += '    <div class="form-group">';
			  html += '      <label class="col-sm-2 control-label" for="input-value' + option_row + '">{{ entry_option_value|e('js') }}</label>';
			  html += '      <div class="col-sm-10"><div class="input-group time"><input type="text" name="product_option[' + option_row + '][value]" value="" placeholder="{{ entry_option_value|e('js') }}" data-date-format="HH:mm" id="input-value' + option_row + '" class="form-control" /><span class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></span></div></div>';
			  html += '    </div>';
		  }

		  if (item['type'] == 'datetime') {
			  html += '    <div class="form-group">';
			  html += '      <label class="col-sm-2 control-label" for="input-value' + option_row + '">{{ entry_option_value|e('js') }}</label>';
			  html += '      <div class="col-sm-10"><div class="input-group datetime"><input type="text" name="product_option[' + option_row + '][value]" value="" placeholder="{{ entry_option_value|e('js') }}" data-date-format="YYYY-MM-DD HH:mm" id="input-value' + option_row + '" class="form-control" /><span class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></span></div></div>';
			  html += '    </div>';
		  }

		  if (item['type'] == 'select' || item['type'] == 'radio' || item['type'] == 'checkbox' || item['type'] == 'image' || item['type'] == 'color') {
			  html += '    <div class="dc-opt-cards" id="option-value' + option_row + '"></div>';
			  html += '    <div class="dc-opt-actions">';
			  html += '      <button type="button" class="btn btn-primary btn-sm" onclick="addOptionValue(\'' + option_row + '\');"><i class="fa fa-plus-circle"></i> {{ button_option_value_add|e('js') }}</button>';
			  html += '      <button type="button" class="btn btn-default btn-sm" onclick="addAllOptionValues(\'' + option_row + '\');"><i class="fa fa-plus-square"></i> {{ button_add_all_values|e('js') }}</button>';
			  html += '    </div>';

			  html += '    <select id="option-values' + option_row + '" style="display: none;">';
			  for (i = 0; i < item['option_value'].length; i++) {
				  html += '    <option value="' + item['option_value'][i]['option_value_id'] + '">' + item['option_value'][i]['name'] + '</option>';
			  }
			  html += '    </select>';
		  }

		  html += '  </div>';
		  html += '</div>';

		  $('#dc-options-container').append(html);

		  $('#option-sidebar-list').append('<li class="dc-opt-sidebar__item" data-target="option-section' + option_row + '"><a href="javascript:void(0)" onclick="dcScrollToOption(\'option-section' + option_row + '\')"><i class="fa fa-circle"></i> ' + item['label'] + ' <span class="dc-opt-sidebar__required">*</span> <small class="text-muted">(' + item['type'] + ')</small></a><button type="button" class="dc-opt-sidebar__remove" onclick="dcRemoveOption(\'' + option_row + '\')" title="{{ button_remove|e('js') }}">&times;</button></li>');

		  $('[data-toggle=\'tooltip\']').tooltip({
			  container: 'body',
			  html: true
		  });

		  $('.date').datetimepicker({
			  language: '{{ datepicker }}',
			  pickTime: false
		  });

		  $('.time').datetimepicker({
			  language: '{{ datepicker }}',
			  pickDate: false
		  });

		  $('.datetime').datetimepicker({
			  language: '{{ datepicker }}',
			  pickDate: true,
			  pickTime: true
		  });

		  $('input[name=\'option\']').val('').blur();

		  option_row++;
	  }
  });

  $(document).on('change', '.dc-option-section__required select', function() {
	  var sectionId = $(this).closest('.dc-option-section').attr('id');
	  var $item = $('#option-sidebar-list li[data-target="' + sectionId + '"]');
	  var $a = $item.find('a');
	  var isRequired = $(this).val() == '1';
	  if (isRequired) {
		  if (!$a.find('.dc-opt-sidebar__required').length) {
			  $a.find('small').before('<span class="dc-opt-sidebar__required">*</span> ');
		  }
	  } else {
		  $a.find('.dc-opt-sidebar__required').remove();
	  }
  });

  //--></script>
  <script type="text/javascript"><!--
  var option_value_row = {{ option_value_row }};

  function dcBuildOptionValueCard(option_row, ovRow, optionValueId, optionValueName, price, price_prefix, points, points_prefix, weight, weight_prefix, isHit) {
	  var html = '';
	  var optionType = $('#option-section' + option_row + ' input[name$="[type]"]').val();
	  html += '<div class="dc-opt-card" id="option-value-row' + ovRow + '">';
	  html += '  <div class="dc-opt-card__header">';
	  html += '    <span class="dc-opt-card__title">' + (optionValueName || '') + '</span>';
	  html += '    <span class="dc-opt-card__badges">';
	  if (isHit) {
		  html += '      <span class="dc-opt-badge dc-opt-badge--hit">{{ entry_hit|e('js') }}</span>';
	  }
	  if (parseFloat(price) != 0) {
		  html += '      <span class="dc-opt-badge dc-opt-badge--price" data-badge="price">' + price_prefix + price + '</span>';
	  } else {
		  html += '      <span class="dc-opt-badge dc-opt-badge--price" data-badge="price" style="display:none"></span>';
	  }
	  html += '    </span>';
	  html += '    <button type="button" class="btn btn-danger btn-xs dc-opt-card__remove" onclick="$(this).closest(\'.dc-opt-card\').remove();" data-toggle="tooltip" title="{{ button_remove|e('js') }}"><i class="fa fa-minus-circle"></i></button>';
	  html += '  </div>';
	  html += '  <div class="dc-opt-card__body">';
	  html += '    <input type="hidden" name="product_option[' + option_row + '][product_option_value][' + ovRow + '][product_option_value_id]" value="" />';
	  html += '    <input type="hidden" name="product_option[' + option_row + '][product_option_value][' + ovRow + '][is_hit]" value="0" />';
	  html += '    <div class="dc-opt-card__grid">';
	  html += '      <div class="dc-opt-card__field">';
	  html += '        <label>{{ entry_option_value|e('js') }}</label>';
	  html += '        <select name="product_option[' + option_row + '][product_option_value][' + ovRow + '][option_value_id]" class="form-control" onchange="dcUpdateCardTitle(this)">';
	  var optsHtml = $('#option-values' + option_row).html();
	  if (optionValueId) {
		  optsHtml = optsHtml.replace(/value="([^"]*)"/g, function(match, val) {
			  return val == optionValueId ? 'value="' + val + '" selected="selected"' : match;
		  });
	  }
	  html += optsHtml;
	  html += '        </select>';
	  html += '      </div>';
	  html += '      <div class="dc-opt-card__field">';
	  html += '        <label>{{ entry_price|e('js') }}</label>';
	  html += '        <div class="option-value-prefix-group">';
	  html += '          <select name="product_option[' + option_row + '][product_option_value][' + ovRow + '][price_prefix]" class="form-control option-value-prefix-select">';
	  html += '            <option value="+"' + (price_prefix == '+' ? ' selected="selected"' : '') + '>+</option>';
	  html += '            <option value="-"' + (price_prefix == '-' ? ' selected="selected"' : '') + '>-</option>';
	  html += '          </select>';
	  html += '          <input type="text" name="product_option[' + option_row + '][product_option_value][' + ovRow + '][price]" value="' + price + '" placeholder="{{ entry_price|e('js') }}" class="form-control option-value-prefix-input" oninput="dcUpdateBadges(this)" />';
	  html += '        </div>';
	  html += '      </div>';
	  html += '      <div class="dc-opt-card__field">';
	  html += '        <label>{{ entry_option_points|e('js') }}</label>';
	  html += '        <div class="option-value-prefix-group">';
	  html += '          <select name="product_option[' + option_row + '][product_option_value][' + ovRow + '][points_prefix]" class="form-control option-value-prefix-select">';
	  html += '            <option value="+"' + (points_prefix == '+' ? ' selected="selected"' : '') + '>+</option>';
	  html += '            <option value="-"' + (points_prefix == '-' ? ' selected="selected"' : '') + '>-</option>';
	  html += '          </select>';
	  html += '          <input type="text" name="product_option[' + option_row + '][product_option_value][' + ovRow + '][points]" value="' + points + '" placeholder="{{ entry_points|e('js') }}" class="form-control option-value-prefix-input" />';
	  html += '        </div>';
	  html += '      </div>';
	  html += '      <div class="dc-opt-card__field">';
	  html += '        <label>{{ entry_weight|e('js') }}</label>';
	  html += '        <div class="option-value-prefix-group">';
	  html += '          <select name="product_option[' + option_row + '][product_option_value][' + ovRow + '][weight_prefix]" class="form-control option-value-prefix-select">';
	  html += '            <option value="+"' + (weight_prefix == '+' ? ' selected="selected"' : '') + '>+</option>';
	  html += '            <option value="-"' + (weight_prefix == '-' ? ' selected="selected"' : '') + '>-</option>';
	  html += '          </select>';
	  html += '          <input type="text" name="product_option[' + option_row + '][product_option_value][' + ovRow + '][weight]" value="' + weight + '" placeholder="{{ entry_weight|e('js') }}" class="form-control option-value-prefix-input" />';
	  html += '        </div>';
	  html += '      </div>';
	  html += '    </div>';
	  if (optionType === 'color') {
		  html += '    <div class="dc-opt-card__hit">';
		  html += '      <label class="dc-opt-card__hit-label">';
		  html += '        <input type="checkbox" name="product_option[' + option_row + '][product_option_value][' + ovRow + '][is_hit]" value="1" onchange="$(this).closest(\'.dc-opt-card\').find(\'input[name$=\\\'[is_hit\\\']\').val(this.checked ? 1 : 0);dcUpdateHitBadge(this)" />';
		  html += '        <i class="fa fa-star"></i> {{ entry_hit|e('js') }}';
		  html += '      </label>';
		  html += '    </div>';
		  html += '    <div class="dc-opt-card__color-images">';
		  html += '      <label class="dc-opt-card__color-images-label"><i class="fa fa-image"></i> {{ entry_color_images|e('js') }}</label>';
		  html += '      <div class="dc-color-img-picker" data-opt-row="' + option_row + '" data-ov-row="' + ovRow + '" data-selected="[]"></div>';
		  html += '    </div>';
	  }
	  html += '    <div class="dc-opt-card__cg">';
	  html += '      <button type="button" class="btn btn-default btn-xs dc-opt-card__cg-toggle" onclick="event.stopPropagation();$(this).closest(\'.dc-opt-card__cg\').find(\'.dc-opt-card__cg-body\').slideToggle(150);">';
	  html += '        <i class="fa fa-users"></i> {{ entry_option_value_cg_price|e('js') }}';
	  html += '      </button>';
