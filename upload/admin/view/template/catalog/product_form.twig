  function updateImageSortOrders() {
    $('.product-images').each(function() {
      $(this).find('.dc-img-card').each(function(i) {
        $(this).find('.dc-img-sort-order').val(i);
      });
    });
  }

  if (typeof Sortable !== 'undefined') {
    $('.product-images').each(function() {
      Sortable.create(this, {
        animation: 150,
        filter: '.dc-img-remove, input',
        ghostClass: 'dc-img-ghost',
        chosenClass: 'dc-img-chosen',
        onEnd: function() {
          updateImageSortOrders();
        }
      });
    });
  }

  function clearProductVideo() {
    $('#input-video-youtube').val('');
    $('#video-youtube-preview').hide();
    var $card = $('#video-mp4-block').find('.dc-video-card');
    $card.find('.dc-video-card__img').attr('src', $card.find('.dc-video-card__img').attr('data-placeholder'));
    $card.find('.dc-video-card__overlay').hide();
    $('#input-product-video').val('');
    $('#video-mp4-block').hide();
  }

  function clearModel3d() {
    var $card = $('#thumb-model-3d').closest('.dc-video-card');
    $card.find('.dc-video-card__img').attr('src', $card.find('.dc-video-card__img').attr('data-placeholder'));
    $card.find('.dc-video-card__overlay').hide();
    $('#input-model-3d').val('');
  }

  function openVideoFileManager() {
    $('#modal-image').remove();
    $.ajax({
      url: 'index.php?route=common/filemanager&user_token=' + getURLVar('user_token')
           + '&target=input-product-video&thumb=thumb-product-video&type=video',
      dataType: 'html',
      beforeSend: function() {
        $('#button-browse-mp4').prop('disabled', true);
      },
      complete: function() {
        $('#button-browse-mp4').prop('disabled', false);
      },
      success: function(html) {
        $('body').append('<div id="modal-image" class="modal">' + html + '</div>');
        $('#modal-image').modal('show');
      }
    });
  }

  $(document).on('input', '#input-video-youtube', function() {
    var val = $(this).val().trim();
    if (val) {
      $('#video-mp4-block').hide();
      $('#input-product-video').val('');
      $('#video-mp4-block').find('.dc-video-card__img').attr('src', $('#video-mp4-block').find('.dc-video-card__img').attr('data-placeholder'));
      $('#video-mp4-block').find('.dc-video-card__overlay').hide();
      $('#video-youtube-preview').show();
      $('#video-youtube-thumb-img').attr('src', 'https://img.youtube.com/vi/' + encodeURIComponent(val) + '/hqdefault.jpg');
    } else {
      $('#video-youtube-preview').hide();
    }
  });

  $(document).on('hidden.bs.modal', '#modal-image', function() {
    var mp4Val = $('#input-product-video').val();
    if (mp4Val) {
      $('#video-youtube-preview').hide();
      $('#input-video-youtube').val('');
      $('#video-mp4-block').show();
      $('#video-mp4-block').find('.dc-video-card__overlay').show();
      $('#video-mp4-block').find('.dc-video-card__name').text(mp4Val);
    }
    var modelVal = $('#input-model-3d').val();
    if (modelVal) {
      $('#thumb-model-3d').closest('.dc-video-card').find('.dc-video-card__overlay').show();
      $('#thumb-model-3d').closest('.dc-video-card').find('.dc-video-card__name').text(modelVal);
    }
  });

