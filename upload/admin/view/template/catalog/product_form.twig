                                          <option value="-"{% if product_option_value.points_prefix == '-' %} selected="selected"{% endif %}>-</option>
                                        </select>
                                        <input type="text" name="product_option[{{ option_row }}][product_option_value][{{ option_value_row }}][points]" value="{{ product_option_value.points }}" placeholder="{{ entry_points }}" class="form-control option-value-prefix-input" />
                                      </div>
                                    </div>
