      : $('#product-images-' + language_id);
    var html = '<div class="dc-img-card" data-row="' + image_row + '" title="{{ text_drag_to_reorder }}">';
    html += '<input type="hidden" name="product_image[' + image_row + '][image]" value="" id="input-image' + image_row + '"/>';
    html += '<input type="hidden" name="product_image[' + image_row + '][sort_order]" value="0" class="dc-img-sort-order"/>';
    html += '<input type="hidden" name="product_image[' + image_row + '][language_id]" value="' + language_id + '"/>';
    html += '<a href="" id="thumb-image' + image_row + '" data-toggle="image" class="dc-img-link"><img src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" draggable="false"/></a>';
    html += '<button type="button" onclick="removeImage(' + image_row + ');" class="dc-img-remove"><i class="fa fa-times"></i></button>';
    html += '</div>';
    $container.append(html);
    dcRefreshColorImagePickers();
