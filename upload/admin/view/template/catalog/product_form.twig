                                    {% else %}
                                      <span class="dc-opt-badge dc-opt-badge--price" data-badge="price" style="display:none"></span>
                                    {% endif %}
                                  </span>
                                  <button type="button" class="btn btn-danger btn-xs dc-opt-card__remove" onclick="$(this).closest('.dc-opt-card').remove();" data-toggle="tooltip" title="{{ button_remove }}"><i class="fa fa-minus-circle"></i></button>
                                </div>
                                <div class="dc-opt-card__body">
                                  <input type="hidden" name="product_option[{{ option_row }}][product_option_value][{{ option_value_row }}][product_option_value_id]" value="{{ product_option_value.product_option_value_id }}"/>
                                  <input type="hidden" name="product_option[{{ option_row }}][product_option_value][{{ option_value_row }}][is_hit]" value="0"/>
<div class="dc-opt-card__grid">
