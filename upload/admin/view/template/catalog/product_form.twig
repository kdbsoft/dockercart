                                        <input type="text" name="product_option[{{ option_row }}][product_option_value][{{ option_value_row }}][price]" value="{{ product_option_value.price }}" placeholder="{{ entry_price }}" class="form-control option-value-prefix-input" oninput="dcUpdateBadges(this)" />
                                      </div>
                                    </div>
                                    <div class="dc-opt-card__field">
                                      <label>{{ entry_option_points }}</label>
                                      <div class="option-value-prefix-group">
