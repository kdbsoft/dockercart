                        <div class="dc-video-card">
                          <a href="" id="thumb-product-video" data-toggle="image" data-type="video" class="dc-video-card__link">
                            <img src="{{ video_thumb }}" data-placeholder="{{ video_placeholder }}" class="dc-video-card__img" />
                            <div class="dc-video-card__overlay"{% if not (video_type == 'mp4' and video) %} style="display:none;"{% endif %}>
                              <i data-lucide="film" class="dc-video-card__icon"></i>
                              <span class="dc-video-card__name">{{ video }}</span>
                            </div>
                          </a>
