  <script type="text/javascript"><!--
  // Manufacturer
  $('input[name=\'manufacturer\']').autocomplete({
	  'source': function(request, response) {
		  $.ajax({
			  url: 'index.php?route=catalog/manufacturer/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
			  dataType: 'json',
			  success: function(json) {
				  json.unshift({
					  manufacturer_id: 0,
					  name: '{{ text_none }}'
				  });

				  response($.map(json, function(item) {
					  return {
						  label: item['name'],
						  value: item['manufacturer_id']
					  }
				  }));
			  }
		  });
	  },
	  'select': function(item) {
		  $('input[name=\'manufacturer\']').val(item['label']);
		  $('input[name=\'manufacturer_id\']').val(item['value']);
	  }
  });

  // Category Tree Modal
  var selectedCategories = [];
  var categoryTreeLoaded = false;

  function syncSelectedCategoriesFromWell() {
    selectedCategories = [];
    $('#product-category > div').each(function() {
      var $div = $(this);
      var id = $div.find('input[name="product_category[]"]').val();
      var name = $div.clone().children().remove().end().text().trim();
      if (id) {
        selectedCategories.push({category_id: id, name: name});
      }
    });
  }

  syncSelectedCategoriesFromWell();

  $(document).on('click', '#category-tree-btn', function() {
    syncSelectedCategoriesFromWell();
    if (!categoryTreeLoaded) {
      loadCategoryTree();
    }
    $('#category-tree-modal').modal('show');
  });

  function loadCategoryTree() {
    $.ajax({
      url: 'index.php?route=catalog/category/tree&user_token={{ user_token }}',
      dataType: 'json',
      success: function(data) {
        renderCategoryTree(data);
      },
      error: function() {
        $('#category-tree-container').html('<div class="text-center text-danger">{{ text_no_results }}</div>');
      }
    });
  }

  function renderCategoryTree(data) {
    var $container = $('#category-tree-container');
    var $ul = $('<ul class="category-tree list-unstyled" style="margin:0"></ul>');

    if (!data.length) {
      $container.html('<div class="text-center text-muted">{{ text_no_results }}</div>');
      return;
    }

    data.forEach(function(cat) {
      if (cat.level === 0) {
        $ul.append(createCategoryNode(cat, data));
      }
    });

    $container.html($ul);
    categoryTreeLoaded = true;

    selectedCategories.forEach(function(sel) {
      var $cb = $container.find('.category-check[value="' + sel.category_id + '"]');
      if ($cb.length) {
        $cb.prop('checked', true);
        $cb.parents('ul.category-children').show().prev('.category-node').find('.category-toggle i.fa')
          .removeClass('fa-plus-square-o').addClass('fa-minus-square-o');
      }
    });
  }

  function createCategoryNode(cat, allData) {
    var $li = $('<li></li>');
    var $div = $('<div class="category-node" style="white-space:nowrap;padding:2px 0"></div>');
    var indent = cat.level * 20;
    $div.css('padding-left', indent + 'px');

    if (cat.has_children) {
      var $toggle = $('<span class="category-toggle" style="cursor:pointer;display:inline-block;width:16px;text-align:center"><i class="fa fa-plus-square-o"></i></span>');
      $toggle.data('id', cat.category_id);
      $div.append($toggle);
    } else {
      $div.append($('<span style="display:inline-block;width:16px"></span>'));
    }

    var escName = $('<span>').text(cat.name).html();
    var escPath = $('<span>').text(cat.path || cat.name).html();

    var $label = $('<label style="font-weight:normal;margin:0 0 0 4px;cursor:pointer"></label>');
    var $checkbox = $('<input type="checkbox" class="category-check" value="' + cat.category_id + '" data-name="' + escName + '" data-path="' + escPath + '">');
    $label.append($checkbox).append(' ' + cat.name);
    $div.append($label);
    $li.append($div);

    if (cat.has_children) {
      var $children = $('<ul class="category-children list-unstyled" style="display:none;margin:0"></ul>');
      allData.forEach(function(child) {
        if (child.parent_id === cat.category_id) {
          $children.append(createCategoryNode(child, allData));
        }
      });
      $li.append($children);
    }

    return $li;
  }

  $(document).on('click', '.category-toggle', function(e) {
    e.stopPropagation();
    var $children = $(this).closest('li').find('> ul.category-children');
    var $icon = $(this).find('i.fa');
    if ($children.is(':visible')) {
      $children.slideUp(150);
      $icon.removeClass('fa-minus-square-o').addClass('fa-plus-square-o');
    } else {
      $children.slideDown(150);
      $icon.removeClass('fa-plus-square-o').addClass('fa-minus-square-o');
    }
  });

  // Checkbox cascade
  $(document).on('change', '.category-check', function() {
    var $cb = $(this);
    var $li = $cb.closest('li');

    if ($cb.is(':checked')) {
      $li.parents('li').find('> .category-node > label > .category-check').prop('checked', true);
    } else {
      $li.find('.category-check').prop('checked', false);
    }
  });

  $('#category-tree-search').on('input', function() {
    var query = $(this).val().toLowerCase().trim();
    var $container = $('#category-tree-container');

    if (!query) {
      $container.find('li').show();
      $container.find('ul.category-children').hide();
      $container.find('.category-toggle i.fa')
        .removeClass('fa-minus-square-o').addClass('fa-plus-square-o');
      return;
    }

    $container.find('li').each(function() {
      var name = $(this).find('.category-node label').text().toLowerCase();
      if (name.indexOf(query) !== -1) {
        $(this).show();
        $(this).parents('ul.category-children').show();
        $(this).parents('li').find('> .category-node > .category-toggle i.fa')
          .removeClass('fa-plus-square-o').addClass('fa-minus-square-o');
      } else {
        $(this).hide();
      }
    });
  });

  $(document).on('click', '#category-tree-confirm', function() {
