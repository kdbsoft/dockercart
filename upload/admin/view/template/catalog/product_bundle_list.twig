{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus"></i></a>
        <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-bundle').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-bundle">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                  <td class="text-left">{% if sort == 'b.name' %}<a href="{{ sort_name }}" class="{{ order|lower }}">{{ column_name }}</a>{% else %}<a href="{{ sort_name }}">{{ column_name }}</a>{% endif %}</td>
                  <td class="text-center">{% if sort == 'product_count' %}<a href="{{ sort_product_count }}" class="{{ order|lower }}">{{ column_products }}</a>{% else %}<a href="{{ sort_product_count }}">{{ column_products }}</a>{% endif %}</td>
                  <td class="text-center">{% if sort == 'b.discount_value' %}<a href="{{ sort_discount }}" class="{{ order|lower }}">{{ column_discount }}</a>{% else %}<a href="{{ sort_discount }}">{{ column_discount }}</a>{% endif %}</td>
                  <td class="text-center">{% if sort == 'b.status' %}<a href="{{ sort_status }}" class="{{ order|lower }}">{{ column_status }}</a>{% else %}<a href="{{ sort_status }}">{{ column_status }}</a>{% endif %}</td>
                  <td class="text-center">{% if sort == 'b.date_start' %}<a href="{{ sort_date_start }}" class="{{ order|lower }}">{{ column_date_start }}</a>{% else %}<a href="{{ sort_date_start }}">{{ column_date_start }}</a>{% endif %}</td>
                  <td class="text-center">{% if sort == 'b.date_end' %}<a href="{{ sort_date_end }}" class="{{ order|lower }}">{{ column_date_end }}</a>{% else %}<a href="{{ sort_date_end }}">{{ column_date_end }}</a>{% endif %}</td>
                  <td class="text-center">{% if sort == 'b.sort_order' %}<a href="{{ sort_sort_order }}" class="{{ order|lower }}">{{ column_sort_order }}</a>{% else %}<a href="{{ sort_sort_order }}">{{ column_sort_order }}</a>{% endif %}</td>
                  <td class="text-right">{{ column_action }}</td>
                </tr>
              </thead>
              <tbody>
                {% if bundles %}
                {% for bundle in bundles %}
                <tr>
                  <td class="text-center"><input type="checkbox" name="selected[]" value="{{ bundle.bundle_id }}" {% if bundle.bundle_id in selected %}checked{% endif %} /></td>
                  <td class="text-left">
                    <span class="inline-edit" data-bundle-id="{{ bundle.bundle_id }}" data-field="name" data-value="{{ bundle.name_raw }}">{{ bundle.name }}<i class="fa fa-pencil-square-o inline-edit-icon"></i></span>
                  </td>
                  <td class="text-center">{{ bundle.product_count }}</td>
                  <td class="text-center">
                    <span class="inline-edit discount" data-bundle-id="{{ bundle.bundle_id }}" data-field="discount" data-value="{{ bundle.discount_raw }}" data-discount-type="{{ bundle.discount_type_raw }}">{{ bundle.discount }}<i class="fa fa-pencil-square-o inline-edit-icon"></i></span>
                  </td>
                  <td class="text-center">
                    <span class="inline-edit" data-bundle-id="{{ bundle.bundle_id }}" data-field="status" data-value="{{ bundle.status_raw }}">{{ bundle.status }}<i class="fa fa-pencil-square-o inline-edit-icon"></i></span>
                  </td>
                  <td class="text-center">
                    {% if bundle.date_start_raw != '0000-00-00' %}
                    <span class="inline-edit" data-bundle-id="{{ bundle.bundle_id }}" data-field="date_start" data-value="{{ bundle.date_start_raw }}">{{ bundle.date_start }}<i class="fa fa-pencil-square-o inline-edit-icon"></i></span>
                    {% endif %}
                  </td>
                  <td class="text-center">
                    {% if bundle.date_end_raw != '0000-00-00' %}
                    <span class="inline-edit" data-bundle-id="{{ bundle.bundle_id }}" data-field="date_end" data-value="{{ bundle.date_end_raw }}">{{ bundle.date_end }}<i class="fa fa-pencil-square-o inline-edit-icon"></i></span>
                    {% endif %}
                  </td>
                  <td class="text-center">
                    <span class="inline-edit" data-bundle-id="{{ bundle.bundle_id }}" data-field="sort_order" data-value="{{ bundle.sort_order_raw }}">{{ bundle.sort_order }}<i class="fa fa-pencil-square-o inline-edit-icon"></i></span>
                  </td>
                  <td class="text-right"><a href="{{ bundle.edit }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a></td>
                </tr>
                {% endfor %}
                {% else %}
                <tr>
                  <td class="text-center" colspan="9">{{ text_no_results }}</td>
                </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
        <div class="row">
          <div class="col-sm-6 text-left">{{ pagination }}</div>
          <div class="col-sm-6 text-right">{{ results }}</div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
.inline-edit { cursor: default; }
.inline-edit .inline-edit-icon { margin-left: 4px; font-size: 13px; opacity: 0.3; cursor: pointer; }
.inline-edit:hover .inline-edit-icon { opacity: 0.8; }
.inline-edit-input { width: 80px; text-align: right; display: inline-block !important; height: 28px; padding: 3px 8px; }
.inline-edit-input-left { width: 200px; text-align: left; display: inline-block !important; height: 28px; padding: 3px 8px; }
.inline-edit-name-input { width: 200px; display: inline-block !important; height: 28px; padding: 3px 8px; }
.inline-edit-error { margin-left: 4px; font-size: 11px; white-space: nowrap; }
</style>
<script type="text/javascript"><!--
$(document).on('click', '.inline-edit-icon', function(e) {
	e.stopPropagation();

	var $span = $(this).closest('.inline-edit');
	if ($span.find('input, select').length) return;

	var field = $span.data('field');
	var rawValue = $span.data('value');
	var bundleId = $span.data('bundle-id');

	$span.data('display', $span.html());

	if (field === 'status') {
		var $select = $('<select class="form-control input-sm" style="width:auto;display:inline-block;">');
		$select.append('<option value="1"' + (rawValue == 1 ? ' selected' : '') + '>{{ text_enabled }}</option>');
		$select.append('<option value="0"' + (rawValue == 0 ? ' selected' : '') + '>{{ text_disabled }}</option>');
		$span.html($select);
		$select.focus();

		var saved = false;

		$select.on('change', function() {
			saved = true;
			var newValue = $(this).val();

			$.ajax({
				url: 'index.php?route=catalog/product_bundle/updateField&user_token={{ user_token }}',
				type: 'post',
				dataType: 'json',
				data: { bundle_id: bundleId, field: 'status', value: newValue },
				success: function(json) {
					if (json['error']) {
						$span.html($span.data('display') + ' <span class="text-danger inline-edit-error">' + json['error'] + '</span>');
						setTimeout(function() { $span.html($span.data('display')); }, 3000);
					} else {
						$span.data('value', newValue);
						$span.html(json['value_html'] + '<i class="fa fa-pencil-square-o inline-edit-icon"></i>');
					}
				},
				error: function() {
					$span.html($span.data('display'));
				}
			});
		});

		$select.on('blur', function() {
			if (!saved) {
				$span.html($span.data('display'));
			}
		});
	} else if (field === 'discount') {
		var discountType = $span.data('discount-type');

		var html = '<input type="text" class="form-control input-sm inline-edit-input" value="' + rawValue + '" style="width:70px;">';
		html += '<select class="form-control input-sm" style="width:auto;display:inline-block;margin-left:4px;">';
		html += '<option value="percentage"' + (discountType == 'percentage' ? ' selected' : '') + '>%</option>';
		html += '<option value="fixed"' + (discountType == 'fixed' ? ' selected' : '') + '>{{ text_fixed }}</option>';
		html += '</select>';
		html += ' <button type="button" class="btn btn-primary btn-xs inline-edit-discount-save">{{ button_save }}</button>';
		$span.html(html);
		$span.find('input').focus().select();

		var reverted = false;

		$span.find('.inline-edit-discount-save').on('click', function() {
			var newValue = $span.find('input').val();
			var newType = $span.find('select').val();

			$.ajax({
				url: 'index.php?route=catalog/product_bundle/updateDiscount&user_token={{ user_token }}',
				type: 'post',
				dataType: 'json',
				data: { bundle_id: bundleId, value: newValue, type: newType },
				success: function(json) {
					if (json['error']) {
						$span.append(' <span class="text-danger inline-edit-error">' + json['error'] + '</span>');
						setTimeout(function() { $span.find('.inline-edit-error').remove(); }, 3000);
					} else {
						reverted = true;
						$span.data('value', newValue);
						$span.data('discount-type', newType);
						$span.html(json['value_html'] + '<i class="fa fa-pencil-square-o inline-edit-icon"></i>');
					}
				},
				error: function() {
					$span.html($span.data('display'));
				}
			});
		});

		$span.find('input').on('keydown', function(e) {
			if (e.which === 27) {
				reverted = true;
				$span.html($span.data('display'));
			}
		});

		$span.find('select').on('blur', function() {
			setTimeout(function() {
				if (!$span.find('select').is(':focus') && !$span.find('input').is(':focus') && !$span.find('.inline-edit-discount-save').is(':focus') && !reverted) {
					$span.html($span.data('display'));
				}
			}, 200);
		});
	} else {
		var $input;

		if (field === 'name') {
			$span.html('<input type="text" class="form-control input-sm inline-edit-input-left" value="' + ('' + rawValue).replace(/"/g, '&quot;') + '">');
			$input = $span.find('input');
		} else if (field === 'date_start' || field === 'date_end') {
			$span.html('<input type="date" class="form-control input-sm" value="' + rawValue + '" style="width:auto;display:inline-block;">');
			$input = $span.find('input');
		} else {
			$span.html('<input type="text" class="form-control input-sm inline-edit-input" value="' + rawValue + '">');
			$input = $span.find('input');
		}
		$input.focus().select();

		function revert() {
			$span.html($span.data('display'));
		}

		function save() {
			var newValue = $input.val();

			$.ajax({
				url: 'index.php?route=catalog/product_bundle/updateField&user_token={{ user_token }}',
				type: 'post',
				dataType: 'json',
				data: { bundle_id: bundleId, field: field, value: newValue },
				success: function(json) {
					if (json['error']) {
						$span.html($span.data('display') + ' <span class="text-danger inline-edit-error">' + json['error'] + '</span>');
						setTimeout(function() { $span.html($span.data('display')); }, 3000);
					} else {
						$span.data('value', newValue);
						$span.html(json['value_html'] + '<i class="fa fa-pencil-square-o inline-edit-icon"></i>');
					}
				},
				error: function() {
					revert();
				}
			});
		}

		$input.on('blur', save);
		$input.on('keydown', function(e) {
			if (e.which === 13) { e.preventDefault(); $input.trigger('blur'); }
			if (e.which === 27) { revert(); }
		});
	}
});
//--></script>
{{ footer }}
