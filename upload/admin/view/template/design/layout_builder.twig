<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ heading_title_builder }} — {% set first_desc = layout_descriptions|first %}{{ first_desc.name ?? '' }}</title>
<script src="view/javascript/tailwind-cdn.min.js"></script>
<script src="view/javascript/lucide.min.js"></script>
<script src="view/javascript/sortablejs/Sortable.min.js"></script>
<style>
	.zone-drop-area { min-height: 60px; transition: background-color 0.2s; }
	.zone-drop-area.sortable-ghost { opacity: 0.4; background-color: #e2e8f0; }
	.zone-drop-area .sortable-ghost { opacity: 0.3; }
	.module-card { cursor: grab; transition: box-shadow 0.15s, transform 0.15s; }
	.module-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
	.module-card.sortable-chosen { box-shadow: 0 4px 16px rgba(59,130,246,0.3); transform: scale(1.02); z-index: 10; }
	.module-card.sortable-drag { opacity: 0.7; }
	.palette-item { cursor: grab; transition: background-color 0.15s; }
	.palette-item:hover { background-color: #f1f5f9; }
	.palette-item.sortable-chosen { background-color: #dbeafe; }
	.module-card.selected { ring: 2px solid #3b82f6; box-shadow: 0 0 0 2px #3b82f6; }
	#page-canvas { max-width: 100%; }
	#canvas-container.viewport-tablet #page-canvas { max-width: 768px; }
	#canvas-container.viewport-mobile #page-canvas { max-width: 375px; }
	#canvas-container.viewport-tablet .responsive-lg-only,
	#canvas-container.viewport-mobile .responsive-lg-only { opacity: 0.35; }
	#canvas-container.viewport-tablet .responsive-lg-only .zone-hidden-badge,
	#canvas-container.viewport-mobile .responsive-lg-only .zone-hidden-badge { display: inline !important; }
	.toast { animation: toastIn 0.3s ease-out; }
	@keyframes toastIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
	.lang-tab { transition: all 0.15s; }
	.lang-tab.active { background-color: #3b82f6; color: white; border-radius: 4px; }
</style>
</head>
<body class="h-screen flex flex-col bg-gray-100 font-sans text-sm text-gray-800">

{# ==================== TOP BAR ==================== #}
<header class="bg-white border-b border-gray-200 px-4 py-2 flex items-center gap-3 shrink-0 z-10" style="min-height:48px">
	<a href="{{ back }}" class="flex items-center gap-1 text-gray-500 hover:text-gray-700 shrink-0" title="{{ text_back_to_layouts }}">
		<i data-lucide="arrow-left" class="w-4 h-4"></i>
	</a>

	{% set first_lang_id = languages|first.language_id %}
	<div class="flex items-center gap-1 shrink-0">
		<input type="text" id="layout-name-input"
			value="{{ attribute(layout_descriptions, first_lang_id).name ?? '' }}"
			placeholder="{{ entry_name }}"
			class="border border-gray-300 rounded px-2 py-1 text-sm w-48 focus:outline-none focus:border-blue-400"
			data-language-id="{{ first_lang_id }}">
	</div>

	{% if languages|length > 1 %}
	<div class="flex items-center gap-0.5 shrink-0" id="lang-tabs">
		{% for language in languages %}
		<button type="button" class="lang-tab px-1.5 py-0.5 text-xs text-gray-500 hover:text-gray-700 {% if loop.first %}active{% endif %}"
			data-lang-id="{{ language.language_id }}"
			data-lang-name="{{ attribute(layout_descriptions, language.language_id).name ?? '' }}">
			{{ language.code|split('-')|first|upper }}
		</button>
		{% endfor %}
	</div>
	{% endif %}

	<div class="flex-1"></div>

	<div class="flex items-center gap-1 bg-gray-100 rounded-lg p-0.5 shrink-0" id="viewport-switcher">
		<button type="button" data-viewport="desktop" class="px-2 py-1 rounded-md text-xs font-medium bg-white shadow-sm text-gray-700" title="Desktop">
			<i data-lucide="monitor" class="w-3.5 h-3.5"></i>
		</button>
		<button type="button" data-viewport="tablet" class="px-2 py-1 rounded-md text-xs font-medium text-gray-500 hover:text-gray-700" title="Tablet">
			<i data-lucide="tablet" class="w-3.5 h-3.5"></i>
		</button>
		<button type="button" data-viewport="mobile" class="px-2 py-1 rounded-md text-xs font-medium text-gray-500 hover:text-gray-700" title="Mobile">
			<i data-lucide="smartphone" class="w-3.5 h-3.5"></i>
		</button>
	</div>

	<a href="{{ preview_url }}" target="_blank" class="flex items-center gap-1 px-2 py-1 text-xs text-gray-600 hover:text-gray-800 border border-gray-200 rounded shrink-0" title="{{ text_preview_page }}">
		<i data-lucide="external-link" class="w-3.5 h-3.5"></i>
		<span class="hidden sm:inline">{{ text_preview_page }}</span>
	</a>

	<a href="{{ classic_url }}" class="flex items-center gap-1 px-2 py-1 text-xs text-gray-600 hover:text-gray-800 border border-gray-200 rounded shrink-0" title="{{ text_back_to_classic }}">
		<i data-lucide="file-text" class="w-3.5 h-3.5"></i>
		<span class="hidden sm:inline">{{ text_switch_to_classic }}</span>
	</a>

	<button type="button" id="btn-save" class="flex items-center gap-1 px-3 py-1 text-xs font-medium text-white bg-blue-600 hover:bg-blue-700 rounded shrink-0 disabled:opacity-50">
		<i data-lucide="save" class="w-3.5 h-3.5"></i>
		<span class="hidden sm:inline">{{ button_builder_save }}</span>
	</button>
</header>

{# ==================== MAIN AREA ==================== #}
<div class="flex flex-1 overflow-hidden">

{# --- LEFT PANEL: Module Palette --- #}
<aside class="w-56 lg:w-64 bg-white border-r border-gray-200 flex flex-col shrink-0">
	<div class="px-3 py-2.5 border-b border-gray-100 font-semibold text-xs text-gray-500 uppercase tracking-wider flex items-center gap-2">
		<i data-lucide="box" class="w-3.5 h-3.5"></i>
		{{ text_modules_palette }}
	</div>

	<div class="px-2 py-1.5 border-b border-gray-100">
		<input type="text" id="module-search" placeholder="Search modules..."
			class="w-full border border-gray-200 rounded px-2 py-1 text-xs focus:outline-none focus:border-blue-400">
	</div>

	<div class="flex-1 overflow-y-auto p-1.5" id="module-palette">
		{% for extension in extensions %}
		<div class="palette-group-header text-xs font-semibold text-gray-400 uppercase px-2 py-1.5 tracking-wide" data-group-name="{{ extension.name|lower }}">{{ extension.name }}</div>
		{% if extension.module %}
			{% for module in extension.module %}
			{% set display_name = extension.name ~ ' → ' ~ module.name %}
			<div class="palette-item flex items-center gap-2 px-2 py-1.5 rounded text-gray-700 text-xs cursor-grab"
				data-palette-code="{{ module.code }}"
				data-palette-name="{{ module.name }}"
				data-palette-display="{{ display_name }}">
				<i data-lucide="grip-vertical" class="w-3 h-3 text-gray-300 shrink-0"></i>
				<span class="truncate">{{ display_name }}</span>
			</div>
			{% endfor %}
		{% else %}
		<div class="palette-item flex items-center gap-2 px-2 py-1.5 rounded text-gray-700 text-xs cursor-grab"
			data-palette-code="{{ extension.code }}"
			data-palette-name="{{ extension.name }}">
			<i data-lucide="grip-vertical" class="w-3 h-3 text-gray-300 shrink-0"></i>
			<span class="truncate">{{ extension.name }}</span>
		</div>
		{% endif %}
		{% endfor %}
	</div>
</aside>

{# --- CENTER: Page Canvas --- #}
<main class="flex-1 overflow-auto flex justify-center p-4 lg:p-6 bg-gray-100" id="canvas-container">
	<div class="w-full transition-all duration-200" id="page-canvas">

		{% macro renderZone(zone_id, zone_title, modules, text_drop_zone, text_add_module, responsive, hiddenMobileText) %}
		<div class="mb-4{% if responsive == 'lg_only' %} responsive-lg-only{% endif %}">
			<div class="flex items-center justify-between mb-1.5">
				<div class="flex items-center gap-2">
					<span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ zone_title }}</span>
					{% if responsive == 'lg_only' %}
					<span class="zone-hidden-badge text-[10px] text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded-full" style="display:none">{{ hiddenMobileText }}</span>
					{% endif %}
				</div>
				<button type="button" class="zone-add-btn text-xs text-blue-600 hover:text-blue-800 flex items-center gap-1"
					data-zone="{{ zone_id }}">
					<i data-lucide="plus" class="w-3 h-3"></i> {{ text_add_module }}
				</button>
			</div>
			<div class="zone-drop-area bg-white border-2 border-dashed border-gray-200 rounded-lg p-2 min-h-[60px] transition-colors"
				data-zone="{{ zone_id }}"{% if responsive %} data-responsive="{{ responsive }}"{% endif %}>
				{% if modules is empty %}
				<div class="zone-empty flex items-center justify-center h-14 text-xs text-gray-400">
					{{ text_drop_zone }}
				</div>
				{% endif %}
				{% for module in modules %}
				<div class="module-card flex items-center gap-2 bg-white border border-gray-200 rounded px-2 py-1.5 mb-1"
					data-module-idx="{{ module.idx }}"
					data-module-code="{{ module.code }}"
					data-module-name="{{ module.name }}"
					data-module-edit="{{ module.edit }}">
					<i data-lucide="grip-vertical" class="w-3.5 h-3.5 text-gray-300 shrink-0 cursor-grab"></i>
					<span class="flex-1 truncate text-xs font-medium">{{ module.display_name ?? module.name }}</span>
					<button type="button" class="module-edit-btn text-gray-400 hover:text-blue-600 p-0.5" data-module-idx="{{ module.idx }}" title="{{ text_edit_module }}">
						<i data-lucide="settings" class="w-3 h-3"></i>
					</button>
					<button type="button" class="module-remove-btn text-gray-400 hover:text-red-600 p-0.5" data-module-idx="{{ module.idx }}" title="{{ text_remove_module }}">
						<i data-lucide="x" class="w-3 h-3"></i>
					</button>
				</div>
				{% endfor %}
			</div>
		</div>
		{% endmacro %}

		{% import _self as builder %}
		{% set hiddenMobileText = 'Hidden on Mobile & Tablet' %}

		{% if 'content_top' in active_positions %}
		{{ builder.renderZone('content_top', text_content_top, modules_by_position.content_top, text_drop_zone, text_add_module, '', hiddenMobileText) }}
		{% endif %}

		{% set hasLeft = 'column_left' in active_positions %}
		{% set hasRight = 'column_right' in active_positions %}
		{% set leftResp = responsive_map.column_left ?? '' %}
		{% set rightResp = responsive_map.column_right ?? '' %}

		{% if hasLeft or hasRight %}
		<div class="flex gap-4">
			{% if hasLeft %}
			<div class="w-1/3 lg:w-1/4">
				{{ builder.renderZone('column_left', text_column_left, modules_by_position.column_left, text_drop_zone, text_add_module, leftResp, hiddenMobileText) }}
			</div>
			{% endif %}
			<div class="flex-1 bg-white border border-gray-200 rounded-lg flex items-center justify-center" style="min-height:120px">
				<div class="text-center p-4">
					<i data-lucide="layout" class="w-5 h-5 text-gray-300 mx-auto mb-1"></i>
					<span class="text-xs text-gray-400">Main Content Area</span>
				</div>
			</div>
			{% if hasRight %}
			<div class="w-1/3 lg:w-1/4">
				{{ builder.renderZone('column_right', text_column_right, modules_by_position.column_right, text_drop_zone, text_add_module, rightResp, hiddenMobileText) }}
			</div>
			{% endif %}
		</div>
		{% else %}
		<div class="flex-1 bg-white border border-gray-200 rounded-lg flex items-center justify-center" style="min-height:120px">
			<div class="text-center p-4">
				<i data-lucide="layout" class="w-5 h-5 text-gray-300 mx-auto mb-1"></i>
				<span class="text-xs text-gray-400">Main Content Area</span>
			</div>
		</div>
		{% endif %}

		{% if 'content_bottom' in active_positions %}
		{{ builder.renderZone('content_bottom', text_content_bottom, modules_by_position.content_bottom, text_drop_zone, text_add_module, '', hiddenMobileText) }}
		{% endif %}

	</div>
</main>

{# --- RIGHT PANEL: Properties --- #}
<aside class="w-60 lg:w-72 bg-white border-l border-gray-200 flex flex-col shrink-0" id="properties-panel">
	<div class="px-3 py-2.5 border-b border-gray-100 font-semibold text-xs text-gray-500 uppercase tracking-wider flex items-center gap-2">
		<i data-lucide="sliders-horizontal" class="w-3.5 h-3.5"></i>
		{{ text_properties }}
	</div>

	<div class="flex-1 p-3" id="properties-content">
		<div class="flex flex-col items-center justify-center h-full text-center text-gray-400">
			<i data-lucide="mouse-pointer-click" class="w-8 h-8 mb-2 text-gray-300"></i>
			<p class="text-xs">{{ text_select_module }}</p>
		</div>
	</div>

	<div id="properties-form" class="p-3 hidden">
		<div class="mb-3">
			<label class="block text-xs font-medium text-gray-500 mb-1">{{ entry_name }}</label>
			<input type="text" id="prop-module-name" readonly
				class="w-full border border-gray-200 rounded px-2 py-1 text-sm bg-gray-50 text-gray-600">
		</div>
		<div class="mb-3">
			<label class="block text-xs font-medium text-gray-500 mb-1">{{ text_position }}</label>
			<select id="prop-position" class="w-full border border-gray-200 rounded px-2 py-1 text-sm">
				<option value="content_top">{{ text_content_top }}</option>
				<option value="column_left">{{ text_column_left }}</option>
				<option value="column_right">{{ text_column_right }}</option>
				<option value="content_bottom">{{ text_content_bottom }}</option>
			</select>
		</div>
		<div class="mb-4">
			<label class="block text-xs font-medium text-gray-500 mb-1">{{ text_sort_order }}</label>
			<input type="number" id="prop-sort-order" min="0"
				class="w-full border border-gray-200 rounded px-2 py-1 text-sm">
		</div>
		<div class="flex flex-col gap-2">
			<button type="button" id="prop-edit-btn"
				class="flex items-center justify-center gap-1 w-full px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded">
				<i data-lucide="settings" class="w-3.5 h-3.5"></i> {{ text_edit_module }}
			</button>
			<button type="button" id="prop-remove-btn"
				class="flex items-center justify-center gap-1 w-full px-3 py-1.5 text-xs font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded">
				<i data-lucide="trash-2" class="w-3.5 h-3.5"></i> {{ text_remove_module }}
			</button>
		</div>
	</div>
</aside>

</div>

{# ==================== TOAST ==================== #}
<div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2"></div>

{# ==================== CONFIG & JS ==================== #}
<script>
window.DOCKERCART_BUILDER = {
	saveUrl: {{ action|json_encode|raw }},
	classicUrl: {{ classic_url|json_encode|raw }},
	backUrl: {{ back|json_encode|raw }},
	previewUrl: {{ preview_url|json_encode|raw }},
	userToken: {{ user_token|json_encode|raw }},
	layoutId: {{ layout_id }},
	languages: {{ languages|json_encode|raw }},
	layoutDescriptions: {{ layout_descriptions|json_encode|raw }},
	layoutRoutes: {{ layout_routes|json_encode|raw }},
	layoutModules: {{ layout_modules|json_encode|raw }},
	activePositions: {{ active_positions|json_encode|raw }},
	responsiveMap: {{ responsive_map|json_encode|raw }},
	texts: {
		dropZone: {{ text_drop_zone|json_encode|raw }},
		addModule: {{ text_add_module|json_encode|raw }},
		selectModule: {{ text_select_module|json_encode|raw }},
		editModule: {{ text_edit_module|json_encode|raw }},
		removeModule: {{ text_remove_module|json_encode|raw }},
		position: {{ text_position|json_encode|raw }},
		sortOrder: {{ text_sort_order|json_encode|raw }},
		name: {{ entry_name|json_encode|raw }},
		contentTop: {{ text_content_top|json_encode|raw }},
		columnLeft: {{ text_column_left|json_encode|raw }},
		columnRight: {{ text_column_right|json_encode|raw }},
		contentBottom: {{ text_content_bottom|json_encode|raw }},
		save: {{ button_builder_save|json_encode|raw }},
		success: {{ text_success|json_encode|raw }},
		saveError: 'Error saving layout',
		hiddenMobile: 'Hidden on Mobile & Tablet'
	}
};
</script>
<script src="view/javascript/dockercart_layout_builder.js"></script>
</body>
</html>