function updateMp4Preview($block) {
  var $a = $block.find('.dc-video-thumb');
  if (!$a.length) return;
  var $img = $a.find('.dc-video-thumb__img');
  var $overlay = $a.find('.dc-video-thumb__overlay');
  var $input = $block.find('input[type="hidden"]');
  var videoVal = $input.val();

  if (videoVal) {
    $img.hide();
    $overlay.show();
    $overlay.find('.dc-video-thumb__name').text(videoVal);
  } else {
    $img.show();
    $overlay.hide();
    $img.attr('src', $img.attr('data-placeholder'));
  }
}

function updateYoutubePreview($input) {
  var val = $input.val().trim();
  var $preview = $input.closest('.form-group').find('.dc-banner-youtube-preview');
  if (val) {
    $preview.find('.dc-banner-youtube-thumb').attr('src', 'https://img.youtube.com/vi/' + encodeURIComponent(val) + '/hqdefault.jpg');
    $preview.show();
  } else {
    $preview.hide();
  }
}

function updateAllVideoPreviews() {
  $('.slide-video-block').each(function() {
    updateMp4Preview($(this));
  });
  $('.dc-banner-video-youtube').each(function() {
    updateYoutubePreview($(this));
  });
}

function getAutocompleteRoute(type) {
  var map = {
    'product': 'catalog/product/autocomplete',
    'category': 'catalog/category/autocomplete',
    'manufacturer': 'catalog/manufacturer/autocomplete',
    'information': 'catalog/information/autocomplete',
    'blog': 'extension/module/dockercart_blog_post/autocomplete'
  };
  return map[type] || '';
}

function getAutocompleteIdKey(type) {
  var map = {
    'product': 'product_id',
    'category': 'category_id',
    'manufacturer': 'manufacturer_id',
    'information': 'information_id',
    'blog': 'blog_post_id'
  };
  return map[type] || '';
}

function getEntityRoute(type) {
  var map = {
    'product': 'route=product/product&product_id=',
    'category': 'route=product/category&path=',
    'manufacturer': 'route=product/manufacturer/info&manufacturer_id=',
    'information': 'route=information/information&information_id=',
    'blog': 'route=blog/post&blog_post_id='
  };
  return map[type] || '';
}

function initLinkAutocomplete($input) {
  $input.autocomplete({
    'source': function(request, response) {
      var $card = $input.closest('.banner-slide-card');
      var type = $card.find('.dc-link-type').val();
      var route = getAutocompleteRoute(type);
      if (!route || type === 'custom') {
        response([]);
        return;
      }
      $.ajax({
        url: 'index.php?route=' + route + '&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
        dataType: 'json',
        success: function(json) {
          response($.map(json, function(item) {
            return {
              label: item['name'],
              value: item[getAutocompleteIdKey(type)]
            }
          }));
        }
      });
    },
    'select': function(item) {
      var $card = $input.closest('.banner-slide-card');
      var type = $card.find('.dc-link-type').val();
      $card.find('.dc-link-hidden').val(getEntityRoute(type) + item.value);
      $input.val(item['label']);
    }
  });
}

function toggleLinkField($select, isInit) {
  var $card = $select.closest('.banner-slide-card');
  var val = $select.val();
  $card.find('.dc-link-custom').toggle(val === 'custom');
  $card.find('.dc-link-entity').toggle(val !== 'custom');
  if (!isInit) {
    if (val === 'custom') {
      $card.find('.dc-link-hidden').val($card.find('.dc-link-custom-input').val());
    } else {
      $card.find('.dc-link-hidden').val('');
    }
  }
}

function initLinkFields(container) {
  container.find('.dc-link-type').off('change.dcLink').on('change.dcLink', function() {
    toggleLinkField($(this));
  });
  container.find('.dc-link-custom-input').off('input.dcLink').on('input.dcLink', function() {
    var $card = $(this).closest('.banner-slide-card');
    if ($card.find('.dc-link-type').val() === 'custom') {
      $card.find('.dc-link-hidden').val($(this).val());
    }
  });
  container.find('.dc-link-autocomplete').each(function() {
    initLinkAutocomplete($(this));
  });
  container.find('.dc-link-type').each(function() {
    toggleLinkField($(this), true);
  });
}

function initVideoFields(container) {
  container.find('.dc-banner-video-youtube').each(function() {
    updateYoutubePreview($(this));
  });
  container.find('.slide-video-block').each(function() {
    updateMp4Preview($(this));
  });
}

$(document).ready(function() {
  initColorisPicker();

  $(document).on('click', '.banner-slide-card__head', function() {
    $(this).closest('.banner-slide-card').toggleClass('collapsed');
  });

  $(document).on('input', '.dc-banner-video-youtube', function() {
    var $section = $(this).closest('.slide-section');
    $section.find('.slide-video-block input[type="hidden"]').val('');
    $section.find('.dc-video-thumb__img').show();
    $section.find('.dc-video-thumb__overlay').hide();
    updateYoutubePreview($(this));
  });

  $(document).on('input', '.slide-video-block input[type="hidden"]', function() {
    var $section = $(this).closest('.slide-section');
    $section.find('.dc-banner-video-youtube').val('');
    $section.find('.dc-banner-youtube-preview').hide();
    updateMp4Preview($(this).closest('.slide-video-block'));
  });

  $(document).on('hidden.bs.modal', '#modal-image', function() {
    updateAllVideoPreviews();
  });

  $(document).on('click', '#button-clear', function() {
    setTimeout(function() {
      updateAllVideoPreviews();
    }, 100);
  });

  $('.banner-slide-card').each(function() {
    initColorInputs($(this));
    initLinkFields($(this));
  });

  $(document).on('dragstart', '.banner-slide-card', function(e) {
    var $card = $(this);
    if (!$card.hasClass('collapsed')) {
      e.preventDefault();
      return;
    }
    if (!$(e.target).closest('.slide-drag-handle').length && e.target !== this) {
      e.preventDefault();
      return;
    }
    var $list = $card.closest('[id^="slide-list-"]');
    $card.addClass('dragging');
    _dragCard = $card;
    _dragSrcLangId = $list.attr('id').replace('slide-list-', '');
    e.originalEvent.dataTransfer.effectAllowed = 'move';
    e.originalEvent.dataTransfer.setData('text/plain', '');
  });

  $(document).on('dragover', '.banner-slide-card', function(e) {
    e.preventDefault();
    e.originalEvent.dataTransfer.dropEffect = 'move';
    var $target = $(this);
    var $list = $target.closest('[id^="slide-list-"]');
    $list.find('.banner-slide-card').not('.dragging').removeClass('drag-over');
    if (!$target.hasClass('dragging')) {
      $target.addClass('drag-over');
    }
  });

  $(document).on('drop', '.banner-slide-card', function(e) {
    e.preventDefault();
    var $target = $(this);
    var $list = $target.closest('[id^="slide-list-"]');
    if (!_dragCard || _dragCard.is($target)) return;
    if ($list.attr('id') !== 'slide-list-' + _dragSrcLangId) return;

    var targetIndex = $target.index();
    var draggedIndex = _dragCard.index();

    if (targetIndex < draggedIndex) {
      _dragCard.insertBefore($target);
    } else {
      _dragCard.insertAfter($target);
    }

    renumberSlides(_dragSrcLangId);
    _dragCard = null;
    _dragSrcLangId = null;
  });

  $(document).on('dragend', '.banner-slide-card', function() {
    $(this).removeClass('dragging');
    $('[id^="slide-list-"]').find('.banner-slide-card').removeClass('drag-over');
    $('#language li').removeClass('drag-over-tab');
    _dragCard = null;
    _dragSrcLangId = null;
  });

  $(document).on('dragover', '#language li', function(e) {
    if (!_dragCard) return;
    e.preventDefault();
    var targetLangId = $(this).find('a').attr('href').replace('#language', '');
    if (targetLangId !== _dragSrcLangId) {
      $(this).addClass('drag-over-tab');
    }
  });

  $(document).on('dragleave', '#language li', function() {
    $(this).removeClass('drag-over-tab');
  });

  $(document).on('drop', '#language li a', function(e) {
    e.preventDefault();
    e.stopPropagation();
    $(this).closest('li').removeClass('drag-over-tab');

    var targetLangId = $(this).attr('href').replace('#language', '');
    if (!_dragCard || targetLangId === _dragSrcLangId) return;

    var $targetList = $('#slide-list-' + targetLangId);
    $('#no-slides-' + targetLangId).hide();
    $targetList.append(_dragCard);

    changeSlideLanguage(_dragCard, targetLangId);

    $(this).tab('show');

    renumberSlides(_dragSrcLangId);
    renumberSlides(targetLangId);

    _dragCard = null;
    _dragSrcLangId = null;
  });

  $(document).on('input', '.slide-title-input', function() {
    updateSlideLabel($(this));
  });

  $('#form-banner').on('submit', function() {
    $('[id^="slide-list-"]').each(function() {
      $(this).children('.banner-slide-card').each(function(i) {
        var $card = $(this);
        var $sortInput = $card.find('[name$="[sort_order]"]');
        if (!$sortInput.length) {
          var $firstInput = $card.find('[name^="banner_image["]');
          if ($firstInput.length) {
            var baseName = $firstInput.attr('name').replace(/\[[^\]]+\]$/, '');
            $sortInput = $('<input type="hidden">').attr('name', baseName + '[sort_order]');
            $card.append($sortInput);
          }
        }
        if ($sortInput.length) {
          $sortInput.val(i);
        }
      });
    });
  });

  $('#language a:first').tab('show');
});
</script>

</div>
{{ footer }}