{{ header }}{{ column_left }}
<div id="content">
  <link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@melloware/coloris/dist/coloris.min.css" />
  <style>
    .banner-slide-card { border: 1px solid #e5e7eb; border-radius: 10px; background: #fff; margin-bottom: 18px; overflow: hidden; }
    .banner-slide-card__head { display: flex; align-items: center; justify-content: space-between; padding: 12px 18px; background: #f9fafb; border-bottom: 1px solid #e5e7eb; }
    .banner-slide-card__num { font-weight: 700; color: #374151; font-size: 13px; }
    .banner-slide-card__body { padding: 18px; }
    .banner-slide-card .form-group { margin-bottom: 14px; }
    .banner-slide-card .form-group label { font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 4px; display: block; }
    .banner-slide-card .form-control { font-size: 13px; }
    .accent-hint { font-size: 11px; color: #9ca3af; margin-top: 3px; }
    .accent-hint code { background: #f3f4f6; border-radius: 3px; padding: 1px 4px; color: #6366f1; }
    .slide-images-row { display: flex; gap: 16px; flex-wrap: wrap; }
    .slide-image-block { text-align: center; }
    .slide-image-block small,
    .slide-video-block small { display: block; color: #9ca3af; font-size: 11px; margin-top: 4px; }
    .btn-row-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .no-slides-msg { text-align: center; color: #9ca3af; padding: 28px; font-style: italic; }
    .add-slide-btn-wrap { padding: 10px 0 4px; text-align: right; }
    .dcx-divider { border: none; border-top: 1px solid #e5e7eb; margin: 20px 0 18px; }
    .slide-section { margin-bottom: 18px; }
    .slide-section__title { font-size: 11px; font-weight: 700; color: #6366f1; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid #f3f4f6; }
    .position-radio-group { display: flex; gap: 0; max-width: 280px; }
    .position-radio-group label { display: inline-flex; align-items: center; gap: 5px; padding: 7px 14px; font-size: 12px; font-weight: 500; border: 1px solid #e5e7eb; cursor: pointer; background: #fff; color: #6b7280; transition: all .15s; }
    .position-radio-group label:first-child { border-radius: 6px 0 0 6px; }
    .position-radio-group label:last-child { border-radius: 0 6px 6px 0; }
    .position-radio-group label:has(input:checked) { background: #eef2ff; border-color: #6366f1; color: #4f46e5; }
    .position-radio-group input[type="radio"] { display: none; }
    .slide-advanced-toggle { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; color: #9ca3af; cursor: pointer; margin-top: 10px; border: none; background: none; padding: 0; }
    .slide-advanced-toggle:hover { color: #6366f1; }
    .slide-advanced-toggle .fa { transition: transform .2s; font-size: 10px; }
    .slide-advanced-toggle.open .fa { transform: rotate(90deg); }
    .slide-advanced-body { display: none; margin-top: 10px; padding-top: 10px; border-top: 1px solid #f3f4f6; }
    .slide-advanced-body.open { display: block; }
    .banner-slide-card.collapsed .banner-slide-card__body { display: none; }
    .banner-slide-card__toggle { cursor: pointer; margin-right: 6px; transition: transform .2s; vertical-align: middle; font-size: 14px; }
    .banner-slide-card:not(.collapsed) .banner-slide-card__toggle { transform: rotate(90deg); }
    .dc-video-thumb { position: relative; display: inline-flex; align-items: center; justify-content: center; min-width: 100px; min-height: 90px; }
    .dc-video-thumb__overlay { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #1f2937; border-radius: 5px; gap: 4px; color: #9ca3af; padding: 8px; }
    .dc-video-thumb__icon { width: 28px; height: 28px; stroke: #6b7280; flex-shrink: 0; }
    .dc-video-thumb__name { font-size: 10px; color: #9ca3af; word-break: break-all; text-align: center; line-height: 1.2; max-width: 100%; overflow: hidden; text-overflow: ellipsis; }
    .dc-youtube-block { display: flex; gap: 12px; align-items: flex-start; flex-wrap: wrap; }
    .dc-youtube-thumb img { display: block; border: 1px solid #e5e7eb; border-radius: 4px; max-height: 60px; width: auto; }
    .slide-drag-handle { cursor: grab; color: #9ca3af; margin-right: 6px; font-size: 13px; vertical-align: middle; }
    .slide-drag-handle:active { cursor: grabbing; }
    .banner-slide-card.drag-over { border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99,102,241,.25); }
    .banner-slide-card.dragging { opacity: .4; }
    #language li.drag-over-tab > a { background: #eef2ff; border-color: #6366f1; color: #4f46e5; }
    .btn-duplicate { color: #6366f1; margin-left: 4px; }
    .btn-duplicate:hover { color: #4f46e5; background: #eef2ff; }
  </style>

  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-banner" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    {# ── Main tabs ──────────────────────────────────────────── #}
    <ul class="nav nav-tabs dcx-profile-tabs" id="banner-tabs" role="tablist">
      <li class="active"><a href="#tab-general" data-toggle="tab"><i class="fa fa-image"></i> {{ text_tab_general }}</a></li>
      <li><a href="#tab-slides" data-toggle="tab"><i class="fa fa-list-alt"></i> {{ text_tab_slides }}</a></li>
    </ul>

    <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-banner">

      <div class="dcx-shell">

        <div class="dcx-panel">
          <div class="dcx-panel-head">
            <div class="dcx-panel-head__icon"><i class="fa fa-image"></i></div>
            <div>
              <h3 class="dcx-panel-title">{{ text_form }}</h3>
              <div class="dcx-panel-subtitle">{{ heading_title }}</div>
            </div>
          </div>
          <div class="dcx-panel-body">

            {# ── GENERAL TAB ─────────────────────────────────────── #}
            <div class="dcx-tab-pane active" id="tab-general">
              <div class="dcx-section">
                <h4>{{ text_general_settings }}</h4>
                <div class="form-horizontal dcx-form">

                  <div class="form-group required">
                    <label class="col-sm-3 control-label" for="input-name">{{ entry_name }}</label>
                    <div class="col-sm-9">
                      <input type="text" name="name" value="{{ name }}" placeholder="{{ entry_name }}" id="input-name" class="form-control" />
                      {% if error_name %}<div class="text-danger">{{ error_name }}</div>{% endif %}
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                    <div class="col-sm-9">
                      <select name="status" id="input-status" class="form-control">
                        <option value="1" {% if status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                        <option value="0" {% if not status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                      </select>
                    </div>
                  </div>

                </div>
              </div>
            </div>

            {# ── SLIDES TAB ──────────────────────────────────────── #}
            <div class="dcx-tab-pane" id="tab-slides">
              <div class="dcx-section">
                <h4>{{ text_slides_by_language }}</h4>

                <ul class="nav nav-tabs dcx-profile-tabs" id="language">
              {% for language in languages %}
              <li {% if loop.first %}class="active"{% endif %}>
                <a href="#language{{ language.language_id }}" data-toggle="tab">
                  <span class="lang-code">{{ language.code|split('-')|first|upper }}</span> {{ language.name }}
                </a>
              </li>
              {% endfor %}
                </ul>

                <div class="tab-content">
              {% set image_row = 0 %}
              {% for language in languages %}
              <div class="tab-pane {% if loop.first %}active{% endif %}" id="language{{ language.language_id }}">

                <div id="slide-list-{{ language.language_id }}">
                  {% if banner_images[language.language_id] %}
                  {% for banner_image in banner_images[language.language_id] %}
                  <div class="banner-slide-card collapsed" draggable="true" id="image-row{{ image_row }}">
                    <div class="banner-slide-card__head" style="cursor:pointer;">
                      <span>
                        <i class="fa fa-arrows slide-drag-handle"></i>
                        <i class="fa fa-chevron-right banner-slide-card__toggle"></i>
                        <span class="banner-slide-card__num"><i class="fa fa-image" style="margin-right:6px;color:#6366f1;"></i><span class="slide-label">{% if banner_image.title %}{{ banner_image.title }}{% else %}{{ text_slide }} #{{ loop.index }}{% endif %}</span></span>
                      </span>
                      <span>
                        <button type="button" onclick="duplicateSlide({{ image_row }}, {{ language.language_id }}); event.stopPropagation();" class="btn btn-default btn-xs btn-duplicate"><i class="fa fa-clone"></i></button>
                        <button type="button" onclick="removeSlide({{ image_row }}); event.stopPropagation();" class="btn btn-danger btn-xs"><i class="fa fa-trash-o"></i> {{ button_remove }}</button>
                      </span>
                    </div>
                    <div class="banner-slide-card__body">

                      {# ── Content ── #}
                      <div class="slide-section">
                        <div class="slide-section__title"><i class="fa fa-pencil" style="margin-right:4px;"></i>{{ text_tab_general }}</div>
                        <div class="form-group">
                          <label>{{ entry_title }}</label>
                          <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][title]" value="{{ banner_image.title }}" placeholder="{{ entry_title }}" class="form-control slide-title-input" />
                          <div class="accent-hint">{{ entry_title_hint }}</div>
                        </div>
                        <div class="form-group">
                          <label>{{ entry_subtitle }}</label>
                          <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][subtitle]" value="{{ banner_image.subtitle }}" placeholder="{{ entry_subtitle }}" class="form-control" />
                        </div>
                        <div class="form-group">
                          <label>{{ entry_content_position }}</label>
                          <div class="position-radio-group">
                            <label><input type="radio" name="banner_image[{{ language.language_id }}][{{ image_row }}][content_position]" value="left" {% if banner_image.content_position == 'left' %}checked{% endif %} /><i class="fa fa-align-left"></i> {{ text_content_position_left }}</label>
                            <label><input type="radio" name="banner_image[{{ language.language_id }}][{{ image_row }}][content_position]" value="center" {% if banner_image.content_position == 'center' %}checked{% endif %} /><i class="fa fa-align-center"></i> {{ text_content_position_center }}</label>
                            <label><input type="radio" name="banner_image[{{ language.language_id }}][{{ image_row }}][content_position]" value="right" {% if banner_image.content_position == 'right' %}checked{% endif %} /><i class="fa fa-align-right"></i> {{ text_content_position_right }}</label>
                          </div>
                        </div>
                      </div>

                      {# ── Media ── #}
                      <div class="slide-section">
                        <div class="slide-section__title"><i class="fa fa-image" style="margin-right:4px;"></i>{{ entry_image }}</div>
                        <div class="form-group">
                          <div class="slide-images-row">
                            <div class="slide-image-block">
                              <a href="" id="thumb-image{{ image_row }}" data-toggle="image" class="img-thumbnail"><img src="{{ banner_image.thumb }}" alt="" title="" data-placeholder="{{ placeholder }}" style="max-height:90px;" /></a>
                              <input type="hidden" name="banner_image[{{ language.language_id }}][{{ image_row }}][image]" value="{{ banner_image.image }}" id="input-image{{ image_row }}" />
                              <small>{{ text_landscape }}</small>
                            </div>
                            <div class="slide-image-block">
                              <a href="" id="thumb-image-portrait{{ image_row }}" data-toggle="image" class="img-thumbnail"><img src="{{ banner_image.thumb_portrait }}" alt="" title="" data-placeholder="{{ placeholder }}" style="max-height:90px;" /></a>
                              <input type="hidden" name="banner_image[{{ language.language_id }}][{{ image_row }}][image_portrait]" value="{{ banner_image.image_portrait }}" id="input-image-portrait{{ image_row }}" />
                              <small>{{ text_portrait }}</small>
                            </div>
                          </div>
                        </div>
                        <div class="form-group">
                          <label>{{ entry_video_type }}</label>
                          <select name="banner_image[{{ language.language_id }}][{{ image_row }}][video_type]" class="form-control dc-video-type-select" style="max-width:200px;">
                            <option value="" {% if banner_image.video_type == '' %}selected{% endif %}>{{ entry_video_type_none }}</option>
                            <option value="youtube" {% if banner_image.video_type == 'youtube' %}selected{% endif %}>{{ entry_video_type_youtube }}</option>
                            <option value="mp4" {% if banner_image.video_type == 'mp4' %}selected{% endif %}>{{ entry_video_type_mp4 }}</option>
                          </select>
                        </div>
                        <div class="form-group dc-video-field" data-type="youtube"{% if banner_image.video_type != 'youtube' %} style="display:none;"{% endif %}>
                          <label>{{ entry_video }}</label>
                          <div class="dc-youtube-block">
                            <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][video]" value="{{ banner_image.video }}" placeholder="dQw4w9WgXcQ" class="form-control dc-youtube-input" style="max-width:400px;" />
                            {% if banner_image.video_type == 'youtube' and banner_image.video %}
                            <div class="dc-youtube-thumb">
                              <img src="https://img.youtube.com/vi/{{ banner_image.video }}/hqdefault.jpg" />
                            </div>
                            {% endif %}
                          </div>
                          <div class="accent-hint">{{ help_video_youtube }}</div>
                        </div>
                        <div class="form-group dc-video-field" data-type="mp4"{% if banner_image.video_type != 'mp4' %} style="display:none;"{% endif %}>
                          <label>{{ entry_video_mp4 }}</label>
                          <div class="slide-video-block">
                            <a href="" id="thumb-video{{ image_row }}" data-toggle="image" data-type="video" class="img-thumbnail dc-video-thumb">
                              <img src="{{ video_placeholder }}" alt="" title="" data-placeholder="{{ video_placeholder }}" class="dc-video-thumb__img" style="max-height:90px;{{ banner_image.video_type == 'mp4' and banner_image.video ? 'display:none;' : '' }}" />
                              <div class="dc-video-thumb__overlay" style="{{ banner_image.video_type == 'mp4' and banner_image.video ? '' : 'display:none;' }}">
                                <i data-lucide="film" class="dc-video-thumb__icon"></i>
                                <span class="dc-video-thumb__name">{{ banner_image.video }}</span>
                              </div>
                            </a>
                            <input type="hidden" name="banner_image[{{ language.language_id }}][{{ image_row }}][video]" value="{{ banner_image.video }}" id="input-video{{ image_row }}" />
                            <small>{{ text_mp4 }}</small>
                          </div>
                          <div class="accent-hint">{{ help_video_mp4 }}</div>
                        </div>
                      </div>

                      {# ── Buttons ── #}
                      <div class="slide-section">
                        <div class="slide-section__title"><i class="fa fa-hand-pointer-o" style="margin-right:4px;"></i>{{ text_tab_slides }}</div>
                        <div class="btn-row-2col">
                          <div class="form-group">
                            <label>{{ entry_primary_btn_text }}</label>
                            <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][primary_btn_text]" value="{{ banner_image.primary_btn_text }}" placeholder="{{ placeholder_primary_btn }}" class="form-control" />
                          </div>
                          <div class="form-group">
                            <label>{{ entry_primary_btn_link }}</label>
                            <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][primary_btn_link]" value="{{ banner_image.primary_btn_link }}" placeholder="/category/new-arrivals" class="form-control" />
                          </div>
                        </div>
                        <div class="btn-row-2col">
                          <div class="form-group">
                            <label>{{ entry_secondary_btn_text }}</label>
                            <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][secondary_btn_text]" value="{{ banner_image.secondary_btn_text }}" placeholder="{{ placeholder_secondary_btn }}" class="form-control" />
                          </div>
                          <div class="form-group">
                            <label>{{ entry_secondary_btn_link }}</label>
                            <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][secondary_btn_link]" value="{{ banner_image.secondary_btn_link }}" placeholder="/collections/all" class="form-control" />
                          </div>
                        </div>
                        <button type="button" class="slide-advanced-toggle" onclick="$(this).toggleClass('open'); $(this).next('.slide-advanced-body').toggleClass('open');"><i class="fa fa-chevron-right"></i> {{ text_tab_general }}</button>
                        <div class="slide-advanced-body">
                          <div class="btn-row-2col">
                            <div class="form-group">
                              <label>{{ entry_primary_btn_text_color }}</label>
                              <div style="display:flex;gap:8px;align-items:center;">
                                <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][primary_btn_text_color]" value="{{ banner_image.primary_btn_text_color|default('#ffffff') }}" class="form-control dc-color-input primary-btn-text-color-text" data-default-color="#ffffff" placeholder="#ffffff" style="flex:1;" maxlength="16" />
                              </div>
                            </div>
                            <div class="form-group">
                              <label>{{ entry_primary_btn_bg_color }}</label>
                              <div style="display:flex;gap:8px;align-items:center;">
                                <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][primary_btn_bg_color]" value="{{ banner_image.primary_btn_bg_color|default('#2563eb') }}" class="form-control dc-color-input primary-btn-bg-color-text" data-default-color="#2563eb" placeholder="#2563eb" style="flex:1;" maxlength="16" />
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>

                      {# ── Badge ── #}
                      <div class="slide-section">
                        <div class="slide-section__title"><i class="fa fa-tag" style="margin-right:4px;"></i>{{ entry_accent_text }}</div>
                        <div class="btn-row-2col">
                          <div class="form-group">
                            <label>{{ entry_accent_text }}</label>
                            <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][accent_text]" value="{{ banner_image.accent_text }}" placeholder="{{ placeholder_accent_text }}" class="form-control" />
                          </div>
                          <div class="form-group">
                            <label>{{ entry_accent_color }}</label>
                            <div style="display:flex;gap:8px;align-items:center;">
                              <input type="text" name="banner_image[{{ language.language_id }}][{{ image_row }}][accent_color]" value="{{ banner_image.accent_color|default('#6366f1') }}" class="form-control dc-color-input accent-color-text" data-default-color="#6366f1" placeholder="#6366f1" style="flex:1;" maxlength="16" />
                            </div>
                            <div class="accent-hint">{{ entry_accent_hint }}</div>
                          </div>
                        </div>
                      </div>

                    </div>
                  </div>
                  {% set image_row = image_row + 1 %}
                  {% endfor %}
                  {% else %}
                  <div class="no-slides-msg" id="no-slides-{{ language.language_id }}"><i class="fa fa-picture-o" style="font-size:22px;margin-bottom:8px;display:block;"></i>{{ text_no_slides }}</div>
                  {% endif %}
                </div>

                <div class="add-slide-btn-wrap">
                  <button type="button" onclick="addSlide({{ language.language_id }});" class="btn btn-primary btn-sm"><i class="fa fa-plus-circle"></i> {{ button_add_slide }}</button>
                </div>

              </div>
              {% endfor %}
                </div>

            </div>

          </div>
        </div>

      </div>{# /dcx-shell #}
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/@melloware/coloris/dist/coloris.min.js"></script>
<script type="text/javascript">
var image_row = {{ image_row }};
var placeholder = '{{ placeholder }}';
var _dragCard = null;
var _dragSrcLangId = null;

function removeSlide(row) {
  $('#image-row' + row + ', .tooltip').not('.tooltip:not([id])').remove();
  $('#image-row' + row).remove();
}

function duplicateSlide(row, language_id) {
  var $original = $('#image-row' + row);
  if (!$original.length) return;

  var newRow = image_row;
  var $clone = $original.clone(true);

  $clone.attr('id', 'image-row' + newRow);

  $clone.find('[name]').each(function() {
    var name = $(this).attr('name');
    if (name) {
      $(this).attr('name', name.replace(/\[(\d+)\](?=\[[^\]]+\]$)/, '[' + newRow + ']'));
    }
  });

  $clone.find('[id]').each(function() {
    var id = $(this).attr('id');
    if (id) {
      $(this).attr('id', id.replace(/(\d+)(?!.*\d)/, newRow));
    }
  });

  $clone.find('[onclick]').each(function() {
    var onclick = $(this).attr('onclick');
    if (onclick) {
      $(this).attr('onclick', onclick.replace(/removeSlide\(\d+\)/g, 'removeSlide(' + newRow + ')').replace(/duplicateSlide\(\d+,(\d+)\)/g, 'duplicateSlide(' + newRow + ',$1)'));
    }
  });

  $clone.find('.dc-video-thumb__img').each(function() {
    var src = $(this).attr('src');
    var placeholder = $(this).attr('data-placeholder') || window.placeholder || '';
    if (src && src !== placeholder) {
      $(this).attr('src', src);
    }
  });

  $clone.attr('draggable', 'true');
  $clone.removeClass('collapsed');
  $clone.insertAfter($original);

  initColorInputs($clone);
  initVideoFields($clone);
  if (window.lucide && typeof window.lucide.createIcons === 'function') {
    window.lucide.createIcons();
  }

  image_row++;
  renumberSlides(language_id);
}

function renumberSlides(language_id) {
  var $list = $('#slide-list-' + language_id);
  var $cards = $list.children('.banner-slide-card');

  $cards.each(function(i) {
    var $card = $(this);
    var oldId = $card.attr('id');
    var oldRow = oldId ? oldId.replace('image-row', '') : '0';

    $card.attr('id', 'image-row' + i);

    $card.find('[name]').each(function() {
      var name = $(this).attr('name');
      if (name) {
        $(this).attr('name', name.replace(/\[\d+\](?=\[[^\]]+\]$)/, '[' + i + ']'));
      }
    });

    $card.find('[id]').each(function() {
      var id = $(this).attr('id');
      if (id) {
        $(this).attr('id', id.replace(/\d+(?!.*\d)/, i));
      }
    });

    $card.find('[onclick]').each(function() {
      var onclick = $(this).attr('onclick');
      if (onclick) {
        $(this).attr('onclick', onclick.replace(/removeSlide\(\d+\)/g, 'removeSlide(' + i + ')').replace(/duplicateSlide\(\d+,(\d+)\)/g, 'duplicateSlide(' + i + ',$1)'));
      }
    });

    var $title = $card.find('.slide-title-input');
    var title = $title.length ? $title.val().trim() : '';
    var fallback = '{{ text_slide }} #' + (i + 1);
    $card.find('.slide-label').text(title || fallback);

    var $sortInput = $card.find('[name$="[sort_order]"]');
    if ($sortInput.length) {
      $sortInput.val(i);
    }
  });
}

function updateSlideLabel($input) {
  var $card = $input.closest('.banner-slide-card');
  var title = $input.val().trim();
  var idx = $card.index() + 1;
  var fallback = '{{ text_slide }} #' + idx;
  $card.find('.slide-label').text(title || fallback);
}

function changeSlideLanguage($card, newLangId) {
  $card.find('[name]').each(function() {
    var name = $(this).attr('name');
    if (name) {
      $(this).attr('name', name.replace(/banner_image\[\d+\]/, 'banner_image[' + newLangId + ']'));
    }
  });
  $card.find('[onclick]').each(function() {
    var onclick = $(this).attr('onclick');
    if (onclick) {
      $(this).attr('onclick', onclick.replace(
        /duplicateSlide\(\d+,\s*\d+\)/g,
        'duplicateSlide($1,' + newLangId + ')'
      ));
    }
  });
}

function normalizeHexColor(value, fallback) {
  var val = String(value || '').trim();
  var defaultColor = fallback || '#000000';

  if (/^[0-9a-fA-F]{6}$/.test(val)) {
    return '#' + val.toLowerCase();
  }

  if (/^#[0-9a-fA-F]{3}$/.test(val)) {
    return '#' + val[1] + val[1] + val[2] + val[2] + val[3] + val[3];
  }

  if (/^#[0-9a-fA-F]{6}$/.test(val)) {
    return val.toLowerCase();
  }

  return defaultColor;
}

function initColorInputs(container) {
  container.find('.dc-color-input').each(function() {
    var $input = $(this);
    var fallback = $input.data('default-color') || '#000000';

    $input.val(normalizeHexColor($input.val(), fallback));
    $input.off('blur.dcColor').on('blur.dcColor', function() {
      $input.val(normalizeHexColor($input.val(), fallback));
    });
  });
}

function initColorisPicker() {
  if (typeof Coloris === 'undefined') {
    return;
  }

  Coloris({
    el: '.dc-color-input',
    alpha: false,
    format: 'hex',
    formatToggle: false,
    swatches: [
      '#6366f1',
      '#2563eb',
      '#ffffff',
      '#111827',
      '#f59e0b',
      '#10b981',
      '#ef4444'
    ]
  });
}

function addSlide(language_id) {
  var row = image_row;
  var pfx = 'banner_image[' + language_id + '][' + row + ']';
  var html = '<div class="banner-slide-card collapsed" draggable="true" id="image-row' + row + '">';
  html += '<div class="banner-slide-card__head" style="cursor:pointer;">';
  html += '<span>';
  html += '<i class="fa fa-arrows slide-drag-handle"></i> ';
  html += '<i class="fa fa-chevron-right banner-slide-card__toggle"></i> ';
  html += '<span class="banner-slide-card__num"><i class="fa fa-image" style="margin-right:6px;color:#6366f1;"></i><span class="slide-label">{{ text_slide }} #' + row + '</span></span></span>';
  html += '<span>';
  html += '<button type="button" onclick="duplicateSlide(' + row + ',' + language_id + '); event.stopPropagation();" class="btn btn-default btn-xs btn-duplicate"><i class="fa fa-clone"></i></button> ';
  html += '<button type="button" onclick="removeSlide(' + row + '); event.stopPropagation();" class="btn btn-danger btn-xs"><i class="fa fa-trash-o"></i> {{ button_remove }}</button>';
  html += '</span>';
  html += '</div>';
  html += '<div class="banner-slide-card__body">';

  // Content
  html += '<div class="slide-section">';
  html += '<div class="slide-section__title"><i class="fa fa-pencil" style="margin-right:4px;"></i>{{ text_tab_general }}</div>';
  html += '<div class="form-group"><label>{{ entry_title }}</label><input type="text" name="' + pfx + '[title]" value="" placeholder="{{ entry_title }}" class="form-control slide-title-input" /><div class="accent-hint">{{ entry_title_hint }}</div></div>';
  html += '<div class="form-group"><label>{{ entry_subtitle }}</label><input type="text" name="' + pfx + '[subtitle]" value="" placeholder="{{ entry_subtitle }}" class="form-control" /></div>';
  html += '<div class="form-group"><label>{{ entry_content_position }}</label>';
  html += '<div class="position-radio-group">';
  html += '<label><input type="radio" name="' + pfx + '[content_position]" value="left" checked /><i class="fa fa-align-left"></i> {{ text_content_position_left }}</label>';
  html += '<label><input type="radio" name="' + pfx + '[content_position]" value="center" /><i class="fa fa-align-center"></i> {{ text_content_position_center }}</label>';
  html += '<label><input type="radio" name="' + pfx + '[content_position]" value="right" /><i class="fa fa-align-right"></i> {{ text_content_position_right }}</label>';
  html += '</div></div>';
  html += '</div>';

  // Badge
  html += '<div class="slide-section">';
  html += '<div class="slide-section__title"><i class="fa fa-tag" style="margin-right:4px;"></i>{{ entry_accent_text }}</div>';
  html += '<div class="btn-row-2col">';
  html += '<div class="form-group"><label>{{ entry_accent_text }}</label><input type="text" name="' + pfx + '[accent_text]" value="" placeholder="{{ placeholder_accent_text }}" class="form-control" /></div>';
  html += '<div class="form-group"><label>{{ entry_accent_color }}</label><div style="display:flex;gap:8px;align-items:center;"><input type="text" name="' + pfx + '[accent_color]" value="#6366f1" class="form-control dc-color-input accent-color-text" data-default-color="#6366f1" placeholder="#6366f1" style="flex:1;" maxlength="16" /></div><div class="accent-hint">{{ entry_accent_hint }}</div></div>';
  html += '</div>';
  html += '</div>';

  // Link
  html += '<div class="slide-section">';
  html += '<div class="slide-section__title"><i class="fa fa-link" style="margin-right:4px;"></i>{{ entry_link }}</div>';
  html += '<div class="form-group"><input type="text" name="' + pfx + '[link]" value="" placeholder="{{ entry_link }}" class="form-control" /></div>';
  html += '</div>';

  html += '</div></div>';

  $('#no-slides-' + language_id).hide();
  var $card = $(html);
  $('#slide-list-' + language_id).append($card);
  initColorInputs($card);
  initVideoFields($card);
  if (window.lucide && typeof window.lucide.createIcons === 'function') {
    window.lucide.createIcons();
  }

  image_row++;
}

function initVideoFields(container) {
  container.find('.dc-video-type-select').each(function() {
    toggleVideoField($(this));
  });
}

function toggleVideoField($select) {
  var $card = $select.closest('.banner-slide-card__body, .banner-slide-card');
  var val = $select.val();
  $card.find('.dc-video-field').each(function() {
    if ($(this).data('type') === val) {
      $(this).show();
    } else {
      $(this).hide();
    }
  });
}

function updateMp4Preview($block) {
  var $a = $block.find('.dc-video-thumb');
  if (!$a.length) return;
  var $img = $a.find('.dc-video-thumb__img');
  var $overlay = $a.find('.dc-video-thumb__overlay');
  var $input = $block.find('input[type="hidden"]');
  var $card = $block.closest('.banner-slide-card__body, .banner-slide-card');
  var videoType = $card.find('.dc-video-type-select').val();
  var videoVal = $input.val();

  if (videoType === 'mp4' && videoVal) {
    $img.hide();
    $overlay.show();
    $overlay.find('.dc-video-thumb__name').text(videoVal);
  } else {
    $img.show();
    $overlay.hide();
    $img.attr('src', $img.attr('data-placeholder'));
  }
}

function updateYoutubePreview($input) {
  var val = $input.val().trim();
  var $thumb = $input.closest('.dc-youtube-block').find('.dc-youtube-thumb');
  if (val) {
    $thumb.find('img').attr('src', 'https://img.youtube.com/vi/' + encodeURIComponent(val) + '/hqdefault.jpg');
    $thumb.show();
  } else {
    $thumb.hide();
  }
}

function updateAllVideoPreviews() {
  $('.slide-video-block').each(function() {
    updateMp4Preview($(this));
  });
  $('.dc-youtube-input').each(function() {
    updateYoutubePreview($(this));
  });
}

$(document).ready(function() {
  initColorisPicker();

  $(document).on('click', '.banner-slide-card__head', function() {
    $(this).closest('.banner-slide-card').toggleClass('collapsed');
  });

  $(document).on('change', '.dc-video-type-select', function() {
    toggleVideoField($(this));
    var $card = $(this).closest('.banner-slide-card__body, .banner-slide-card');
    $card.find('.slide-video-block').each(function() {
      updateMp4Preview($(this));
    });
    $card.find('.dc-youtube-input').each(function() {
      updateYoutubePreview($(this));
    });
  });

  $(document).on('input', '.dc-youtube-input', function() {
    updateYoutubePreview($(this));
  });

  $(document).on('hidden.bs.modal', '#modal-image', function() {
    updateAllVideoPreviews();
  });

  $(document).on('click', '#button-clear', function() {
    setTimeout(function() {
      updateAllVideoPreviews();
    }, 100);
  });

  $('.banner-slide-card').each(function() {
    initColorInputs($(this));
    initVideoFields($(this));
  });

  $(document).on('dragstart', '.banner-slide-card', function(e) {
    var $card = $(this);
    if (!$card.hasClass('collapsed')) {
      e.preventDefault();
      return;
    }
    if (!$(e.target).closest('.slide-drag-handle').length && e.target !== this) {
      e.preventDefault();
      return;
    }
    var $list = $card.closest('[id^="slide-list-"]');
    $card.addClass('dragging');
    _dragCard = $card;
    _dragSrcLangId = $list.attr('id').replace('slide-list-', '');
    e.originalEvent.dataTransfer.effectAllowed = 'move';
    e.originalEvent.dataTransfer.setData('text/plain', '');
  });

  $(document).on('dragover', '.banner-slide-card', function(e) {
    e.preventDefault();
    e.originalEvent.dataTransfer.dropEffect = 'move';
    var $target = $(this);
    var $list = $target.closest('[id^="slide-list-"]');
    $list.find('.banner-slide-card').not('.dragging').removeClass('drag-over');
    if (!$target.hasClass('dragging')) {
      $target.addClass('drag-over');
    }
  });

  $(document).on('drop', '.banner-slide-card', function(e) {
    e.preventDefault();
    var $target = $(this);
    var $list = $target.closest('[id^="slide-list-"]');
    if (!_dragCard || _dragCard.is($target)) return;
    if ($list.attr('id') !== 'slide-list-' + _dragSrcLangId) return;

    var targetIndex = $target.index();
    var draggedIndex = _dragCard.index();

    if (targetIndex < draggedIndex) {
      _dragCard.insertBefore($target);
    } else {
      _dragCard.insertAfter($target);
    }

    renumberSlides(_dragSrcLangId);
    _dragCard = null;
    _dragSrcLangId = null;
  });

  $(document).on('dragend', '.banner-slide-card', function() {
    $(this).removeClass('dragging');
    $('[id^="slide-list-"]').find('.banner-slide-card').removeClass('drag-over');
    $('#language li').removeClass('drag-over-tab');
    _dragCard = null;
    _dragSrcLangId = null;
  });

  $(document).on('dragover', '#language li', function(e) {
    if (!_dragCard) return;
    e.preventDefault();
    var targetLangId = $(this).find('a').attr('href').replace('#language', '');
    if (targetLangId !== _dragSrcLangId) {
      $(this).addClass('drag-over-tab');
    }
  });

  $(document).on('dragleave', '#language li', function() {
    $(this).removeClass('drag-over-tab');
  });

  $(document).on('drop', '#language li a', function(e) {
    e.preventDefault();
    e.stopPropagation();
    $(this).closest('li').removeClass('drag-over-tab');

    var targetLangId = $(this).attr('href').replace('#language', '');
    if (!_dragCard || targetLangId === _dragSrcLangId) return;

    var $targetList = $('#slide-list-' + targetLangId);
    $('#no-slides-' + targetLangId).hide();
    $targetList.append(_dragCard);

    changeSlideLanguage(_dragCard, targetLangId);

    $(this).tab('show');

    renumberSlides(_dragSrcLangId);
    renumberSlides(targetLangId);

    _dragCard = null;
    _dragSrcLangId = null;
  });

  $(document).on('input', '.slide-title-input', function() {
    updateSlideLabel($(this));
  });

  $('#form-banner').on('submit', function() {
    $('[id^="slide-list-"]').each(function() {
      $(this).children('.banner-slide-card').each(function(i) {
        var $card = $(this);
        var $sortInput = $card.find('[name$="[sort_order]"]');
        if (!$sortInput.length) {
          var $firstInput = $card.find('[name^="banner_image["]');
          if ($firstInput.length) {
            var baseName = $firstInput.attr('name').replace(/\[[^\]]+\]$/, '');
            $sortInput = $('<input type="hidden">').attr('name', baseName + '[sort_order]');
            $card.append($sortInput);
          }
        }
        if ($sortInput.length) {
          $sortInput.val(i);
        }
      });
    });
  });

  $('#language a:first').tab('show');
});
</script>

</div>
{{ footer }}