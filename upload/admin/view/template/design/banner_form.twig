  html += '<a href="" id="thumb-video' + row + '" data-toggle="image" data-type="video" class="img-thumbnail dc-video-thumb" style="width:130px;height:100px;display:flex;align-items:center;justify-content:center;overflow:hidden;">';
  html += '<img src="{{ video_placeholder }}" alt="" title="" data-placeholder="{{ video_placeholder }}" class="dc-video-thumb__img" style="max-height:90px;" />';
  html += '<div class="dc-video-thumb__overlay" style="display:none;position:absolute;inset:0;flex-direction:column;align-items:center;justify-content:center;background:#1f2937;border-radius:5px;gap:4px;">';
