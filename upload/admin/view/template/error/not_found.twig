{{ header }}{{ column_left }}
<div id="content">
<div class="page-header">
  <div class="container-fluid">
    <h1>{{ heading_title }}</h1>
    <ul class="breadcrumb">
      {% for breadcrumb in breadcrumbs %}
      <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
      {% endfor %}
    </ul>
  </div>
</div>
<div class="container-fluid">
  <div class="panel panel-default">
    <div class="panel-heading">
      <div class="panel-heading__icon"><i class="fa fa-exclamation-triangle"></i></div>
      <div>
        <h3 class="panel-title">{{ heading_title }}</h3>
        <div class="panel-heading__subtitle">{{ text_not_found_subtitle }}</div>
      </div>
    </div>
    <div class="panel-body">
      <p class="text-center">{{ text_not_found }}</p>
    </div>
  </div>
</div>
{{ footer }}