{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">

    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div id="ext-alert-success" class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    {# ---- Toolbar ---- #}
    <style>
      .ext-toolbar-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
      .ext-toolbar-search { flex: 1 1 260px; min-width: 200px; max-width: 400px; }
      .ext-toolbar-filters { flex: 0 0 auto; white-space: nowrap; }
    </style>
    <div class="panel panel-default">
      <div class="panel-body" style="padding-bottom:8px;">
        <div class="ext-toolbar-row">
          <div class="ext-toolbar-search">
            <div class="input-group">
              <span class="input-group-addon"><i class="fa fa-search"></i></span>
              <input type="text" id="ext-search" class="form-control" placeholder="{{ text_search }}" autocomplete="off">
            </div>
          </div>
          <div class="ext-toolbar-filters">
            <label class="checkbox-inline" style="font-weight:normal;cursor:pointer;margin:0;">
              <input type="checkbox" id="ext-filter-installed"> {{ text_installed }}
            </label>
            <span id="ext-visible-count" class="text-muted" style="font-size:12px;"></span>
          </div>
        </div>
        <div class="ext-type-filter" id="ext-type-filter" role="group">
          <button type="button" class="ext-type-btn {% if filter_type == '' or filter_type == 'all' %}active{% endif %}" data-type="all">
            {{ text_all }}
          </button>
          {% for tf in type_filters %}
          <button type="button" class="ext-type-btn {% if filter_type == tf.type %}active{% endif %}" data-type="{{ tf.type }}">
            <i class="fa {{ tf.icon }}"></i>
            {{ tf.label }}
            <span class="ext-type-count">{{ tf.count }}</span>
          </button>
          {% endfor %}
        </div>
      </div>
    </div>

    {# ---- Extension groups ---- #}
    {% for group in groups %}
    <div class="ext-group" data-type="{{ group.type }}">
      <h4 class="ext-group-heading">
        <i class="fa {{ group.icon }}"></i>
        {{ group.label }}
        <small>{{ group.extensions|length }} {{ text_ext_short }}</small>
      </h4>
      <div class="row ext-cards-row">
        {% for ext in group.extensions %}
        <div class="col-lg-3 col-md-4 col-sm-6 col-xs-12 ext-card-wrapper"
             data-type="{{ group.type }}"
             data-name="{{ ext.name|striptags|lower }}"
             data-installed="{{ ext.installed ? '1' : '0' }}"
             {% if ext.installed %}data-edit="{{ ext.edit }}"{% endif %}>
          <div class="panel ext-card {{ ext.installed ? (ext.status_raw ? 'panel-success' : 'panel-default') : 'panel-default ext-card-not-installed' }}">
            {# Card header - click to edit if installed #}
            {% if ext.installed %}
            <a href="{{ ext.edit }}" class="ext-card-link">
            {% endif %}
            <div class="panel-heading">
              <i class="fa {{ group.icon }} fa-lg" style="color:{% if ext.installed %}{% if ext.status_raw %}#166534{% else %}#6b7280{% endif %}{% else %}#9ca3af{% endif %};"></i>
              <strong title="{{ ext.name|striptags }}">{{ ext.name|raw }}</strong>
              {% if ext.is_official %}
              <span style="font-size:11px;color:#2563eb;vertical-align:middle;margin-left:4px;"><i class="fa fa-check-circle"></i> {{ text_official }}</span>
              {% endif %}
            </div>
            {% if ext.installed %}
            </a>
            {% endif %}

            <div class="panel-body">
              {# Status + badges #}
              <div style="margin-bottom:8px;display:flex;align-items:center;flex-wrap:wrap;gap:4px;">
                {% if ext.installed %}
                  {% if ext.status_raw %}
                  <span class="label label-success"><i class="fa fa-check-circle"></i> {{ text_enabled }}</span>
                  {% else %}
                  <span class="label label-default"><i class="fa fa-circle-o"></i> {{ text_disabled }}</span>
                  {% endif %}
                {% else %}
                  <span class="label label-warning"><i class="fa fa-download"></i> {{ text_not_installed }}</span>
                {% endif %}
                {% if ext.sort_order is not empty %}
                <span class="label label-default" title="Sort order"><i class="fa fa-sort"></i> {{ ext.sort_order }}</span>
                {% endif %}
                {% if ext.instance_count > 0 %}
                <span class="label label-info"><i class="fa fa-clone"></i> {{ ext.instance_count }} {{ text_instances }}</span>
                {% endif %}
              </div>

              {% if ext.instances is defined and ext.instances|length > 0 %}
              <div class="ext-instances">
                {% for instance in ext.instances %}
                <div class="ext-instance">
                  <i class="fa fa-folder-open" style="color:#6b7280;flex-shrink:0;"></i>
                  <span title="{{ instance.name }}">{{ instance.name }}</span>
                  <a href="{{ instance.edit }}" class="btn btn-xs btn-info" title="{{ button_edit }}"><i class="fa fa-pencil"></i></a>
                  <button type="button" class="btn btn-xs btn-warning btn-instance-delete" title="{{ button_delete }}" data-url="{{ instance.delete }}" data-name="{{ instance.name }}" data-confirm="{{ text_confirm_instance }}"><i class="fa fa-trash-o"></i></button>
                </div>
                {% endfor %}
                <div style="margin-top:4px;">
                  <a href="{{ ext.edit }}" style="font-size:12px;"><i class="fa fa-plus-circle"></i> {{ button_add }}</a>
                </div>
              </div>
              {% endif %}

              {% if ext.ext_link %}
              <div class="ext-payment-link" onclick="event.stopPropagation();">
                {{ ext.ext_link|raw }}
              </div>
              {% endif %}
            </div>

            <div class="panel-footer">
              {% if ext.installed %}
                <a href="{{ ext.edit }}" class="btn btn-xs btn-primary" title="{{ button_edit }}">
                  <i class="fa fa-pencil"></i> {{ button_edit }}
                </a>
                <button type="button"
                        class="btn btn-xs btn-danger btn-ext-uninstall"
                        title="{{ button_uninstall }}"
                        data-url="{{ ext.uninstall_url }}"
                        data-name="{{ ext.name|striptags }}"
                        data-confirm="{{ text_confirm }}">
                  <i class="fa fa-minus-circle"></i>
                </button>
              {% else %}
                <button type="button"
                        class="btn btn-xs btn-success btn-ext-install"
                        title="{{ button_install }}"
                        data-url="{{ ext.install_url }}"
                        data-name="{{ ext.name|striptags }}">
                  <i class="fa fa-plus-circle"></i> {{ button_install }}
                </button>
              {% endif %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>{# end .row #}
    </div>{# end .ext-group #}
    {% else %}
    <div class="text-center text-muted" style="padding:40px 0;">
      <i class="fa fa-puzzle-piece fa-3x" style="display:block;margin-bottom:10px;opacity:0.5;"></i>
      {{ text_no_results }}
    </div>
    {% endfor %}

    <div id="ext-empty-state">
      <i class="fa fa-search fa-3x"></i>
      {{ text_no_results }}
    </div>

  </div>{# end .container-fluid #}
</div>{# end #content #}
{{ footer }}

<script type="text/javascript">
(function() {
  var $search   = $('#ext-search');
  var $instOnly = $('#ext-filter-installed');
  var $typeFilter = $('#ext-type-filter');
  var $emptyState = $('#ext-empty-state');
  var activeType  = '{{ filter_type }}' || 'all';

  function updateCount() {
    var visible = $('.ext-card-wrapper:visible').length;
    var countLabel = visible === 1 ? '{{ text_ext_count|escape('js') }}' : '{{ text_ext_count_plural|escape('js') }}';
    $('#ext-visible-count').text(countLabel.replace('%s', visible));
  }

  function applyFilters() {
    var query     = $search.val().toLowerCase().trim();
    var instOnly  = $instOnly.is(':checked');
    var anyVisible = false;

    // Show/hide groups
    $('.ext-group').each(function() {
      var groupType = $(this).data('type');
      var groupShow = (activeType === 'all' || activeType === groupType);
      var groupHasVisible = false;

      $(this).find('.ext-card-wrapper').each(function() {
        var $w = $(this);
        var name      = $w.data('name');
        var installed = $w.data('installed') === 1 || $w.data('installed') === '1';

        var show = groupShow
          && (!query || name.indexOf(query) !== -1)
          && (!instOnly || installed);

        $w.toggle(show);
        if (show) { groupHasVisible = true; anyVisible = true; }
      });

      // Hide entire group heading if nothing visible
      $(this).find('.ext-group-heading').toggle(groupHasVisible);
      $(this).find('.ext-cards-row').toggle(groupHasVisible);
    });

    $emptyState.toggle(!anyVisible);
    updateCount();
  }

  // Type filter buttons
  $typeFilter.on('click', '.ext-type-btn', function() {
    activeType = $(this).data('type');
    $typeFilter.find('.ext-type-btn').removeClass('active');
    $(this).addClass('active');
    applyFilters();
  });

  $search.on('input', applyFilters);
  $instOnly.on('change', applyFilters);

  // Set initial active button based on filter_type
  if (activeType !== 'all') {
    $typeFilter.find('.ext-type-btn').removeClass('active');
    $typeFilter.find('.ext-type-btn[data-type="' + activeType + '"]').addClass('active');
  }

  // Initial count
  applyFilters();

  // ---- Install / Uninstall via AJAX ----
  function showAlert(msg, type) {
    var cls = type === 'error' ? 'alert-danger' : 'alert-success';
    var icon = type === 'error' ? 'fa-exclamation-circle' : 'fa-check-circle';
    var html = '<div class="alert ' + cls + ' alert-dismissible"><i class="fa ' + icon + '"></i> ' + msg + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>';
    var $alert = $(html);
    $('#ext-alert-success, #ext-alert-danger').remove();
    $('#content > .container-fluid').prepend($alert);
  }

  function doExtAction(url, $btn, onSuccess) {
    $btn.prop('disabled', true);
    var $icon = $btn.find('i');
    var origClass = $icon.attr('class');
    $icon.attr('class', 'fa fa-spinner fa-spin');

    $.ajax({
      url: url,
      type: 'GET',
      dataType: 'json',
      success: function(json) {
        if (json.success) {
          onSuccess();
          // Refresh sidebar menu
          $.ajax({
            url: 'index.php?route=marketplace/extension/refreshMenu&user_token={{ user_token }}',
            dataType: 'html',
            success: function(html) {
              if (html) { $('#column-left').replaceWith(html); }
            }
          });
        } else {
          showAlert(json.error || 'Error', 'error');
          $icon.attr('class', origClass);
          $btn.prop('disabled', false);
        }
      },
      error: function(xhr) {
        showAlert('Server error: ' + xhr.status, 'error');
        $icon.attr('class', origClass);
        $btn.prop('disabled', false);
      }
    });
  }

  function buildReloadUrl() {
    var params = ['route=marketplace/extension', 'user_token={{ user_token }}'];
    if (activeType && activeType !== 'all') {
      params.push('type=' + encodeURIComponent(activeType));
    }
    var search = $search.val().trim();
    if (search) {
      params.push('search=' + encodeURIComponent(search));
    }
    if ($instOnly.is(':checked')) {
      params.push('installed=1');
    }
    return window.location.pathname + '?' + params.join('&');
  }

  // Install button
  $(document).on('click', '.btn-ext-install', function(e) {
    e.stopPropagation();
    var $btn  = $(this);
    var url   = $btn.data('url');

    doExtAction(url, $btn, function() {
      window.location.href = buildReloadUrl();
    });
  });

  // Uninstall button
  $(document).on('click', '.btn-ext-uninstall', function(e) {
    e.stopPropagation();
    var $btn  = $(this);
    var name  = $btn.data('name');
    var confirm_msg = $btn.data('confirm') || '{{ text_confirm }}';

    if (!confirm(confirm_msg + '\n\n' + name)) {
      return;
    }

    var url   = $btn.data('url');

    doExtAction(url, $btn, function() {
      window.location.href = buildReloadUrl();
    });
  });

  // Instance delete buttons
  $(document).on('click', '.btn-instance-delete', function(e) {
    e.stopPropagation();
    var $btn  = $(this);
    var name  = $btn.data('name');
    var confirm_msg = $btn.data('confirm') || '{{ text_confirm_instance }}';

    if (!confirm(confirm_msg + '\n\n' + name)) {
      return;
    }

    var url = $btn.data('url');

    $btn.prop('disabled', true);
    var $icon = $btn.find('i');
    var origClass = $icon.attr('class');
    $icon.attr('class', 'fa fa-spinner fa-spin');

    $.ajax({
      url: url,
      type: 'GET',
      dataType: 'json',
      success: function(json) {
        if (json.success) {
          showAlert(json.success, 'success');
          window.location.href = buildReloadUrl();
        } else {
          showAlert(json.error || 'Error', 'error');
          $icon.attr('class', origClass);
          $btn.prop('disabled', false);
        }
      },
      error: function(xhr) {
        showAlert('Server error: ' + xhr.status, 'error');
        $icon.attr('class', origClass);
        $btn.prop('disabled', false);
      }
    });
  });

  // Prevent card click propagation from action buttons
  $(document).on('click', '.ext-card .panel-footer', function(e) {
    e.stopPropagation();
  });

  // Make entire card clickable if installed
  $(document).on('click', '.ext-card', function(e) {
    if ($(e.target).closest('a, button, input, select, textarea, label').length) {
      return;
    }
    var editUrl = $(this).closest('.ext-card-wrapper').data('edit');
    if (editUrl) {
      window.location.href = editUrl;
    }
  });

})();
</script>
</script>