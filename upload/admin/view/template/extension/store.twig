{{ header }}{{ column_left }}
<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<h1>{{ heading_title }}</h1>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
				<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
				{% endfor %}
			</ul>
		</div>
	</div>
	<div class="container-fluid">
		{% if error %}
		<div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error }}</div>
		{% else %}
			{% if error_warning %}
			<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}</div>
			{% endif %}
			{% if success %}
			<div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}</div>
			{% endif %}

			<div class="panel panel-default">
				<div class="panel-heading">
					<h3 class="panel-title"><i class="fa fa-cubes"></i> {{ heading_title }}</h3>
					<div class="pull-right">
						<a href="{{ refresh_url }}" class="btn btn-warning" title="{{ text_refresh }}" data-toggle="tooltip"><i class="fa fa-refresh"></i></a>
					</div>
				</div>
				<div class="panel-body">
					<div class="row">
						<div class="col-sm-3">
							<div class="store-categories-panel">
								<div class="store-categories-header">{{ text_categories }}</div>
								<ul class="store-categories-tree">
									<li class="{% if selected_category == '' %}active{% endif %}">
										<a href="{{ base_url }}" data-category-id="">{{ text_all_categories }}</a>
									</li>
									{% for category in categories_tree %}
										<li class="{% if selected_category == category.id %}active{% endif %}">
											<a href="{{ base_url }}&category_id={{ category.id }}" data-category-id="{{ category.id }}">{{ category.name }}</a>
											{% if category.children %}
											<ul>
												{% for child in category.children %}
												<li class="{% if selected_category == child.id %}active{% endif %}">
													<a href="{{ base_url }}&category_id={{ child.id }}" data-category-id="{{ child.id }}">{{ child.name }}</a>
													{% if child.children %}
													<ul>
														{% for grandchild in child.children %}
														<li class="{% if selected_category == grandchild.id %}active{% endif %}">
															<a href="{{ base_url }}&category_id={{ grandchild.id }}" data-category-id="{{ grandchild.id }}">{{ grandchild.name }}</a>
														</li>
														{% endfor %}
													</ul>
													{% endif %}
												</li>
												{% endfor %}
											</ul>
											{% endif %}
										</li>
									{% endfor %}
								</ul>
							</div>
						</div>
						<div class="col-sm-9">
							{% if offers %}
							<p class="text-muted">{{ total_offers }} {{ text_extensions_found }}</p>
							<div class="row store-grid">
								{% for offer in offers %}
								<div class="col-sm-6 col-md-4 col-lg-3">
									<div class="store-card" data-sku="{{ offer.sku }}">
										<div class="store-card-image">
											{% if offer.pictures %}
											<img src="{{ offer.pictures[0] }}" alt="{{ offer.name }}" loading="lazy" />
											{% else %}
											<div class="store-card-image-placeholder">
												<i data-lucide="package" style="width: 48px; height: 48px; stroke-width: 1;"></i>
											</div>
											{% endif %}
										</div>
										<div class="store-card-body">
											<h4 class="store-card-title">{{ offer.name }}</h4>
											{% if offer.installed_version %}
											<small class="text-muted">{{ text_installed }}: v{{ offer.installed_version }}</small>
											{% endif %}
											{% if offer.version and offer.state == 'update' %}
											<small class="text-success">→ v{{ offer.version }}</small>
											{% elseif offer.version and not offer.installed_version %}
											<small class="text-muted">v{{ offer.version }}</small>
											{% endif %}
										</div>
										<div class="store-card-footer">
											<span class="store-card-price">
												{% if offer.price > 0 %}
												${{ offer.price|number_format(0, '.', ',') }}
												{% else %}
												<strong class="text-success">{{ text_free }}</strong>
												{% endif %}
											</span>
											{% if offer.state == 'buy' %}
											<a href="{{ offer.buy_url }}" class="btn btn-sm btn-primary store-card-btn" target="_blank" rel="noopener">
												<i class="fa fa-shopping-cart"></i> {{ text_buy }}
											</a>
											{% elseif offer.state == 'install' %}
											<button class="btn btn-sm btn-success store-card-btn store-install-btn" data-sku="{{ offer.sku }}">
												<i class="fa fa-download"></i> {{ text_install }}
											</button>
											{% elseif offer.state == 'update' %}
											<button class="btn btn-sm btn-warning store-card-btn store-update-btn" data-sku="{{ offer.sku }}">
												<i class="fa fa-arrow-up"></i> {{ text_update }}
											</button>
											{% elseif offer.state == 'up_to_date' %}
											<span class="label label-success store-card-btn-label">{{ text_up_to_date }}</span>
											{% elseif offer.state in ['revoked', 'expired'] %}
											<span class="label label-danger store-card-btn-label">{{ attribute(_context, 'text_state_' ~ offer.state) }}</span>
											{% endif %}
										</div>
									</div>
								</div>
								{% endfor %}
							</div>
							{% else %}
							<div class="text-center text-muted" style="padding: 60px 0;">
								<i data-lucide="package-open" style="width: 64px; height: 64px; stroke-width: 1; margin-bottom: 12px; display: block; margin-left: auto; margin-right: auto;"></i>
								<p>{{ text_no_extensions }}</p>
							</div>
							{% endif %}
						</div>
					</div>
				</div>
			</div>

			{% if licenses %}
			<div class="panel panel-default">
				<div class="panel-heading">
					<h3 class="panel-title"><i class="fa fa-shopping-cart"></i> {{ text_license_management }}</h3>
				</div>
				<div class="panel-body">
					<div class="table-responsive">
						<table class="table table-bordered table-hover">
							<thead>
								<tr>
									<th>{{ text_name }}</th>
									<th>{{ text_sku }}</th>
									<th>{{ text_version }}</th>
									<th>{{ text_license_key }}</th>
									<th>{{ text_status }}</th>
									<th>{{ text_expires }}</th>
									<th>{{ text_last_verified }}</th>
									<th></th>
								</tr>
							</thead>
							<tbody>
								{% for license in licenses %}
								<tr>
									<td>{{ license.ext_name }}</td>
									<td><code>{{ license.ext_sku }}</code></td>
									<td>
										{% if license.installed_version %}
											<span class="text-muted">v{{ license.installed_version }}</span>
											{% if license.update_available %}
												→ <strong class="text-warning">v{{ license.latest_version }}</strong>
											{% endif %}
										{% elseif license.latest_version %}
											<span class="text-muted">—</span>
											<small class="text-success">v{{ license.latest_version }}</small>
										{% else %}
											<span class="text-muted">—</span>
										{% endif %}
									</td>
									<td>
										<code class="store-license-key" style="cursor:pointer;font-size:11px;" data-full-key="{{ license.license_key }}">{{ license.license_key[:24] }}{% if license.license_key|length > 24 %}...{% endif %}</code>
										<i class="fa fa-pencil store-license-edit" style="cursor:pointer;margin-left:4px;" data-module-code="{{ license.module_code }}" data-full-key="{{ license.license_key }}"></i>
									</td>
									<td>
										{% if license.status == 'active' %}
										<span class="label label-success">Active</span>
										{% elseif license.status == 'grace' %}
										<span class="label label-warning">Grace</span>
										{% elseif license.status == 'revoked' %}
										<span class="label label-danger">Revoked</span>
										{% elseif license.status == 'expired' %}
										<span class="label label-danger">Expired</span>
										{% elseif license.status == 'invalid' %}
										<span class="label label-danger">Invalid</span>
										{% else %}
										<span class="label label-default">{{ license.status }}</span>
										{% endif %}
										{% if license.is_test %}<small class="text-muted"> (test)</small>{% endif %}
									</td>
									<td>{{ license.expires_at ?? '—' }}</td>
									<td>{{ license.last_verified ?? text_no_license }}</td>
									<td>
										{% if license.update_available %}
										<button class="btn btn-xs btn-warning store-update-btn" data-sku="{{ license.ext_sku }}" title="{{ text_update }}"><i class="fa fa-arrow-up"></i></button>
										{% endif %}
										{% if license.is_installed %}
										<button class="btn btn-xs btn-danger store-uninstall-btn" data-sku="{{ license.ext_sku }}" title="{{ text_uninstall }}"><i class="fa fa-trash-o"></i></button>
										{% endif %}
									</td>
								</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				</div>
			</div>
			{% endif %}
		{% endif %}
	</div>
</div>

<div class="modal fade" id="store-modal" tabindex="-1" role="dialog" aria-labelledby="store-modal-title">
	<div class="modal-dialog store-modal-dialog" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<button type="button" class="close" data-dismiss="modal" aria-label="{{ text_close }}"><span aria-hidden="true">&times;</span></button>
				<h4 class="modal-title" id="store-modal-title"></h4>
			</div>
			<div class="modal-body">
				<div id="store-modal-carousel" class="carousel slide store-modal-carousel" data-ride="carousel" style="display:none;">
					<ol class="carousel-indicators" id="store-modal-indicators"></ol>
					<div class="carousel-inner" id="store-modal-carousel-inner" role="listbox"></div>
					<a class="left carousel-control" href="#store-modal-carousel" role="button" data-slide="prev">
						<span class="fa fa-chevron-left" aria-hidden="true"></span>
					</a>
					<a class="right carousel-control" href="#store-modal-carousel" role="button" data-slide="next">
						<span class="fa fa-chevron-right" aria-hidden="true"></span>
					</a>
				</div>
				<div class="store-modal-description" id="store-modal-description"></div>
				<div class="store-modal-params" id="store-modal-params"></div>
				<div class="store-modal-changelog" id="store-modal-changelog"></div>
				<div class="store-modal-update-changelog" id="store-modal-update-changelog" style="display:none;"></div>
				<div class="store-modal-license" id="store-modal-license" style="display:none;">
					<label for="store-modal-license-key-input">{{ text_license_key }}</label>
					<div class="store-license-input-group">
						<input type="text" id="store-modal-license-key-input" class="form-control" placeholder="DCL-..." />
						<button type="button" class="btn btn-primary store-activate-btn" id="store-modal-activate-btn"><i class="fa fa-key"></i> {{ text_activate_key }}</button>
					</div>
				</div>
			</div>
			<div class="modal-footer store-modal-footer">
				<a href="#" id="store-modal-buy" class="btn btn-primary btn-lg btn-buy" target="_blank" rel="noopener">
					<i class="fa fa-shopping-cart"></i> <span id="store-modal-buy-text">{{ text_buy }}</span>
				</a>
				<button type="button" class="btn btn-success btn-lg" id="store-modal-install-btn" style="display:none;">
					<i class="fa fa-download"></i> <span>{{ text_install }}</span>
				</button>
				<button type="button" class="btn btn-warning btn-lg" id="store-modal-update-btn" style="display:none;">
					<i class="fa fa-arrow-up"></i> <span>{{ text_update }}</span>
				</button>
				<button type="button" class="btn btn-default" data-dismiss="modal">{{ text_close }}</button>
			</div>
		</div>
	</div>
</div>

<div class="modal fade" id="store-key-modal" tabindex="-1" role="dialog">
	<div class="modal-dialog modal-sm" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<button type="button" class="close" data-dismiss="modal">&times;</button>
				<h4 class="modal-title">{{ text_set_key }}</h4>
			</div>
			<div class="modal-body">
				<div class="form-group">
					<label for="key-modal-key-input">{{ text_license_key }}</label>
					<input type="text" id="key-modal-key-input" class="form-control" placeholder="DCL-..." />
					<input type="hidden" id="key-modal-module-code" />
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-primary" id="key-modal-save-btn">{{ text_set_key }}</button>
				<button type="button" class="btn btn-default" data-dismiss="modal">{{ text_close }}</button>
			</div>
		</div>
	</div>
</div>

<script type="text/javascript"><!--
$(document).ready(function() {
	var $modal = $('#store-modal');
	var $modalTitle = $('#store-modal-title');
	var $modalCarousel = $('#store-modal-carousel');
	var $modalIndicators = $('#store-modal-indicators');
	var $modalCarouselInner = $('#store-modal-carousel-inner');
	var $modalDescription = $('#store-modal-description');
	var $modalParams = $('#store-modal-params');
	var $modalBuy = $('#store-modal-buy');
	var $modalBuyText = $('#store-modal-buy-text');
	var $modalChangelog = $('#store-modal-changelog');
	var $modalUpdateChangelog = $('#store-modal-update-changelog');
	var $modalLicense = $('#store-modal-license');
	var $modalInstallBtn = $('#store-modal-install-btn');
	var $modalUpdateBtn = $('#store-modal-update-btn');
	var $modalLicenseInput = $('#store-modal-license-key-input');

	var currentDetail = null;

	function showModal(sku) {
		$modalTitle.text('{{ text_loading }}');
		$modalCarousel.hide();
		$modalDescription.html('').hide();
		$modalParams.html('').hide();
		$modalBuy.hide();
		$modalInstallBtn.hide();
		$modalUpdateBtn.hide();
		$modalChangelog.html('').hide();
		$modalUpdateChangelog.html('').hide();
		$modalLicense.hide();
		$modalBuyText.text('{{ text_buy }}');
		$modalIndicators.empty();
		$modalCarouselInner.empty();

		$.getJSON('{{ detail_url }}&sku=' + encodeURIComponent(sku), function(data) {
			if (data.error) {
				$modalTitle.text('{{ text_error }}');
				$modalDescription.html('<div class="alert alert-danger store-modal-alert">' + data.error + '</div>').show();
				$modal.modal('show');
				return;
			}

			currentDetail = data;

			$modalTitle.text(data.name);

			if (data.pictures && data.pictures.length > 0) {
				$modalCarousel.show();

				$.each(data.pictures, function(i, url) {
					var active = i === 0 ? ' active' : '';
					$modalIndicators.append($('<li>', {
						'data-target': '#store-modal-carousel',
						'data-slide-to': i,
						'class': active
					}));
					var $img = $('<img>', {
						src: url,
						alt: '',
						css: { width: '100%', maxHeight: '400px', objectFit: 'contain' }
					});
					$modalCarouselInner.append($('<div>', { class: 'item' + active }).append($img));
				});
			}

			if (data.description) {
				$modalDescription.html(data.description).show();
			}

			if (data.params && data.params.length > 0) {
				var paramsHtml = '';
				$.each(data.params, function(i, param) {
					paramsHtml += '<div class="store-param-badge">';
					paramsHtml += '<span class="store-param-label">' + param.name + '</span>';
					paramsHtml += '<span class="store-param-value">' + param.value + '</span>';
					paramsHtml += '</div>';
				});
				$modalParams.html(paramsHtml).show();
			}

			if (data.changelog) {
				var changelogHtml = '<div class="store-changelog-title">{{ text_changelog|escape('js') }}</div>';
				changelogHtml += '<div class="store-changelog-content">' + data.changelog + '</div>';
				$modalChangelog.html(changelogHtml).show();
			}

			if (data.update_changelog) {
				var updateHtml = '<div class="store-changelog-title">{{ text_whats_new|escape('js') }}</div>';
				updateHtml += data.update_changelog;
				$modalUpdateChangelog.html(updateHtml).show();
			}

			var state = data.state || 'buy';

			if (state === 'buy') {
				if (data.buy_url) {
					var priceText = '{{ text_buy }}';
					if (data.price > 0) {
						priceText += ' — $' + data.price.toLocaleString('en-US', {minimumFractionDigits: 0});
					}
					$modalBuyText.text(priceText);
					$modalBuy.attr('href', data.buy_url).show();
				}
				$modalLicense.show();
				$modalLicenseInput.val(data.license_key || '');
			} else if (state === 'install') {
				$modalInstallBtn.show();
				if (data.license_key) {
					$modalLicenseInput.val(data.license_key);
				}
				$modalLicense.show();
			} else if (state === 'update') {
				$modalUpdateBtn.show();
			} else {
				$modalBuy.hide();
				$modalInstallBtn.hide();
				$modalUpdateBtn.hide();
			}

			$modal.modal('show');
		}).fail(function() {
			$modalTitle.text('{{ text_error }}');
			$modalDescription.html('<div class="alert alert-danger store-modal-alert">{{ text_error_detail }}</div>').show();
			$modal.modal('show');
		});
	}

	$('.store-grid').on('click', '.store-card', function() {
		var sku = $(this).data('sku');
		showModal(sku);
	});

	$('.store-grid').on('click', '.store-card-btn', function(e) {
		e.stopPropagation();
	});

	$('.store-grid').on('click', '.store-install-btn', function(e) {
		e.stopPropagation();
		var sku = $(this).data('sku');
		showModal(sku);
	});

	$(document).on('click', '.store-update-btn', function(e) {
		e.stopPropagation();
		var sku = $(this).data('sku');
		showModal(sku);
	});

	$modalInstallBtn.on('click', function() {
		if (!currentDetail) return;

		var $btn = $(this).prop('disabled', true);
		var licenseKey = $modalLicenseInput.val().trim();
		var sku = currentDetail.sku;

		if (!licenseKey) {
			$btn.prop('disabled', false);
			alert('{{ error_license_required }}');
			return;
		}

		if (!confirm('{{ text_confirm_install }}')) { $btn.prop('disabled', false); return; }

		$.post('{{ install_url }}', { sku: sku, license_key: licenseKey }, function(resp) {
			if (resp.error) {
				$btn.prop('disabled', false);
				alert(resp.error);
			} else {
				alert(resp.message);
				location.reload();
			}
		}, 'json').fail(function() {
			$btn.prop('disabled', false);
			alert('{{ text_error }}');
		});
	});

	$modalUpdateBtn.on('click', function() {
		if (!currentDetail) return;

		var $btn = $(this).prop('disabled', true);
		var licenseKey = $modalLicenseInput.val().trim();

		if (!confirm('{{ text_confirm_update }}')) { $btn.prop('disabled', false); return; }

		$.post('{{ update_url }}', { sku: currentDetail.sku, license_key: licenseKey }, function(resp) {
			if (resp.error) {
				$btn.prop('disabled', false);
				alert(resp.error);
			} else {
				alert(resp.message);
				location.reload();
			}
		}, 'json').fail(function() {
			$btn.prop('disabled', false);
			alert('{{ text_error }}');
		});
	});

	$('#store-modal-activate-btn').on('click', function() {
		if (!currentDetail) return;

		var $btn = $(this).prop('disabled', true);
		var licenseKey = $modalLicenseInput.val().trim();

		if (!licenseKey) {
			$btn.prop('disabled', false);
			alert('{{ error_license_required }}');
			return;
		}

		$.post('{{ activate_key_url }}', { sku: currentDetail.sku, license_key: licenseKey }, function(resp) {
			if (resp.error) {
				$btn.prop('disabled', false);
				alert(resp.error);
			} else {
				alert(resp.message);
				$modal.modal('hide');
				location.reload();
			}
		}, 'json').fail(function() {
			$btn.prop('disabled', false);
			alert('{{ text_error }}');
		});
	});

	var $keyModal = $('#store-key-modal');
	var $keyModalInput = $('#key-modal-key-input');
	var $keyModalModuleCode = $('#key-modal-module-code');

	$(document).on('click', '.store-license-key', function() {
		var key = $(this).data('full-key');
		if (!key) return;
		if (navigator.clipboard && navigator.clipboard.writeText) {
			navigator.clipboard.writeText(key).then(function() {
				var $el = $(this);
				var orig = $el.text();
				$el.text('{{ text_copied }}');
				setTimeout(function() { $el.text(orig); }, 2000);
			}.bind(this));
		} else {
			var $input = $('<input>');
			$('body').append($input);
			$input.val(key).select();
			document.execCommand('copy');
			$input.remove();
			var $el = $(this);
			var orig = $el.text();
			$el.text('{{ text_copied }}');
			setTimeout(function() { $el.text(orig); }, 2000);
		}
	});

	$(document).on('click', '.store-license-edit', function() {
		var moduleCode = $(this).data('module-code');
		var key = $(this).data('full-key') || '';
		$keyModalModuleCode.val(moduleCode);
		$keyModalInput.val(key);
		$keyModal.modal('show');
	});

	$('#key-modal-save-btn').on('click', function() {
		var $btn = $(this).prop('disabled', true);
		var moduleCode = $keyModalModuleCode.val();
		var key = $keyModalInput.val().trim();

		if (!key) {
			$btn.prop('disabled', false);
			alert('{{ error_license_required }}');
			return;
		}

		$.post('{{ set_license_key_url }}', { module_code: moduleCode, license_key: key }, function(resp) {
			if (resp.error) {
				$btn.prop('disabled', false);
				alert(resp.error);
			} else {
				alert(resp.message);
				location.reload();
			}
		}, 'json').fail(function() {
			$btn.prop('disabled', false);
			alert('{{ text_error }}');
		});
	});

	$(document).on('click', '.store-uninstall-btn', function() {
		if (!confirm('{{ text_confirm_uninstall }}')) return;

		var $btn = $(this).prop('disabled', true);
		var sku = $btn.data('sku');

		$.post('{{ uninstall_url }}', { sku: sku }, function(resp) {
			if (resp.error) {
				alert(resp.error);
				$btn.prop('disabled', false);
			} else {
				alert(resp.message);
				location.reload();
			}
		}, 'json').fail(function() {
			alert('{{ text_error }}');
			$btn.prop('disabled', false);
