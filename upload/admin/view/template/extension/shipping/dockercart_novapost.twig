{{ header }}{{ column_left }}
<div id="content">
<link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />

<style>
.dc-np-grid { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:12px; margin-bottom:16px; }
.dc-np-card { background:#fff; border:1px solid #e6e9ef; border-radius:10px; padding:14px 16px; display:flex; flex-direction:column; gap:4px; }
.dc-np-card__k { font-size:11px; text-transform:uppercase; color:#8b96a7; letter-spacing:.04em; }
.dc-np-card__v { font-size:22px; font-weight:600; line-height:1.2; color:#2a3445; }
.dc-np-card__sub { font-size:12px; color:#8b96a7; }
.dc-np-table { width:100%; }
.dc-np-table thead th { font-size:11px; color:#6f7b8f; text-transform:uppercase; letter-spacing:.04em; font-weight:600; background:#f8fafc; padding:10px 12px; }
.dc-np-table tbody td { padding:10px 12px; vertical-align:middle; border-bottom:1px solid #f0f3f8; }
.dc-np-table tbody tr:hover { background:#fafbfe; }
.dc-np-badge { display:inline-block; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:600; }
.dc-np-badge--success { background:#e9f7ef; color:#1e7e34; }
.dc-np-badge--failed { background:#fdecee; color:#b02a37; }
.dc-np-badge--partial { background:#fff3cd; color:#856404; }
.dc-np-badge--running { background:#cce5ff; color:#004085; }
.dc-np-badge--on { background:#e9f7ef; color:#1e7e34; }
.dc-np-badge--off { background:#fdecee; color:#b02a37; }
.dc-np-empty { text-align:center; padding:40px 20px; color:#8b96a7; }
.dc-np-empty i { font-size:48px; display:block; margin-bottom:12px; opacity:0.5; }
.dc-np-country-list { max-height:200px; overflow-y:auto; border:1px solid #ddd; border-radius:4px; padding:8px; }
.dc-np-country-list label { display:block; padding:3px 0; font-weight:400; }
.dc-np-cat-list { display:flex; flex-wrap:wrap; gap:12px; }
.dc-np-cat-list label { font-weight:400; }
.dc-np-sync-btn { position:relative; }
.dc-np-sync-btn .fa-spin { display:none; }
.dc-np-sync-btn.syncing .fa-spin { display:inline; }
.dc-np-sync-btn.syncing .fa-refresh { display:none; }
@media (max-width:767px) { .dc-np-grid { grid-template-columns:1fr 1fr; } }
</style>

  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-novapost" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary">
          <i class="fa fa-save"></i>
        </button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default">
          <i class="fa fa-reply"></i>
        </a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div id="sync-alert" class="alert alert-success alert-dismissible" style="display:none;">
      <i class="fa fa-check-circle"></i> <span id="sync-message"></span>
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>

    <div id="sync-error" class="alert alert-danger alert-dismissible" style="display:none;">
      <i class="fa fa-exclamation-circle"></i> <span id="sync-error-message"></span>
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>

    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i class="fa fa-truck"></i></div>
          <div>
            <h3 class="dcx-panel-title">{{ heading_title }}</h3>
            <div class="dcx-panel-subtitle">{{ text_subtitle }}</div>
          </div>
        </div>
        <div class="dcx-panel-body">

          <ul class="nav nav-tabs dcx-profile-tabs" role="tablist">
            <li class="active"><a href="#tab-dashboard" data-toggle="tab"><i class="fa fa-dashboard"></i> {{ tab_dashboard }}</a></li>
            <li><a href="#tab-settings" data-toggle="tab"><i class="fa fa-cog"></i> {{ tab_general }}</a></li>
            <li><a href="#tab-divisions" data-toggle="tab"><i class="fa fa-building"></i> {{ tab_divisions }}</a></li>
            <li><a href="#tab-tariffs" data-toggle="tab"><i class="fa fa-tags"></i> {{ tab_tariffs }}</a></li>
            <li><a href="#tab-region-mapping" data-toggle="tab"><i class="fa fa-map-marker"></i> {{ tab_region_mapping }}</a></li>
            <li><a href="#tab-sync-log" data-toggle="tab"><i class="fa fa-history"></i> {{ tab_sync_log }}</a></li>
          </ul>

          <div class="tab-content" style="margin-top:16px;">

            {# ── Dashboard Tab ── #}
            <div class="tab-pane active" id="tab-dashboard">
              <div class="dc-np-grid">
                <div class="dc-np-card">
                  <div class="dc-np-card__k">{{ help_total_divisions }}</div>
                  <div class="dc-np-card__v">{{ total_divisions }}</div>
                </div>
                <div class="dc-np-card">
                  <div class="dc-np-card__k">{{ help_countries_loaded }}</div>
                  <div class="dc-np-card__v">{{ divisions_by_country|length }}</div>
                  {% if divisions_by_country %}
                  <div class="dc-np-card__sub">
                    {% for row in divisions_by_country %}
                      {{ row.country_code }}: {{ row.total }}{% if not loop.last %}, {% endif %}
                    {% endfor %}
                  </div>
                  {% endif %}
                </div>
                <div class="dc-np-card">
                  <div class="dc-np-card__k">{{ help_by_category }}</div>
                  <div class="dc-np-card__v">{{ divisions_by_category|length }}</div>
                  {% if divisions_by_category %}
                  <div class="dc-np-card__sub">
                    {% for row in divisions_by_category %}
                      {{ row.category }}: {{ row.total }}{% if not loop.last %}, {% endif %}
                    {% endfor %}
                  </div>
                  {% endif %}
                </div>
                <div class="dc-np-card">
                  <div class="dc-np-card__k">{{ help_last_sync }}</div>
                  {% if last_sync and last_sync.finished_at %}
                  <div class="dc-np-card__v" style="font-size:14px;">{{ last_sync.finished_at }}</div>
                  <div class="dc-np-card__sub">{{ last_sync.status }} ({{ last_sync.total_loaded }} {{ column_loaded }})</div>
                  {% else %}
                  <div class="dc-np-card__v" style="font-size:14px;">{{ text_no_sync }}</div>
                  {% endif %}
                </div>
              </div>

              <div style="margin-top:16px;">
                <button type="button" id="btn-sync" class="btn btn-primary btn-lg dc-np-sync-btn">
                  <i class="fa fa-refresh"></i> <i class="fa fa-spinner fa-spin"></i> {{ button_sync }}
                </button>
              </div>
            </div>

            {# ── Settings Tab ── #}
            <div class="tab-pane" id="tab-settings">
              <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-novapost" class="dcx-form form-horizontal">

                <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
                  <h4><i class="fa fa-key"></i> {{ text_api_config }}</h4>

                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-api-key">{{ entry_api_key }}</label>
                    <div class="col-sm-10">
                      <input type="text" name="shipping_dockercart_novapost_api_key" value="{{ shipping_dockercart_novapost_api_key }}" id="input-api-key" class="form-control" placeholder="Enter your NovaPost API key" />
                      <div class="help-block">{{ entry_api_key_help }}</div>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="col-sm-2 control-label">{{ entry_sandbox }}</label>
                    <div class="col-sm-10">
                      {% if shipping_dockercart_novapost_sandbox %}
                      <label class="radio-inline">
                        <input type="radio" name="shipping_dockercart_novapost_sandbox" value="1" checked /> {{ text_enabled }}
                      </label>
                      <label class="radio-inline">
                        <input type="radio" name="shipping_dockercart_novapost_sandbox" value="0" /> {{ text_disabled }}
                      </label>
                      {% else %}
                      <label class="radio-inline">
                        <input type="radio" name="shipping_dockercart_novapost_sandbox" value="1" /> {{ text_enabled }}
                      </label>
                      <label class="radio-inline">
                        <input type="radio" name="shipping_dockercart_novapost_sandbox" value="0" checked /> {{ text_disabled }}
                      </label>
                      {% endif %}
                      <div class="help-block">{{ entry_sandbox_help }}</div>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                    <div class="col-sm-10">
                      <select name="shipping_dockercart_novapost_status" id="input-status" class="form-control">
                        {% if shipping_dockercart_novapost_status %}
                        <option value="1" selected>{{ text_enabled }}</option>
                        <option value="0">{{ text_disabled }}</option>
                        {% else %}
                        <option value="1">{{ text_enabled }}</option>
                        <option value="0" selected>{{ text_disabled }}</option>
                        {% endif %}
                      </select>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
                    <div class="col-sm-10">
                      <input type="text" name="shipping_dockercart_novapost_sort_order" value="{{ shipping_dockercart_novapost_sort_order }}" id="input-sort-order" class="form-control" style="max-width:100px;" />
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="col-sm-2 control-label">{{ entry_calculation_method }}</label>
                    <div class="col-sm-10">
                      {% if shipping_dockercart_novapost_calculation_method == 'api' %}
                      <label class="radio-inline"><input type="radio" name="shipping_dockercart_novapost_calculation_method" value="tariff" /> {{ text_tariff }}</label>
                      <label class="radio-inline"><input type="radio" name="shipping_dockercart_novapost_calculation_method" value="api" checked /> {{ text_api }}</label>
                      {% else %}
                      <label class="radio-inline"><input type="radio" name="shipping_dockercart_novapost_calculation_method" value="tariff" checked /> {{ text_tariff }}</label>
                      <label class="radio-inline"><input type="radio" name="shipping_dockercart_novapost_calculation_method" value="api" /> {{ text_api }}</label>
                      {% endif %}
                      <div class="help-block">{{ entry_calculation_method_help }}</div>
                    </div>
                  </div>
                </div>

                <div class="dcx-section">
                  <h4><i class="fa fa-globe"></i> {{ entry_country_codes }}</h4>

                  <div class="form-group">
                    <label class="col-sm-2 control-label">{{ entry_country_codes }}</label>
                    <div class="col-sm-10">
                      <div class="dc-np-country-list">
                        {% for code, name in supported_countries %}
                        <label>
                          <input type="checkbox" name="shipping_dockercart_novapost_country_codes[]" value="{{ code }}" {% if code in shipping_dockercart_novapost_country_codes %}checked{% endif %} />
                          {{ name }} ({{ code }})
                        </label>
                        {% endfor %}
                      </div>
                      <div class="help-block">{{ entry_country_codes_help }}</div>
                    </div>
                  </div>
                </div>

                <div class="dcx-section">
                  <h4><i class="fa fa-building"></i> {{ entry_division_categories }}</h4>

                  <div class="form-group">
                    <label class="col-sm-2 control-label">{{ entry_division_categories }}</label>
                    <div class="col-sm-10">
                      <div class="dc-np-cat-list">
                        {% for cat in division_categories %}
                        <label>
                          <input type="checkbox" name="shipping_dockercart_novapost_division_categories[]" value="{{ cat }}" {% if cat in shipping_dockercart_novapost_division_categories %}checked{% endif %} />
                          {% if cat == 'CargoBranch' %}{{ category_cargo_branch }}
                          {% elseif cat == 'PostBranch' %}{{ category_post_branch }}
                          {% elseif cat == 'Postomat' %}{{ category_postomat }}
                          {% elseif cat == 'PUDO' %}{{ category_pudo }}
                          {% else %}{{ cat }}{% endif %}
                        </label>
                        {% endfor %}
                      </div>
                      <div class="help-block">{{ entry_division_categories_help }}</div>
                    </div>
                  </div>
                </div>

              </form>
            </div>

            {# ── Divisions Tab ── #}
            <div class="tab-pane" id="tab-divisions">
              <form action="{{ action }}" method="get" class="form-horizontal">
                <input type="hidden" name="route" value="extension/shipping/dockercart_novapost" />
                <input type="hidden" name="user_token" value="{{ user_token }}" />
                <input type="hidden" name="tab" value="divisions" />

                <div class="form-group">
                  <label class="col-sm-1 control-label">{{ text_search }}</label>
                  <div class="col-sm-3">
                    <input type="text" name="filter_search" value="{{ filter_search }}" class="form-control" placeholder="{{ text_search_placeholder }}" />
                  </div>
                  <label class="col-sm-1 control-label">{{ text_country }}</label>
                  <div class="col-sm-2">
                    <select name="filter_country" class="form-control">
                      <option value="">{{ text_all }}</option>
                      {% for code, name in supported_countries %}
                      <option value="{{ code }}" {% if filter_country == code %}selected{% endif %}>{{ name }}</option>
                      {% endfor %}
                    </select>
                  </div>
                  <label class="col-sm-1 control-label">{{ text_type }}</label>
                  <div class="col-sm-2">
                    <select name="filter_category" class="form-control">
                      <option value="">{{ text_all }}</option>
                      {% for cat in division_categories %}
                      <option value="{{ cat }}" {% if filter_category == cat %}selected{% endif %}>{{ cat }}</option>
                      {% endfor %}
                    </select>
                  </div>
                  <div class="col-sm-2">
                    <button type="submit" class="btn btn-primary btn-block"><i class="fa fa-search"></i> {{ button_filter }}</button>
                  </div>
                </div>
              </form>

              {% if divisions %}
              <div class="table-responsive">
                <table class="table dc-np-table">
                  <thead>
                    <tr>
                      <th>{{ column_name }}</th>
                      <th>{{ text_type }}</th>
                      <th>{{ column_country }}</th>
                      <th>{{ column_city }}</th>
                      <th>{{ column_address }}</th>
                      <th>{{ column_status }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for div in divisions %}
                    <tr>
                      <td><strong>{{ div.name }}</strong><br><small class="text-muted">{{ div.number }}</small></td>
                      <td><span class="label label-default">{{ div.category }}</span></td>
                      <td>{{ div.country_code }}</td>
                      <td>{{ div.city_name }}</td>
                      <td><small>{{ div.short_address }}</small></td>
                      <td>
                        {% if div.enabled %}
                        <span class="dc-np-badge dc-np-badge--on">{{ text_enabled }}</span>
                        {% else %}
                        <span class="dc-np-badge dc-np-badge--off">{{ text_disabled }}</span>
                        {% endif %}
                      </td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
              <div class="row">
                <div class="col-sm-6 text-left">{{ pagination_divisions }}</div>
                <div class="col-sm-6 text-right">{{ results_divisions }}</div>
              </div>
              {% else %}
              <div class="dc-np-empty">
                <i class="fa fa-building"></i>
                <p>{{ text_no_divisions }}</p>
              </div>
              {% endif %}
            </div>

            {# ── Tariffs Tab ── #}
            <div class="tab-pane" id="tab-tariffs">
              <form action="{{ action }}" method="get" class="form-horizontal">
                <input type="hidden" name="route" value="extension/shipping/dockercart_novapost" />
                <input type="hidden" name="user_token" value="{{ user_token }}" />
                <input type="hidden" name="tab" value="tariffs" />

                <div class="form-group">
                  <label class="col-sm-1 control-label">{{ text_country }}</label>
                  <div class="col-sm-2">
                    <select name="filter_tariff_country" class="form-control">
                      <option value="">{{ text_all }}</option>
                      {% for code, name in supported_countries %}
                      <option value="{{ code }}" {% if filter_tariff_country == code %}selected{% endif %}>{{ name }}</option>
                      {% endfor %}
                    </select>
                  </div>
                  <label class="col-sm-1 control-label">{{ text_type }}</label>
                  <div class="col-sm-2">
                    <select name="filter_tariff_delivery_type" class="form-control">
                      <option value="">{{ text_all }}</option>
                      {% for type, label in delivery_types %}
                      <option value="{{ type }}" {% if filter_tariff_delivery_type == type %}selected{% endif %}>{{ label }}</option>
                      {% endfor %}
                    </select>
                  </div>
                  <div class="col-sm-2">
                    <button type="submit" class="btn btn-primary btn-block"><i class="fa fa-search"></i> {{ button_filter }}</button>
                  </div>
                  <div class="col-sm-4 text-right">
                    <button type="button" id="btn-add-tariff" class="btn btn-success"><i class="fa fa-plus"></i> {{ button_add_tariff }}</button>
                  </div>
                </div>
              </form>

              <div id="tariff-form-wrapper" style="display:none; background:#f8fafc; border:1px solid #e6e9ef; border-radius:8px; padding:16px; margin-bottom:16px;">
                <h4 id="tariff-form-title" style="margin-top:0;">{{ text_add_tariff }}</h4>
                <input type="hidden" id="tariff-id" value="" />
                <div class="row">
                  <div class="col-sm-6">
                    <div class="form-group">
                      <label>{{ text_country }}</label>
                      <select id="tariff-country" class="form-control">
                        {% for code, name in supported_countries %}
                        <option value="{{ code }}">{{ name }} ({{ code }})</option>
                        {% endfor %}
                      </select>
                    </div>
                  </div>
                  <div class="col-sm-6">
                    <div class="form-group">
                      <label>{{ entry_delivery_type }}</label>
                      <select id="tariff-delivery-type" class="form-control">
                        {% for type, label in delivery_types %}
                        <option value="{{ type }}">{{ label }}</option>
                        {% endfor %}
                      </select>
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label>{{ entry_weight_from }}</label>
                      <input type="number" id="tariff-weight-from" class="form-control" step="0.001" min="0" value="0" />
                    </div>
                  </div>
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label>{{ entry_weight_to }}</label>
                      <input type="number" id="tariff-weight-to" class="form-control" step="0.001" min="0.001" value="1" />
                    </div>
                  </div>
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label>{{ entry_cost }}</label>
                      <input type="number" id="tariff-cost" class="form-control" step="0.01" min="0" value="0" />
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label>{{ entry_free_shipping_from }}</label>
                      <input type="number" id="tariff-free-from" class="form-control" step="0.01" min="0" value="" placeholder="{{ text_free_shipping_off }}" />
                    </div>
                  </div>
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label>{{ entry_sort_order }}</label>
                      <input type="number" id="tariff-sort-order" class="form-control" step="1" min="0" value="0" />
                    </div>
                  </div>
                  <div class="col-sm-4">
                    <div class="form-group">
                      <label>{{ entry_status }}</label>
                      <select id="tariff-status" class="form-control">
                        <option value="1">{{ text_enabled }}</option>
                        <option value="0">{{ text_disabled }}</option>
                      </select>
                    </div>
                  </div>
                </div>
                <div class="text-right">
                  <button type="button" id="btn-cancel-tariff" class="btn btn-default">{{ button_cancel_tariff }}</button>
                  <button type="button" id="btn-save-tariff" class="btn btn-primary">{{ button_save }}</button>
                </div>
                <div id="tariff-form-error" class="alert alert-danger" style="display:none; margin-top:8px; margin-bottom:0;">&nbsp;</div>
              </div>

              {% if tariffs %}
              <div class="table-responsive">
                <table class="table dc-np-table">
                  <thead>
                    <tr>
                      <th>{{ column_country }}</th>
                      <th>{{ column_delivery_type }}</th>
                      <th>{{ text_weight_range }}</th>
                      <th>{{ column_cost }}</th>
                      <th>{{ column_free_shipping }}</th>
                      <th>{{ column_sort_order }}</th>
                      <th>{{ column_status }}</th>
                      <th class="text-right">{{ text_action }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for t in tariffs %}
                    <tr>
                      <td><strong>{{ t.country_code }}</strong> — {{ supported_countries[t.country_code] ?? t.country_code }}</td>
                      <td>
                        {% if t.delivery_type == 'branch' %}{{ delivery_branch }}
                        {% elseif t.delivery_type == 'locker' %}{{ delivery_locker }}
                        {% elseif t.delivery_type == 'courier' %}{{ delivery_courier }}
                        {% else %}{{ t.delivery_type }}{% endif %}
                      </td>
                      <td>{{ t.weight_from }} – {{ t.weight_to }} {{ text_kg }}</td>
                      <td>{{ t.cost }}</td>
                      <td>
                        {% if t.free_shipping_from %}
                        {{ t.free_shipping_from }}
                        {% else %}
                        <span class="text-muted">{{ text_free_shipping_off }}</span>
                        {% endif %}
                      </td>
                      <td>{{ t.sort_order }}</td>
                      <td>
                        {% if t.status %}
                        <span class="dc-np-badge dc-np-badge--on">{{ text_enabled }}</span>
                        {% else %}
                        <span class="dc-np-badge dc-np-badge--off">{{ text_disabled }}</span>
                        {% endif %}
                      </td>
                      <td class="text-right">
                        <button type="button" class="btn btn-xs btn-primary btn-edit-tariff"
                          data-id="{{ t.tariff_id }}"
                          data-country="{{ t.country_code }}"
                          data-type="{{ t.delivery_type }}"
                          data-weight-from="{{ t.weight_from }}"
                          data-weight-to="{{ t.weight_to }}"
                          data-cost="{{ t.cost }}"
                          data-free="{{ t.free_shipping_from }}"
                          data-sort="{{ t.sort_order }}"
                          data-status="{{ t.status }}"
                          title="{{ button_edit_tariff }}"><i class="fa fa-pencil"></i></button>
                        <button type="button" class="btn btn-xs btn-danger btn-delete-tariff" data-id="{{ t.tariff_id }}" title="{{ button_delete_tariff }}"><i class="fa fa-trash"></i></button>
                      </td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
              <div class="row">
                <div class="col-sm-6 text-left">{{ pagination_tariffs }}</div>
                <div class="col-sm-6 text-right">{{ results_tariffs }}</div>
              </div>
              {% else %}
              <div class="dc-np-empty">
                <i class="fa fa-tags"></i>
                <p>{{ text_no_tariffs }}</p>
              </div>
              {% endif %}
            </div>

            {# ── Region Mapping Tab ── #}
            <div class="tab-pane" id="tab-region-mapping">
              <form action="{{ action }}" method="get" class="form-horizontal">
                <input type="hidden" name="route" value="extension/shipping/dockercart_novapost" />
                <input type="hidden" name="user_token" value="{{ user_token }}" />
                <input type="hidden" name="tab" value="region-mapping" />

                <div class="form-group">
                  <label class="col-sm-1 control-label">{{ text_country }}</label>
                  <div class="col-sm-2">
                    <select name="filter_region_country" class="form-control">
                      <option value="">{{ text_all }}</option>
                      {% for code, name in supported_countries %}
                      <option value="{{ code }}" {% if filter_region_country == code %}selected{% endif %}>{{ name }}</option>
                      {% endfor %}
                    </select>
                  </div>
                  <label class="col-sm-2 control-label">{{ entry_region_map_filter_status }}</label>
                  <div class="col-sm-2">
                    <select name="filter_region_mapped" class="form-control">
                      <option value="">{{ text_all_status }}</option>
                      <option value="1" {% if filter_region_mapped == '1' %}selected{% endif %}>{{ text_mapped }}</option>
                      <option value="0" {% if filter_region_mapped == '0' %}selected{% endif %}>{{ text_unmapped }}</option>
                    </select>
                  </div>
                  <div class="col-sm-2">
                    <button type="submit" class="btn btn-primary btn-block"><i class="fa fa-search"></i> {{ button_filter }}</button>
                  </div>
                </div>
              </form>

              {% if region_maps %}
              <div class="table-responsive">
                <table class="table dc-np-table">
                  <thead>
                    <tr>
                      <th>{{ column_np_region }}</th>
                      <th>{{ column_country }}</th>
                      <th>{{ column_city }}</th>
                      <th>{{ entry_oc_zone }}</th>
                      <th class="text-right">{{ text_action }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for rm in region_maps %}
                    <tr id="region-row-{{ rm.region_map_id }}">
                      <td><strong>{{ rm.localized_parent_name ?: rm.novapost_region_name }}</strong><br><small class="text-muted">ID: {{ rm.novapost_region_id }}</small></td>
                      <td>{{ rm.country_name ~ ' (' ~ rm.country_code ~ ')' }}</td>
                      <td>
                        <input type="text" class="form-control input-sm" value="{{ rm.city_name }}" placeholder="(все города региона)" style="width:220px;">
                      </td>
                      <td>
                        <select class="form-control zone-select" data-region-id="{{ rm.region_map_id }}" data-country="{{ rm.country_code }}" style="max-width:260px;">
                          <option value="0">{{ text_unmapped }}</option>
                          {% if rm.oc_zone_id > 0 %}
                          <option value="{{ rm.oc_zone_id }}" selected>{{ rm.oc_zone_id }}</option>
                          {% endif %}
                        </select>
                      </td>
                      <td class="text-right">
                        <button type="button" class="btn btn-xs btn-primary btn-map-region" data-id="{{ rm.region_map_id }}"><i class="fa fa-save"></i> {{ button_map }}</button>
                      </td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
              <div class="row">
                <div class="col-sm-6 text-left">{{ pagination_region_maps }}</div>
                <div class="col-sm-6 text-right">{{ results_region_maps }}</div>
              </div>
              {% else %}
              <div class="dc-np-empty">
                <i class="fa fa-map-marker"></i>
                <p>{{ text_no_region_maps }}</p>
              </div>
              {% endif %}
            </div>

            {# ── Sync Log Tab ── #}
            <div class="tab-pane" id="tab-sync-log">
              {% if sync_logs %}
              <div class="table-responsive">
                <table class="table dc-np-table">
                  <thead>
                    <tr>
                      <th>{{ column_status }}</th>
                      <th>{{ column_loaded }}</th>
                      <th>{{ column_errors }}</th>
                      <th>{{ column_countries }}</th>
                      <th>{{ column_started }}</th>
                      <th>{{ column_finished }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for log in sync_logs %}
                    <tr>
                      <td>
                        {% if log.status == 'success' %}
                        <span class="dc-np-badge dc-np-badge--success">{{ status_success }}</span>
                        {% elseif log.status == 'failed' %}
                        <span class="dc-np-badge dc-np-badge--failed">{{ status_failed }}</span>
                        {% elseif log.status == 'partial' %}
                        <span class="dc-np-badge dc-np-badge--partial">{{ status_partial }}</span>
                        {% else %}
                        <span class="dc-np-badge dc-np-badge--running">{{ status_running }}</span>
                        {% endif %}
                      </td>
                      <td>{{ log.total_loaded }}</td>
                      <td>{{ log.total_errors }}</td>
                      <td><small>{{ log.countries }}</small></td>
                      <td>{{ log.started_at }}</td>
                      <td>{{ log.finished_at ?: '-' }}</td>
                    </tr>
                    {% if log.error_message %}
                    <tr>
                      <td colspan="6"><small class="text-danger"><i class="fa fa-exclamation-triangle"></i> {{ log.error_message }}</small></td>
                    </tr>
                    {% endif %}
                    {% endfor %}
                  </tbody>
                </table>
              </div>
              <div class="row">
                <div class="col-sm-6 text-left">{{ pagination_sync }}</div>
                <div class="col-sm-6 text-right">{{ results_sync }}</div>
              </div>
              {% else %}
              <div class="dc-np-empty">
                <i class="fa fa-history"></i>
                <p>{{ text_no_sync_history }}</p>
              </div>
              {% endif %}
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function updateTabUrl(tabName) {
  var url = new URL(window.location.href);
  if (tabName === 'dashboard') {
    url.searchParams.delete('tab');
  } else {
    url.searchParams.set('tab', tabName);
  }
  history.replaceState(null, '', url.toString());
}

$(function() {
  var activeTab = '{{ tab }}';
  if (activeTab && activeTab !== 'dashboard') {
    $('.nav-tabs a[href="#tab-' + activeTab + '"]').tab('show');
  }

  $('.nav-tabs a[data-toggle="tab"]').on('shown.bs.tab', function(e) {
    var tabName = $(e.target).attr('href').replace('#tab-', '');
    updateTabUrl(tabName);
  });

  $('#btn-sync').on('click', function() {
    var btn = $(this);
    if (btn.hasClass('syncing')) return;

    btn.addClass('syncing').prop('disabled', true);
    $('#sync-alert, #sync-error').hide();

    var syncStart = Date.now();
    var syncTimeout = 7200000; // 2 hours

    $.ajax({
      url: '{{ sync_url }}',
      type: 'POST',
      dataType: 'json',
      timeout: syncTimeout,
      success: function(json) {
        btn.removeClass('syncing').prop('disabled', false);
        if (json.success) {
          $('#sync-message').text(json.success);
          $('#sync-alert').show();
          setTimeout(function() { location.reload(); }, 1500);
        } else if (json.error) {
          $('#sync-error-message').text(json.error);
          $('#sync-error').show();
        }
      },
      error: function(jqXHR, textStatus) {
        btn.removeClass('syncing').prop('disabled', false);
        // Browser may timeout but PHP continues (ignore_user_abort)
        if (textStatus === 'timeout') {
          $('#sync-message').text('Sync is still running in the background. Check the Sync Log tab for results.');
          $('#sync-alert').show();
          setTimeout(function() { location.reload(); }, 5000);
        } else {
          $('#sync-error-message').text('{{ error_ajax }} (' + textStatus + ')');
          $('#sync-error').show();
        }
      }
    });
  });
});

// ── Tariff tab JS ─────────────────────────────────────────────────────
(function() {
  var isEditing = false;

  function resetForm() {
    isEditing = false;
    $('#tariff-id').val('');
    $('#tariff-country').val($('#tariff-country option:first').val());
    $('#tariff-delivery-type').val($('#tariff-delivery-type option:first').val());
    $('#tariff-weight-from').val('0');
    $('#tariff-weight-to').val('1');
    $('#tariff-cost').val('0');
    $('#tariff-free-from').val('');
    $('#tariff-sort-order').val('0');
    $('#tariff-status').val('1');
    $('#tariff-form-error').hide();
    $('#tariff-form-title').text('{{ text_add_tariff }}');
  }

  function setFormData(tariff) {
    isEditing = true;
    $('#tariff-id').val(tariff.tariff_id);
    $('#tariff-country').val(tariff.country_code);
    $('#tariff-delivery-type').val(tariff.delivery_type);
    $('#tariff-weight-from').val(tariff.weight_from);
    $('#tariff-weight-to').val(tariff.weight_to);
    $('#tariff-cost').val(tariff.cost);
    $('#tariff-free-from').val(tariff.free_shipping_from || '');
    $('#tariff-sort-order').val(tariff.sort_order);
    $('#tariff-status').val(tariff.status);
    $('#tariff-form-error').hide();
    $('#tariff-form-title').text('{{ text_edit_tariff }}');
  }

  function saveTariff() {
    var tariffId = $('#tariff-id').val();
    var url = tariffId ? '{{ edit_tariff_url }}' : '{{ add_tariff_url }}';

    var data = {
      tariff_id: tariffId || 0,
      country_code: $('#tariff-country').val(),
      delivery_type: $('#tariff-delivery-type').val(),
      weight_from: $('#tariff-weight-from').val(),
      weight_to: $('#tariff-weight-to').val(),
      cost: $('#tariff-cost').val(),
      free_shipping_from: $('#tariff-free-from').val(),
      sort_order: $('#tariff-sort-order').val(),
      status: $('#tariff-status').val()
    };

    $.ajax({
      url: url,
      type: 'POST',
      dataType: 'json',
      data: data,
      success: function(json) {
        if (json.success) {
          location.reload();
        } else if (json.error) {
          $('#tariff-form-error').text(json.error).show();
        }
      },
      error: function() {
        $('#tariff-form-error').text('{{ error_ajax }}').show();
      }
    });
  }

  $('#btn-add-tariff').on('click', function() {
    resetForm();
    $('#tariff-form-wrapper').slideDown();
    $('#tariff-form-wrapper')[0].scrollIntoView({behavior: 'smooth'});
  });

  $('#btn-cancel-tariff').on('click', function() {
    $('#tariff-form-wrapper').slideUp();
    resetForm();
  });

  $('#btn-save-tariff').on('click', function() {
    saveTariff();
  });

  $(document).on('click', '.btn-edit-tariff', function() {
    var $btn = $(this);
    var tariff = {
      tariff_id:     $btn.data('id'),
      country_code:  $btn.data('country'),
      delivery_type: $btn.data('type'),
      weight_from:   $btn.data('weight-from'),
      weight_to:     $btn.data('weight-to'),
      cost:          $btn.data('cost'),
      free_shipping_from: $btn.data('free') || '',
      sort_order:    $btn.data('sort'),
      status:        $btn.data('status')
    };
    setFormData(tariff);
    $('#tariff-form-wrapper').slideDown();
    $('#tariff-form-wrapper')[0].scrollIntoView({behavior: 'smooth'});
  });

  $(document).on('click', '.btn-delete-tariff', function() {
    if (!confirm('{{ confirm_delete_tariff }}')) return;
    var tariffId = $(this).data('id');
    $.ajax({
      url: '{{ delete_tariff_url }}',
      type: 'POST',
      dataType: 'json',
      data: { tariff_id: tariffId },
      success: function(json) {
        if (json.success) {
          location.reload();
        } else if (json.error) {
          alert(json.error);
        }
      }
    });
  });
})();

// ── Region Mapping JS ──────────────────────────────────────────────────
(function() {
  var zoneCache = {};

  function loadZones($select, countryCode, selectedZoneId) {
    if (zoneCache[countryCode]) {
      populateSelect($select, zoneCache[countryCode], selectedZoneId);
      return;
    }
    $.ajax({
      url: '{{ get_zones_url }}',
      type: 'GET',
      dataType: 'json',
      data: { country_code: countryCode },
      success: function(zones) {
        zoneCache[countryCode] = zones || [];
        populateSelect($select, zoneCache[countryCode], selectedZoneId);
      }
    });
  }

  function populateSelect($select, zones, selectedZoneId) {
    $select.empty();
    $select.append('<option value="0">{{ text_unmapped }}</option>');
    for (var i = 0; i < zones.length; i++) {
      var sel = (zones[i].zone_id == selectedZoneId) ? ' selected' : '';
      $select.append('<option value="' + zones[i].zone_id + '"' + sel + '>' + zones[i].name + ' (' + zones[i].code + ')</option>');
    }
  }

  // Populate zone selects on load
  $('.zone-select').each(function() {
    var $sel = $(this);
    var country = $sel.data('country');
    var currentZoneId = $sel.val() || 0;
    loadZones($sel, country, currentZoneId);
  });

  // Save region mapping
  $(document).on('click', '.btn-map-region', function() {
    var $btn = $(this);
    var regionMapId = $btn.data('id');
    var $row = $('#region-row-' + regionMapId);
    var $select = $row.find('.zone-select');
    var $cityInput = $row.find('input[type="text"]');
    var ocZoneId = $select.val() || 0;
    var cityName = $cityInput ? $cityInput.val().trim() : '';

    $btn.prop('disabled', true);

    $.ajax({
      url: '{{ update_region_map_url }}',
      type: 'POST',
      dataType: 'json',
      data: { region_map_id: regionMapId, oc_zone_id: ocZoneId, city_name: cityName },
      success: function(json) {
        $btn.prop('disabled', false);
        if (json.success) {
          $btn.removeClass('btn-primary').addClass('btn-success').find('i').removeClass('fa-save').addClass('fa-check');
          setTimeout(function() {
            $btn.removeClass('btn-success').addClass('btn-primary').find('i').removeClass('fa-check').addClass('fa-save');
          }, 1500);
        } else if (json.error) {
          alert(json.error);
        }
      },
      error: function() {
        $btn.prop('disabled', false);
      }
    });
  });
})();
</script>
{{ footer }}
