{{ header }}{{ column_left }}
<div id="content">
  <link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-image" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ gallery_id ? text_edit_image : text_add_image }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i class="fa fa-edit"></i></div>
          <div>
            <h3 class="dcx-panel-title">{{ gallery_id ? text_edit_image : text_add_image }}</h3>
            <div class="dcx-panel-subtitle">{{ text_gallery_form_subtitle }}</div>
          </div>
        </div>
        <div class="dcx-panel-body">
          <form action="{{ action }}" method="post" id="form-image" class="form-horizontal dcx-form">
            <input type="hidden" name="gallery_id" value="{{ image.gallery_id }}" />

            <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
              <h4>{{ tab_general }}</h4>

              <div class="form-group required">
                <label class="col-sm-2 control-label" for="input-image">{{ entry_image }}</label>
                <div class="col-sm-10">
                  <a href="" id="thumb-image" data-toggle="image" class="img-thumbnail">
                    <img src="{{ thumb }}" alt="" title="" data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden" name="image" value="{{ image.image }}" id="input-image" />
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
                <div class="col-sm-4">
                  <input type="number" name="sort_order" id="input-sort-order" class="form-control" value="{{ image.sort_order }}" />
                </div>

                <label class="col-sm-2 control-label" for="input-image-status">{{ entry_image_status }}</label>
                <div class="col-sm-4">
                  <select name="status" id="input-image-status" class="form-control">
                    <option value="1" {% if image.status %}selected{% endif %}>{{ text_enabled }}</option>
                    <option value="0" {% if not image.status %}selected{% endif %}>{{ text_disabled }}</option>
                  </select>
                </div>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
{{ footer }}
