<div class="modal-header">
  <button type="button" class="close" data-dismiss="modal">&times;</button>
  <h4 class="modal-title"><i class="fa fa-tag"></i> {{ cookie_id ? text_edit_cookie : text_add_cookie }}</h4>
</div>
<div class="modal-body">
  <form id="form-cookie" class="form-horizontal">
    <input type="hidden" name="cookie_id" value="{{ cookie_id }}" />

    <div class="form-group">
      <label class="col-sm-2 control-label">{{ entry_name }}</label>
      <div class="col-sm-10">
        <input type="text" name="name" value="{{ name }}" class="form-control" required />
      </div>
    </div>

    <div class="form-group">
      <label class="col-sm-2 control-label">{{ entry_group }}</label>
      <div class="col-sm-10">
        <select name="cookie_group_id" class="form-control">
          {% for group in cookie_groups %}
            <option value="{{ group.cookie_group_id }}" {% if cookie_group_id == group.cookie_group_id %}selected{% endif %}>{{ group.name }}</option>
          {% endfor %}
        </select>
      </div>
    </div>

    <div class="form-group">
      <label class="col-sm-2 control-label">{{ entry_provider }}</label>
      <div class="col-sm-10">
        <input type="text" name="provider" value="{{ provider }}" class="form-control" />
      </div>
    </div>

    <div class="form-group">
      <label class="col-sm-2 control-label">{{ entry_domain }}</label>
      <div class="col-sm-10">
        <input type="text" name="domain" value="{{ domain }}" class="form-control" />
      </div>
    </div>

    <div class="form-group">
      <label class="col-sm-2 control-label">{{ entry_duration }}</label>
      <div class="col-sm-10">
        <input type="text" name="duration" value="{{ duration }}" class="form-control" placeholder="e.g. 1 year, session" />
      </div>
    </div>

    <div class="form-group">
      <label class="col-sm-2 control-label">{{ entry_sort_order }}</label>
      <div class="col-sm-10">
        <input type="number" name="sort_order" value="{{ sort_order }}" class="form-control" />
      </div>
    </div>

    <div class="form-group">
      <label class="col-sm-2 control-label">{{ entry_status }}</label>
      <div class="col-sm-10">
        <select name="status" class="form-control">
          <option value="1" {% if status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
          <option value="0" {% if not status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
        </select>
      </div>
    </div>

    <ul class="nav nav-tabs" id="cookie-lang-tabs">
      {% for language in languages %}
        <li{% if loop.first %} class="active"{% endif %}><a href="#cookie-lang-{{ language.language_id }}" data-toggle="tab"><span class="lang-code">{{ language.code|split('-')|first|upper }}</span> {{ language.name }}</a></li>
      {% endfor %}
    </ul>

    <div class="tab-content">
      {% for language in languages %}
        <div class="tab-pane{% if loop.first %} active{% endif %}" id="cookie-lang-{{ language.language_id }}">
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_description }}</label>
            <div class="col-sm-10">
              <textarea name="cookie_description[{{ language.language_id }}][description]" rows="3" class="form-control">{{ cookie_description[language.language_id].description }}</textarea>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </form>
</div>
<div class="modal-footer">
  <button type="button" class="btn btn-default" data-dismiss="modal">{{ button_cancel }}</button>
  <button type="button" class="btn btn-primary" id="button-save-cookie"><i class="fa fa-save"></i> {{ button_save }}</button>
</div>

<script type="text/javascript">
$('#button-save-cookie').on('click', function() {
  $.ajax({
    url: '{{ action }}',
    type: 'post',
    data: $('#form-cookie').serialize(),
    dataType: 'json',
    success: function(json) {
      if (json.success) {
        $.magnificPopup.close();
        loadGdprTabContent('gdpr-cookie-groups');
      }
    }
  });
});
</script>
