<div id="gdpr-cookie-groups-list">
  <div class="table-responsive">
    <table class="table table-bordered table-hover dcx-table">
      <thead>
        <tr>
          <td>{{ column_name }}</td>
          <td>{{ column_sort_order }}</td>
          <td class="text-center">{{ column_is_required }}</td>
          <td class="text-center">{{ column_status }}</td>
          <td class="text-right">{{ column_action }}</td>
        </tr>
      </thead>
      <tbody>
        {% if cookie_groups %}
          {% for group in cookie_groups %}
            <tr>
              <td>{{ group.name }}</td>
              <td>{{ group.sort_order }}</td>
              <td class="text-center">
                {% if group.is_required %}
                  <span class="label label-success">{{ text_yes }}</span>
                {% else %}
                  <span class="label label-default">{{ text_no }}</span>
                {% endif %}
              </td>
              <td class="text-center">
                {% if group.status %}
                  <span class="label label-success">{{ text_enabled }}</span>
                {% else %}
                  <span class="label label-danger">{{ text_disabled }}</span>
                {% endif %}
              </td>
              <td class="text-right">
                <a href="{{ group.cookies }}" class="btn btn-info btn-xs" onclick="return loadCookieList(this.href);" title="{{ text_cookies }}"><i class="fa fa-list"></i></a>
                <a href="{{ group.edit }}" class="btn btn-primary btn-xs" onclick="return loadCookieGroupForm(this.href);" title="{{ button_edit }}"><i class="fa fa-pencil"></i></a>
                <a href="{{ group.delete }}" class="btn btn-danger btn-xs" onclick="return confirm('{{ text_confirm_delete }}?');" title="{{ button_delete }}"><i class="fa fa-trash"></i></a>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td class="text-center" colspan="5">{{ text_no_results }}</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>

  <div class="text-right" style="margin-top:10px;">
    <a href="{{ add }}" class="btn btn-primary" onclick="return loadCookieGroupForm(this.href);"><i class="fa fa-plus"></i> {{ button_add_group }}</a>
  </div>
</div>

<div id="gdpr-cookies-sub" class="hidden"></div>

<script type="text/javascript">
function loadCookieGroupForm(url) {
  $.get(url, function(html) {
    $.magnificPopup.open({
      type: 'inline',
      preloader: false,
      items: { src: '<div class="modal-dialog"><div class="modal-content">' + html + '</div></div>' }
    });
  });
  return false;
}

function loadCookieList(url) {
  $.get(url, function(html) {
    $('#gdpr-cookie-groups-list').addClass('hidden');
    $('#gdpr-cookies-sub').html(html).removeClass('hidden');
  });
  return false;
}

function backToCookieGroups() {
  $('#gdpr-cookies-sub').addClass('hidden').empty();
  $('#gdpr-cookie-groups-list').removeClass('hidden');
}
</script>
