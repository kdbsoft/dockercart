{{ header }}{{ column_left }}
<div id="content">
  <link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
  <script src="view/javascript/lucide.min.js"></script>

  <style>
  .dc-icon-picker-modal { display:none; position:fixed; inset:0; z-index:12000; }
  .dc-icon-picker-backdrop { position:absolute; inset:0; background:rgba(0,0,0,0.45); }
  .dc-icon-picker-panel { position:relative; max-width:860px; margin:6vh auto; background:#fff; border-radius:10px; padding:16px; box-shadow:0 10px 40px rgba(2,6,23,0.28); }
  .dc-icon-picker-header { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px; }
  .dc-icon-picker-search { width:100%; max-width:480px; }
  .dc-icon-picker-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(56px,1fr)); gap:8px; max-height:56vh; overflow:auto; padding:6px; }
  .dc-icon-option { display:flex; align-items:center; justify-content:center; gap:6px; border:1px solid #e6eef8; background:#f8fbff; padding:8px; border-radius:8px; cursor:pointer; }
  .dc-icon-option:hover { background:#eaf4ff; border-color:#cfe8ff; }
  .dc-icon-option i { width:18px; height:18px; }
  .dc-icon-sm { width:14px; height:14px; display:inline-block; }
  .dc-icon-picker-btn { display:inline-flex; align-items:center; gap:6px; border:1px solid #d0d5dd; background:#fff; padding:6px 12px; border-radius:6px; cursor:pointer; white-space:nowrap; }
  .dc-icon-picker-btn:hover { background:#f5f7fa; border-color:#98a2b3; }
  .dc-icon-picker-btn i { width:16px; height:16px; }
  </style>

  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-module" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_back }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}

    {% if success %}
      <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}

    <div class="row" style="margin-bottom: 15px;">
      <div class="col-sm-4">
        <div class="panel panel-default">
          <div class="panel-heading"><strong>{{ text_widgets }}</strong></div>
          <div class="panel-body" style="padding: 0;">
            {% if widgets %}
              <div class="list-group" style="margin-bottom: 0;">
                {% for widget in widgets %}
                  <a href="{{ widget.href }}" class="list-group-item{% if widget.active %} active{% endif %}">
                    {{ widget.name }}
                  </a>
                {% endfor %}
              </div>
            {% else %}
              <div style="padding: 15px; color: #8c8c8c;">{{ text_no_widgets }}</div>
            {% endif %}
          </div>
          <div class="panel-footer">
            <a href="{{ new_widget }}" class="btn btn-primary btn-sm"><i class="fa fa-plus"></i> {{ text_create_widget }}</a>
          </div>
        </div>
      </div>

      <div class="col-sm-8">
        <div class="panel panel-default">
          <div class="panel-heading"><strong>{{ text_widget_settings }}</strong></div>
          <div class="panel-body">
            <form action="{{ action }}" method="post" id="form-module" class="form-horizontal">
              <div class="form-group required">
                <label class="col-sm-3 control-label">{{ entry_name }}</label>
                <div class="col-sm-9">
                  <ul class="nav nav-tabs" style="margin-bottom:10px;">
                    {% for language in languages %}
                    <li{% if loop.first %} class="active"{% endif %}><a href="#name-lang-{{ language.language_id }}" data-toggle="tab"><span class="lang-code">{{ language.code|split('-')|first|upper }}</span> {{ language.name }}</a></li>
                    {% endfor %}
                  </ul>
                  <div class="tab-content">
                    {% for language in languages %}
                    <div class="tab-pane{% if loop.first %} active{% endif %}" id="name-lang-{{ language.language_id }}">
                      <input type="text" name="name_translation[{{ language.language_id }}]" value="{{ name_translation[language.language_id] }}" placeholder="{{ entry_name }}" class="form-control" />
                    </div>
                    {% endfor %}
                  </div>
                  {% if error_name %}
                    <div class="text-danger">{{ error_name }}</div>
                  {% endif %}
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-9">
                  <select name="status" id="input-status" class="form-control">
                    <option value="1" {% if status %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                    <option value="0" {% if not status %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">{{ entry_section_title }}</label>
                <div class="col-sm-9">
                  <ul class="nav nav-tabs" role="tablist" style="margin-bottom: 10px;">
                    {% for language in languages %}
                      <li{% if loop.first %} class="active"{% endif %}><a href="#section-title-lang-{{ language.language_id }}" data-toggle="tab"><span class="lang-code">{{ language.code|split('-')|first|upper }}</span> {{ language.name }}</a></li>
                    {% endfor %}
                  </ul>
                  <div class="tab-content">
                    {% for language in languages %}
                      <div class="tab-pane{% if loop.first %} active{% endif %}" id="section-title-lang-{{ language.language_id }}">
                        <input type="text" name="section_title[{{ language.language_id }}]" value="{{ section_title[language.language_id]|default('') }}" placeholder="{{ entry_section_title }}" class="form-control" />
                      </div>
                    {% endfor %}
                  </div>
                </div>
              </div>
              <div class="form-group">
                <label class="col-sm-3 control-label">{{ entry_section_subtitle }}</label>
                <div class="col-sm-9">
                  <ul class="nav nav-tabs" role="tablist" style="margin-bottom: 10px;">
                    {% for language in languages %}
                      <li{% if loop.first %} class="active"{% endif %}><a href="#section-subtitle-lang-{{ language.language_id }}" data-toggle="tab"><span class="lang-code">{{ language.code|split('-')|first|upper }}</span> {{ language.name }}</a></li>
                    {% endfor %}
                  </ul>
                  <div class="tab-content">
                    {% for language in languages %}
                      <div class="tab-pane{% if loop.first %} active{% endif %}" id="section-subtitle-lang-{{ language.language_id }}">
                        <textarea name="section_subtitle[{{ language.language_id }}]" rows="2" placeholder="{{ entry_section_subtitle }}" class="form-control">{{ section_subtitle[language.language_id]|default('') }}</textarea>
                      </div>
                    {% endfor %}
                  </div>
                </div>
              </div>

              <hr />
              <h4 style="margin-top: 0;">{{ text_features }}</h4>

              <div class="table-responsive">
                <table class="table table-bordered table-hover" id="features-table">
                  <thead>
                    <tr>
                      <th style="width: 220px;">{{ entry_icon }}</th>
                      <th>{{ text_multilingual_settings }}</th>
                      <th style="width: 120px;">{{ entry_sort_order }}</th>
                      <th style="width: 80px;">{{ column_action }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% set feature_row = 0 %}
                    {% for feature in features %}
                      <tr id="feature-row-{{ feature_row }}">
                        <td>
                          <input type="hidden" name="features[{{ feature_row }}][icon]" id="feature-icon-{{ feature_row }}" value="{{ feature.icon|default('truck') }}" />
                          <button type="button" class="dc-icon-picker-btn dc-icon-picker-button" data-target="#feature-icon-{{ feature_row }}" title="{{ feature.icon|default('truck') }}">
                            <i data-lucide="{{ feature.icon|default('truck') }}" class="dc-icon-sm"></i>
                            <span class="dc-icon-label">{{ feature.icon|default('truck') }}</span>
                          </button>
                        </td>
                        <td>
                          <ul class="nav nav-tabs" role="tablist" style="margin-bottom: 10px;">
                            {% for language in languages %}
                              <li{% if loop.first %} class="active"{% endif %}><a href="#feature-{{ feature_row }}-lang-{{ language.language_id }}" data-toggle="tab"><span class="lang-code">{{ language.code|split('-')|first|upper }}</span> {{ language.name }}</a></li>
                            {% endfor %}
                          </ul>

                          <div class="tab-content">
                            {% for language in languages %}
                              <div class="tab-pane{% if loop.first %} active{% endif %}" id="feature-{{ feature_row }}-lang-{{ language.language_id }}">
                                <div class="form-group" style="margin-left: 0; margin-right: 0;">
                                  <label class="control-label">{{ entry_title }}</label>
                                  <input type="text" name="features[{{ feature_row }}][title][{{ language.language_id }}]" value="{{ feature.title[language.language_id]|default('') }}" class="form-control" />
                                </div>
                                <div class="form-group" style="margin-left: 0; margin-right: 0; margin-bottom: 0;">
                                  <label class="control-label">{{ entry_text }}</label>
                                  <textarea name="features[{{ feature_row }}][text][{{ language.language_id }}]" rows="3" class="form-control">{{ feature.text[language.language_id]|default('') }}</textarea>
                                </div>
                              </div>
                            {% endfor %}
                          </div>
                        </td>
                        <td>
                          <input type="number" name="features[{{ feature_row }}][sort_order]" value="{{ feature.sort_order|default(0) }}" class="form-control" />
                        </td>
                        <td class="text-center">
                          <button type="button" onclick="$('#feature-row-{{ feature_row }}').remove();" class="btn btn-danger" title="{{ button_remove }}"><i class="fa fa-trash"></i></button>
                        </td>
                      </tr>
                      {% set feature_row = feature_row + 1 %}
                    {% endfor %}
                  </tbody>
                  <tfoot>
                    <tr>
                      <td colspan="4" class="text-right">
                        <button type="button" id="button-add-feature" class="btn btn-primary"><i class="fa fa-plus"></i> {{ button_add_feature }}</button>
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Icon picker modal -->
<div id="dc-icon-picker-modal" class="dc-icon-picker-modal hidden">
  <div class="dc-icon-picker-backdrop"></div>
  <div class="dc-icon-picker-panel" role="dialog" aria-modal="true">
    <div class="dc-icon-picker-header">
      <div style="display:flex;align-items:center;gap:8px;">
        <strong>{{ entry_icon }}</strong>
        <input id="dc-icon-picker-search" class="form-control dc-icon-picker-search" placeholder="{{ entry_search_icons|default('Search icons...') }}" />
      </div>
      <div>
        <button id="dc-icon-picker-close" class="btn btn-default">{{ button_close|default('Close') }}</button>
      </div>
    </div>
    <div id="dc-icon-picker-grid" class="dc-icon-picker-grid">
      {% for icon_option in icon_options %}
      <button type="button" class="dc-icon-option" data-icon="{{ icon_option }}">
        <i data-lucide="{{ icon_option }}"></i>
      </button>
      {% endfor %}
    </div>
  </div>
</div>

<script type="text/javascript">
var feature_row = {{ feature_row }};

function renderLucideIcons() {
  if (window.lucide && typeof window.lucide.createIcons === 'function') {
    window.lucide.createIcons();
  }
}

// Icon picker modal
var __dc_icon_picker_target = null;
var __dc_icon_picker_preview = null;
var __dc_icon_picker_label = null;

$(document).on('click', '.dc-icon-picker-button', function(e) {
  e.preventDefault();
  var $btn = $(this);
  var target = $btn.data('target');
  __dc_icon_picker_target = $(target);
  __dc_icon_picker_preview = $btn.find('i[data-lucide]');
  __dc_icon_picker_label = $btn.find('.dc-icon-label');
  $('#dc-icon-picker-modal').removeClass('hidden').show();
  $('#dc-icon-picker-search').val('');
  $('#dc-icon-picker-grid button').show();
});

$(document).on('click', '#dc-icon-picker-close, #dc-icon-picker-modal .dc-icon-picker-backdrop', function() {
  $('#dc-icon-picker-modal').hide().addClass('hidden');
});

$(document).on('click', '#dc-icon-picker-grid button.dc-icon-option', function(e) {
  var icon = $(this).data('icon');
  if (__dc_icon_picker_target && __dc_icon_picker_target.length) {
    __dc_icon_picker_target.val(icon);
  }
  if (__dc_icon_picker_preview && __dc_icon_picker_preview.length) {
    __dc_icon_picker_preview.attr('data-lucide', icon);
  }
  if (__dc_icon_picker_label && __dc_icon_picker_label.length) {
    __dc_icon_picker_label.text(icon);
  }
  if (__dc_icon_picker_target && __dc_icon_picker_target.attr('id')) {
    var btn = $('[data-target="#' + __dc_icon_picker_target.attr('id') + '"]');
    if (btn.length) {
      btn.attr('title', icon);
      btn.find('i[data-lucide]').attr('data-lucide', icon);
    }
  }
  renderLucideIcons();
  $('#dc-icon-picker-modal').hide().addClass('hidden');
});

$(document).on('input', '#dc-icon-picker-search', function() {
  var q = $(this).val().toLowerCase().trim();
  if (q === '') {
    $('#dc-icon-picker-grid button').show();
    return;
  }
  $('#dc-icon-picker-grid button').each(function() {
    var name = $(this).data('icon') || '';
    if (name.indexOf(q) !== -1) $(this).show(); else $(this).hide();
  });
});

$('#button-add-feature').on('click', function() {
  var html = '';
  html += '<tr id="feature-row-' + feature_row + '">';
  html += '  <td>';
  html += '    <input type="hidden" name="features[' + feature_row + '][icon]" id="feature-icon-' + feature_row + '" value="truck" />';
  html += '    <button type="button" class="dc-icon-picker-btn dc-icon-picker-button" data-target="#feature-icon-' + feature_row + '" title="truck">';
  html += '      <i data-lucide="truck" class="dc-icon-sm"></i>';
  html += '      <span class="dc-icon-label">truck</span>';
  html += '    </button>';
  html += '  </td>';

  html += '  <td>';
  html += '    <ul class="nav nav-tabs" role="tablist" style="margin-bottom: 10px;">';
  {% for language in languages %}
  html += '      <li{% if loop.first %} class="active"{% endif %}><a href="#feature-' + feature_row + '-lang-{{ language.language_id }}" data-toggle="tab"><span class="lang-code">{{ language.code|split('-')|first|upper }}</span> {{ language.name }}</a></li>';
  {% endfor %}
  html += '    </ul>';

  html += '    <div class="tab-content">';
  {% for language in languages %}
  html += '      <div class="tab-pane{% if loop.first %} active{% endif %}" id="feature-' + feature_row + '-lang-{{ language.language_id }}">';
  html += '        <div class="form-group" style="margin-left: 0; margin-right: 0;">';
  html += '          <label class="control-label">{{ entry_title }}</label>';
  html += '          <input type="text" name="features[' + feature_row + '][title][{{ language.language_id }}]" value="" class="form-control" />';
  html += '        </div>';
  html += '        <div class="form-group" style="margin-left: 0; margin-right: 0; margin-bottom: 0;">';
  html += '          <label class="control-label">{{ entry_text }}</label>';
  html += '          <textarea name="features[' + feature_row + '][text][{{ language.language_id }}]" rows="3" class="form-control"></textarea>';
  html += '        </div>';
  html += '      </div>';
  {% endfor %}
  html += '    </div>';
  html += '  </td>';

  html += '  <td><input type="number" name="features[' + feature_row + '][sort_order]" value="' + feature_row + '" class="form-control" /></td>';
  html += '  <td class="text-center"><button type="button" onclick="$(\'#feature-row-' + feature_row + '\').remove();" class="btn btn-danger" title="{{ button_remove }}"><i class="fa fa-trash"></i></button></td>';
  html += '</tr>';

  $('#features-table tbody').append(html);
  renderLucideIcons();
  feature_row++;
});

$(function() {
  renderLucideIcons();
});
</script>

{{ footer }}
