<div class="tile tile-warning">
  <div class="tile-heading">{{ heading_title }}<small class="tile-subtitle" style="display:block;font-size:12px;color:#6d7b92;margin-top:2px;font-weight:400;">{{ text_online_subtitle }}</small></div>
  <div class="tile-body"><i class="fa fa-users"></i>
    <div class="tile-body-right">
      <h2 class="tile-total">{{ total }}</h2>
    </div>
  </div>
  <div class="tile-footer"><a href="{{ online }}">{{ text_view }}</a></div>
</div>
