<div class="panel panel-default">
  <div class="panel-heading">
    <div class="panel-heading__icon"><i class="fa fa-line-chart"></i></div>
    <div>
      <h3 class="panel-title">{{ heading_title }}</h3>
      <div class="panel-heading__subtitle">{{ text_chart_subtitle }}</div>
    </div>
    <div class="pull-right">
      <select class="tile-period-select" id="chart-range">
        <option value="day">{{ text_day }}</option>
        <option value="week">{{ text_week }}</option>
        <option value="month" selected>{{ text_month }}</option>
        <option value="year">{{ text_year }}</option>
      </select>
    </div>
  </div>
  <div class="panel-body chart-panel-body">
    <canvas id="chart-sale"></canvas>
  </div>
</div>
<script>
(function() {
  var ctx = document.getElementById('chart-sale').getContext('2d');
  var chart = null;

  var labels = {
    completed: {{ text_completed|json_encode|raw }},
    pending: {{ text_pending|json_encode|raw }},
    total: {{ text_total|json_encode|raw }},
    revenue: {{ text_revenue|json_encode|raw }}
  };

  var key = 'dashboard_chart_period';
  var $sel = $('#chart-range');
  var saved = localStorage.getItem(key) || 'month';
  $sel.val(saved);

  function loadChart(range) {
    localStorage.setItem(key, range);
    $.getJSON('index.php?route=extension/dashboard/chart/chart&user_token={{ user_token }}&range=' + range, function(json) {
      if (chart) {
        chart.destroy();
      }

      var revenueGradient = ctx.createLinearGradient(0, 0, 0, 280);
      revenueGradient.addColorStop(0, 'rgba(59, 130, 246, 0.15)');
      revenueGradient.addColorStop(1, 'rgba(59, 130, 246, 0.01)');

      chart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: json.labels,
          datasets: [
            {
              label: labels.completed,
              data: json.completed,
              backgroundColor: '#22c55e',
              borderRadius: 4,
              borderSkipped: false,
              yAxisID: 'y',
              order: 3
            },
            {
              label: labels.pending,
              data: json.pending,
              backgroundColor: '#f59e0b',
              borderRadius: 4,
              borderSkipped: false,
              yAxisID: 'y',
              order: 4
            },
            {
              label: labels.total,
              data: json.total,
              type: 'line',
              borderColor: '#8b5cf6',
              backgroundColor: 'transparent',
              borderWidth: 2,
              borderDash: [6, 3],
              tension: 0.4,
              pointRadius: 0,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#8b5cf6',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2,
              yAxisID: 'y',
              order: 1
            },
            {
              label: labels.revenue,
              data: json.revenue,
              type: 'line',
              borderColor: '#3b82f6',
              backgroundColor: revenueGradient,
              fill: true,
              tension: 0.4,
              borderWidth: 2,
              pointRadius: 0,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#3b82f6',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2,
              yAxisID: 'y1',
              order: 2
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            mode: 'index',
            intersect: false
          },
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                usePointStyle: true,
                pointStyle: 'circle',
                padding: 20,
                font: { size: 12, family: 'Inter' }
              }
            },
            tooltip: {
              backgroundColor: 'rgba(31, 41, 55, 0.9)',
              titleFont: { size: 12, family: 'Inter', weight: '600' },
              bodyFont: { size: 12, family: 'Inter' },
              padding: 12,
              cornerRadius: 8,
              displayColors: true,
              boxPadding: 4,
              callbacks: {
                label: function(context) {
                  var label = context.dataset.label || '';
                  var value = context.parsed.y;
                  if (label === labels.revenue) {
                    return label + ': $' + value.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});
                  }
                  return label + ': ' + value;
                }
              }
            }
          },
          scales: {
            x: {
              stacked: true,
              grid: {
                color: 'rgba(0, 0, 0, 0.04)',
                drawBorder: false
              },
              ticks: {
                font: { size: 11, family: 'Inter' },
                color: '#9ca3af',
                maxRotation: 0
              }
            },
            y: {
              stacked: true,
              type: 'linear',
              position: 'left',
              title: {
                display: true,
                text: labels.total,
                font: { size: 11, family: 'Inter', weight: '500' },
                color: '#374151'
              },
              grid: {
                color: 'rgba(0, 0, 0, 0.04)',
                drawBorder: false
              },
              ticks: {
                font: { size: 11, family: 'Inter' },
                color: '#9ca3af',
                stepSize: 1
              }
            },
            y1: {
              type: 'linear',
              position: 'right',
              title: {
                display: true,
                text: labels.revenue + ' ($)',
                font: { size: 11, family: 'Inter', weight: '500' },
                color: '#3b82f6'
              },
              grid: {
                drawOnChartArea: false
              },
              ticks: {
                font: { size: 11, family: 'Inter' },
                color: '#9ca3af',
                callback: function(value) {
                  if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                  if (value >= 1000) return '$' + (value / 1000).toFixed(1) + 'K';
                  return '$' + value;
                }
              }
            }
          }
        }
      });
    });
  }

  $('#chart-range').on('change', function() {
    loadChart($(this).val());
  });

  loadChart(saved);
})();
</script>
