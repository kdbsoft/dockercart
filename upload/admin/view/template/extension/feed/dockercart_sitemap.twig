{{ header }}{{ column_left }}
<div id="content">
  <link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
  <style>
    .dcx-sitemap-url { margin-top:6px; font-size:12px; color:#54627a; }
    .dcx-sitemap-url code { display:inline-block; margin-left:6px; }
  </style>
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-dockercart-sitemap" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <button id="button-generate" type="button" data-toggle="tooltip" title="{{ button_generate }}" class="btn btn-success"><i class="fa fa-refresh"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <ul class="nav nav-tabs dcx-profile-tabs" id="sitemap-tabs" role="tablist">
      <li class="active"><a href="#sitemap-tab-general" class="js-sitemap-tab" data-tab="sitemap-tab-general" data-title="{{ text_tab_general }}" data-subtitle="{{ text_tab_general_subtitle }}" data-icon="fa-sliders"><i class="fa fa-sliders"></i> {{ text_tab_general }}</a></li>
      <li><a href="#sitemap-tab-about" class="js-sitemap-tab" data-tab="sitemap-tab-about" data-title="{{ text_tab_about }}" data-subtitle="{{ text_tab_about_subtitle }}" data-icon="fa-info-circle"><i class="fa fa-info-circle"></i> {{ text_tab_about }}</a></li>
    </ul>

    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i id="sitemap-tab-icon" class="fa fa-sliders"></i></div>
          <div>
            <h3 class="dcx-panel-title" id="sitemap-tab-title">{{ text_tab_general }}</h3>
            <div class="dcx-panel-subtitle" id="sitemap-tab-subtitle">{{ text_tab_general_subtitle }}</div>
          </div>
        </div>
        <div class="dcx-panel-body">
          <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-dockercart-sitemap" class="form-horizontal dcx-form">

          <div id="sitemap-tab-general" class="dcx-tab-pane active">
            <div class="dcx-section">
              <h4>{{ text_section_module_settings }}</h4>

              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-9">
                  <select name="dockercart_sitemap_status" id="input-status" class="form-control">
                    {% if dockercart_sitemap_status %}
                    <option value="1" selected="selected">{{ text_enabled }}</option>
                    <option value="0">{{ text_disabled }}</option>
                    {% else %}
                    <option value="1">{{ text_enabled }}</option>
                    <option value="0" selected="selected">{{ text_disabled }}</option>
                    {% endif %}
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">{{ text_sitemap_url }}</label>
                <div class="col-sm-9">
                  <div class="alert alert-info" style="margin-bottom:0;">
                    <i class="fa fa-info-circle"></i> <a href="{{ sitemap_url }}" target="_blank">{{ sitemap_url }}</a>
                    {% if last_generated %}
                    <div class="dcx-sitemap-url">Last generated: <strong id="sitemap-last-generated">{{ last_generated }}</strong> — <span id="sitemap-file-count">{{ sitemap_file_count }}</span> files</div>
                    {% else %}
                    <div class="dcx-sitemap-url">Last generated: <strong id="sitemap-last-generated">Never</strong></div>
                    {% endif %}
                  </div>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-schedule">{{ entry_schedule }}</label>
                <div class="col-sm-9">
                  <select name="dockercart_sitemap_schedule" id="input-schedule" class="form-control">
                    {% for value, label in schedule_options %}
                      <option value="{{ value }}" {% if value == dockercart_sitemap_schedule %}selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                  </select>
                  <p class="help-block">{{ help_schedule }}</p>
                </div>
              </div>
            </div>

            <div class="dcx-section">
              <h4>{{ text_section_content_types }}</h4>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_products }}">{{ entry_products }}</span>
            </label>
            <div class="col-sm-9">
              <label class="radio-inline">
                {% if dockercart_sitemap_products %}
                <input type="radio" name="dockercart_sitemap_products" value="1" checked="checked" />
                {{ text_enabled }}
                {% else %}
                <input type="radio" name="dockercart_sitemap_products" value="1" />
                {{ text_enabled }}
                {% endif %}
              </label>
              <label class="radio-inline">
                {% if dockercart_sitemap_products %}
                <input type="radio" name="dockercart_sitemap_products" value="0" />
                {{ text_disabled }}
                {% else %}
                <input type="radio" name="dockercart_sitemap_products" value="0" checked="checked" />
                {{ text_disabled }}
                {% endif %}
              </label>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_priority }}">{{ entry_product_priority }}</span>
            </label>
            <div class="col-sm-9">
              <input type="text" name="dockercart_sitemap_product_priority" value="{{ dockercart_sitemap_product_priority }}" placeholder="0.8" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_changefreq }}">{{ entry_product_changefreq }}</span>
            </label>
            <div class="col-sm-9">
              <select name="dockercart_sitemap_product_changefreq" class="form-control">
                {% for value, text in changefreq_options %}
                  {% if value == dockercart_sitemap_product_changefreq %}
                    <option value="{{ value }}" selected="selected">{{ text }}</option>
                  {% else %}
                    <option value="{{ value }}">{{ text }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_categories }}">{{ entry_categories }}</span>
            </label>
            <div class="col-sm-9">
              <label class="radio-inline">
                {% if dockercart_sitemap_categories %}
                <input type="radio" name="dockercart_sitemap_categories" value="1" checked="checked" />
                {{ text_enabled }}
                {% else %}
                <input type="radio" name="dockercart_sitemap_categories" value="1" />
                {{ text_enabled }}
                {% endif %}
              </label>
              <label class="radio-inline">
                {% if dockercart_sitemap_categories %}
                <input type="radio" name="dockercart_sitemap_categories" value="0" />
                {{ text_disabled }}
                {% else %}
                <input type="radio" name="dockercart_sitemap_categories" value="0" checked="checked" />
                {{ text_disabled }}
                {% endif %}
              </label>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_priority }}">{{ entry_category_priority }}</span>
            </label>
            <div class="col-sm-9">
              <input type="text" name="dockercart_sitemap_category_priority" value="{{ dockercart_sitemap_category_priority }}" placeholder="0.9" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_changefreq }}">{{ entry_category_changefreq }}</span>
            </label>
            <div class="col-sm-9">
              <select name="dockercart_sitemap_category_changefreq" class="form-control">
                {% for value, text in changefreq_options %}
                  {% if value == dockercart_sitemap_category_changefreq %}
                    <option value="{{ value }}" selected="selected">{{ text }}</option>
                  {% else %}
                    <option value="{{ value }}">{{ text }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_manufacturers }}">{{ entry_manufacturers }}</span>
            </label>
            <div class="col-sm-9">
              <label class="radio-inline">
                {% if dockercart_sitemap_manufacturers %}
                <input type="radio" name="dockercart_sitemap_manufacturers" value="1" checked="checked" />
                {{ text_enabled }}
                {% else %}
                <input type="radio" name="dockercart_sitemap_manufacturers" value="1" />
                {{ text_enabled }}
                {% endif %}
              </label>
              <label class="radio-inline">
                {% if dockercart_sitemap_manufacturers %}
                <input type="radio" name="dockercart_sitemap_manufacturers" value="0" />
                {{ text_disabled }}
                {% else %}
                <input type="radio" name="dockercart_sitemap_manufacturers" value="0" checked="checked" />
                {{ text_disabled }}
                {% endif %}
              </label>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_priority }}">{{ entry_manufacturer_priority }}</span>
            </label>
            <div class="col-sm-9">
              <input type="text" name="dockercart_sitemap_manufacturer_priority" value="{{ dockercart_sitemap_manufacturer_priority }}" placeholder="0.7" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_changefreq }}">{{ entry_manufacturer_changefreq }}</span>
            </label>
            <div class="col-sm-9">
              <select name="dockercart_sitemap_manufacturer_changefreq" class="form-control">
                {% for value, text in changefreq_options %}
                  {% if value == dockercart_sitemap_manufacturer_changefreq %}
                    <option value="{{ value }}" selected="selected">{{ text }}</option>
                  {% else %}
                    <option value="{{ value }}">{{ text }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_information }}">{{ entry_information }}</span>
            </label>
            <div class="col-sm-9">
              <label class="radio-inline">
                {% if dockercart_sitemap_information %}
                <input type="radio" name="dockercart_sitemap_information" value="1" checked="checked" />
                {{ text_enabled }}
                {% else %}
                <input type="radio" name="dockercart_sitemap_information" value="1" />
                {{ text_enabled }}
                {% endif %}
              </label>
              <label class="radio-inline">
                {% if dockercart_sitemap_information %}
                <input type="radio" name="dockercart_sitemap_information" value="0" />
                {{ text_disabled }}
                {% else %}
                <input type="radio" name="dockercart_sitemap_information" value="0" checked="checked" />
                {{ text_disabled }}
                {% endif %}
              </label>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_priority }}">{{ entry_information_priority }}</span>
            </label>
            <div class="col-sm-9">
              <input type="text" name="dockercart_sitemap_information_priority" value="{{ dockercart_sitemap_information_priority }}" placeholder="0.5" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_changefreq }}">{{ entry_information_changefreq }}</span>
            </label>
            <div class="col-sm-9">
              <select name="dockercart_sitemap_information_changefreq" class="form-control">
                {% for value, text in changefreq_options %}
                  {% if value == dockercart_sitemap_information_changefreq %}
                    <option value="{{ value }}" selected="selected">{{ text }}</option>
                  {% else %}
                    <option value="{{ value }}">{{ text }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

            </div>

            <div class="dcx-section">
              <h4>{{ text_section_limits }}</h4>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_max_urls }}">{{ entry_max_urls }}</span>
            </label>
            <div class="col-sm-9">
              <input type="text" name="dockercart_sitemap_max_urls" value="{{ dockercart_sitemap_max_urls }}" placeholder="50000" class="form-control" />
              <p class="help-block">{{ help_max_urls }}</p>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_max_file_size_mb }}">{{ entry_max_file_size_mb }}</span>
            </label>
            <div class="col-sm-9">
              <input type="text" name="dockercart_sitemap_max_file_size_mb" value="{{ dockercart_sitemap_max_file_size_mb }}" placeholder="50" class="form-control" />
              <p class="help-block">{{ help_max_file_size_mb }}</p>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-3 control-label">
              <span data-toggle="tooltip" title="{{ help_create_gzip }}">{{ entry_create_gzip }}</span>
            </label>
            <div class="col-sm-9">
              <label class="checkbox-inline">
                <input type="hidden" name="dockercart_sitemap_create_gzip" value="0" />
                <input type="checkbox" name="dockercart_sitemap_create_gzip" value="1" {% if dockercart_sitemap_create_gzip %}checked="checked"{% endif %} /> {{ entry_create_gzip }}
              </label>
              <p class="help-block">{{ help_create_gzip }}</p>
            </div>
          </div>

            </div>

          </div>

          <div id="sitemap-tab-about" class="dcx-tab-pane">
            <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
              <h4>{{ text_tab_about }}</h4>
              <table class="table table-bordered dcx-table">
                 <tr>
                  <td><strong>{{ text_developer }}</strong></td>
                  <td>{{ text_developer_name }}</td>
                </tr>
                <tr>
                  <td><strong>{{ text_contact }}</strong></td>
                  <td><a href="mailto:support@dockercart.net">support@dockercart.net</a></td>
                </tr>
              </table>
            </div>
          </div>

        </form>
        </div>
      </div>
    </div>
  </div>
</div>
{{ footer }}

<script>
function updateSitemapPanelHeader(tabLink) {
  var $tab = $(tabLink);
  var title = $tab.data('title') || '{{ text_tab_general }}';
  var subtitle = $tab.data('subtitle') || '{{ text_tab_general_subtitle }}';
  var icon = String($tab.data('icon') || 'fa-sliders').replace(/[^a-z0-9\-]/gi, '');

  $('#sitemap-tab-title').text(title);
  $('#sitemap-tab-subtitle').text(subtitle);
  $('#sitemap-tab-icon').attr('class', 'fa ' + icon);
}

$(document).on('click', '.js-sitemap-tab', function(e) {
  e.preventDefault();
  var tabId = $(this).data('tab');
  if (!tabId) return;

  $('#sitemap-tabs > li').removeClass('active');
  $(this).closest('li').addClass('active');

  $('#sitemap-tab-general, #sitemap-tab-about').removeClass('active');
  $('#' + tabId).addClass('active');

  updateSitemapPanelHeader(this);
});

updateSitemapPanelHeader($('#sitemap-tabs > li.active a.js-sitemap-tab'));
</script>

<script>
/* <![CDATA[ */
(() => {
  const url = '{{ generate_ajax }}';
  const btn = document.getElementById('button-generate');
  if (!btn) return;

  const container = document.querySelector('.container-fluid');
  const lastGeneratedEl = document.getElementById('sitemap-last-generated');
  const fileCountEl = document.getElementById('sitemap-file-count');

  const createAlert = (type, message) => {
    const safe = message || '';
    return `<div class="alert alert-${type} alert-dismissible"><i class="fa ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i> ${safe}<button type="button" class="close" data-dismiss="alert">&times;</button></div>`;
  };

  const setBusy = (isBusy) => {
    btn.disabled = isBusy;
    const icon = btn.querySelector('i');
    if (icon) {
      if (isBusy) {
        icon.classList.add('fa-spin', 'fa-spinner');
      } else {
        icon.classList.remove('fa-spin', 'fa-spinner');
      }
    }
  };

  btn.addEventListener('click', async (ev) => {
    ev.preventDefault();
    setBusy(true);

    try {
      const resp = await fetch(url.replace(/&amp;/g, '&'), {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'application/json'
        }
      });

      if (!resp.ok) {
        const text = await resp.text();
        const html = createAlert('danger', `Server returned ${resp.status}: ${text}`);
        if (container) container.insertAdjacentHTML('afterbegin', html);
        return;
      }

      const json = await resp.json();

      if (json.error) {
        if (container) container.insertAdjacentHTML('afterbegin', createAlert('danger', json.error));
      } else if (json.success) {
        if (container) container.insertAdjacentHTML('afterbegin', createAlert('success', json.success));
        if (json.last_generated && lastGeneratedEl) lastGeneratedEl.textContent = json.last_generated;
        if (typeof json.file_count !== 'undefined' && fileCountEl) fileCountEl.textContent = json.file_count;
      }
    } catch (err) {
      if (container) container.insertAdjacentHTML('afterbegin', createAlert('danger', 'Unexpected error while generating sitemap.'));
      // Keep the real error in console for debugging
      // eslint-disable-next-line no-console
      console.error('Sitemap generation error', err);
    } finally {
      setBusy(false);
    }
  });
})();
/* ]]> */
</script>
