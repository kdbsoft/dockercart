<div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
  <h3 class="text-sm font-bold uppercase tracking-widest text-gray-500 mb-3">{{ heading_title }}</h3>
  <p class="text-xs text-gray-500 mb-4">{{ text_shipping }}</p>
  <div class="space-y-3">
    <div>
      <select name="country_id" id="input-country" class="w-full h-11 px-4 bg-gray-50 border border-gray-300 rounded-lg text-sm text-text-primary focus:border-primary focus:bg-white transition">
        <option value="">{{ text_select|default(' — Please Select — ') }}</option>
        {% for country in countries %}
        <option value="{{ country.country_id }}"{% if country.country_id == country_id %} selected{% endif %}>{{ country.name }}</option>
        {% endfor %}
      </select>
    </div>
    <div>
      <select name="zone_id" id="input-zone" class="w-full h-11 px-4 bg-gray-50 border border-gray-300 rounded-lg text-sm text-text-primary focus:border-primary focus:bg-white transition">
      </select>
    </div>
    <div>
      <input type="text" name="postcode" value="{{ postcode }}" placeholder="{{ entry_postcode }}" id="input-postcode"
        class="w-full h-11 px-4 bg-gray-50 border border-gray-300 rounded-lg text-sm text-text-primary placeholder-gray-400 focus:border-primary focus:bg-white transition">
    </div>
    <button type="button" id="button-quote" class="w-full h-11 bg-gray-100 hover:bg-gray-200 text-text-primary font-medium rounded-lg transition text-sm">
      {{ button_quote }}
    </button>
  </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var quoteBtn = document.getElementById('button-quote');
  if (!quoteBtn) return;
  quoteBtn.addEventListener('click', function() {
    var country = document.querySelector('select[name="country_id"]');
    var zone = document.querySelector('select[name="zone_id"]');
    var postcode = document.querySelector('input[name="postcode"]');
    fetch('index.php?route=extension/total/shipping/quote', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: 'country_id=' + encodeURIComponent(country ? country.value : '') + '&zone_id=' + encodeURIComponent(zone ? zone.value : '') + '&postcode=' + encodeURIComponent(postcode ? postcode.value : '')
    })
    .then(function(r) { return r.json(); })
    .then(function(json) {
      if (json.error) {
        alert(json.error.warning || json.error.country || json.error.zone || json.error.postcode || 'Error');
      }
      if (json.shipping_method) {
        var html = '';
        for (var key in json.shipping_method) {
          html += '<p class="text-xs font-semibold text-gray-700 mt-3 mb-1">' + json.shipping_method[key].title + '</p>';
          for (var qkey in json.shipping_method[key].quote) {
            html += '<label class="flex items-center gap-2 py-1"><input type="radio" name="shipping_method" value="' + json.shipping_method[key].quote[qkey].code + '" class="accent-primary"> <span class="text-sm text-gray-600">' + json.shipping_method[key].quote[qkey].title + ' - ' + json.shipping_method[key].quote[qkey].text + '</span></label>';
          }
        }
        var container = document.createElement('div');
        container.className = 'mt-4 space-y-1';
        container.innerHTML = html;
        var applyBtn = document.createElement('button');
        applyBtn.type = 'button';
        applyBtn.id = 'button-shipping';
        applyBtn.className = 'mt-3 w-full h-11 bg-gray-100 hover:bg-gray-200 text-text-primary font-medium rounded-lg transition text-sm';
        applyBtn.textContent = '{{ button_shipping }}';
        applyBtn.addEventListener('click', function() {
          var selected = document.querySelector('input[name="shipping_method"]:checked');
          if (!selected) return;
          fetch('index.php?route=extension/total/shipping/shipping', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'shipping_method=' + encodeURIComponent(selected.value)
          })
          .then(function(r) { return r.json(); })
          .then(function(json) {
            if (json.error) alert(json.error.warning || json.error);
            if (json.redirect) window.location.href = json.redirect;
          });
        });
        container.appendChild(applyBtn);
        var existing = document.querySelector('.shipping-methods');
        if (existing) existing.remove();
        container.className += ' shipping-methods';
        quoteBtn.parentNode.appendChild(container);
      }
    });
  });
  var countrySelect = document.querySelector('select[name="country_id"]');
  if (countrySelect) {
    countrySelect.addEventListener('change', function() {
      var countryId = this.value;
      if (!countryId) return;
      fetch('index.php?route=extension/total/shipping/country&country_id=' + countryId)
        .then(function(r) { return r.json(); })
        .then(function(json) {
          var zoneSelect = document.querySelector('select[name="zone_id"]');
          if (!zoneSelect) return;
          zoneSelect.innerHTML = '<option value="">{{ text_select|default(' — Please Select — ') }}</option>';
          if (json.zone && json.zone.length) {
            json.zone.forEach(function(z) {
              var opt = document.createElement('option');
              opt.value = z.zone_id;
              opt.textContent = z.name;
              zoneSelect.appendChild(opt);
            });
          }
        });
    });
  }
});
</script>
