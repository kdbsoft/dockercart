<style>
  /* Constrain banner blocks to module-configured dimensions */
  #banner-{{ module }}.banner-layout--grid .banner-slide { {% if banner_width > 0 %}max-width: {{ banner_width }}px;{% endif %} }
  /* Center slides and prevent small images from upscaling; center image inside the slide */
  :root { --banner-gap: 1rem; }
  .banner-slides { display: flex; gap: var(--banner-gap); flex-wrap: wrap; justify-content: center; }
  .banner-slide { position: relative; overflow: hidden; border-radius: 24px; flex: 1 1 auto; min-width: 0; }
  .banner-slide__media { position: relative; display:flex; align-items:center; justify-content:center; }
  {% if banner_height %}
    #banner-{{ module }} .banner-slide__media img { width: 100%; height: {{ banner_height }}px; object-fit: cover; }
  #banner-{{ module }} .banner-slide__media iframe,
  #banner-{{ module }} .banner-slide__media video { width: 100%; height: {{ banner_height }}px; object-fit: cover; }

  {% else %}
  #banner-{{ module }} .banner-slide__media img { max-width:100%; width:auto; height:auto; }
  #banner-{{ module }} .banner-slide__media iframe,
  #banner-{{ module }} .banner-slide__media video { max-width:100%; width:auto; height:auto; }
  {% endif %}
  .banner-slide__link { display: block; text-decoration: none; color: inherit; }
  .banner-slide__overlay { position: absolute; inset: 0; display: flex; align-items: center; pointer-events: none; background: linear-gradient(to right, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 35%, rgba(0,0,0,0.1) 65%, transparent 100%); }
  .banner-slide__overlay--left { justify-content: flex-start; }
  .banner-slide__overlay--center { justify-content: center; }
  .banner-slide__overlay--right { justify-content: flex-end; }
  .banner-slide__content { pointer-events: auto; color: #fff; text-align: left; padding: 1.75rem 1rem 1rem 2rem; max-width: 65%; }
  .banner-slide__overlay--center .banner-slide__content { text-align: center; }
  .banner-slide__overlay--right .banner-slide__content { text-align: right; }
  .banner-slide__title { font-size: 1.75rem; font-weight: 800; line-height: 1.2; margin: 0 0 .75rem; }
  .banner-slide__subtitle { margin: 0 0 .875rem; font-size: 1.125rem; line-height: 1.5; opacity: .95; }
  .banner-slide__badge { display: inline-block; padding: .25rem .5rem; font-weight:700; border-radius: .5rem; margin-bottom: .75rem; background: var(--accent, #2563eb); }
  .banner-slide__btns { margin-top: 0; display:flex; gap:.75rem; flex-wrap:wrap; }
  .banner-slide__overlay--left .banner-slide__btns { justify-content: flex-start; }
  .banner-slide__overlay--center .banner-slide__btns { justify-content: center; }
  .banner-slide__overlay--right .banner-slide__btns { justify-content: flex-end; }
  .banner-slide__btn { display:inline-flex; align-items:center; justify-content:center; gap:.5px; text-decoration:none; font-weight:700; border-radius: .75rem; padding: .5rem .85rem; font-size: .95rem; transition: transform .12s ease, box-shadow .12s ease, opacity .12s ease; }
  .banner-slide__btn--primary { background: var(--accent, #2563eb); color: #fff; border: 1px solid var(--accent, #2563eb); box-shadow: 0 6px 18px rgba(2,6,23,0.12); }
  .banner-slide__btn--primary:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(2,6,23,0.18); filter: brightness(0.92); }
  .banner-slide__btn--secondary { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.18); }
  .banner-slide__btn--secondary:hover { background: rgba(255,255,255,0.18); transform: translateY(-2px); }
  /* If template inlines accent color on primary, keep text white and add subtle shadow for contrast */
  .banner-slide__btn[style*="background-color"] { color: #fff; }
  /* Vertical banners (portrait): more compact text */
  .banner--vertical .banner-slide__title { font-size: 1.5rem; }
  .banner--vertical .banner-slide__subtitle { font-size: 1rem; }
  .banner--vertical .banner-slide__content { max-width: 80%; padding-left: 1.5rem; }
  /* Stack layout: banners in a column, constrained to configured width */
  #banner-{{ module }}.banner-layout--stack { {% if banner_width %} max-width: {{ banner_width }}px; margin-left: auto; margin-right: auto; {% endif %} }
  .banner-layout--stack .banner-slides { flex-direction: column; flex-wrap: nowrap; }
  .banner-layout--stack .banner-slide { max-width: none !important; width: 100%; }
  /* Full-width mode: remove max-width constraint, center content */
  #banner-{{ module }}.banner-slider--full-width.banner-layout--grid .banner-slide { max-width: none; }
  .banner-slider--full-width { border-radius: 0; }
  .banner-slider--full-width .banner-slide { border-radius: 0; }
  .banner-slider--full-width .banner-slide__content { max-width: 1280px; padding-right: 2rem; }
  /* Mobile: horizontal carousel with swipe */
  @media (max-width: 767px) {
    .banner-slider { padding: 0; overflow: hidden; }
    .banner-slides {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 0;
    }
    .banner-slides::-webkit-scrollbar { display: none; }
    .banner-slide {
      min-width: 100%;
      max-width: 100%;
      flex-shrink: 0;
      scroll-snap-align: start;
      border-radius: 0;
      box-shadow: none;
    }
    .banner-slide__media img,
    .banner-slide__media iframe,
    .banner-slide__media video { width: 100%; height: auto; object-fit: cover; }
    .banner-slide__overlay { background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 50%, transparent 100%); }
    .banner-slide__content { max-width: 100%; padding: 1.25rem 1rem; }
    .banner-slide__title { font-size: 1.375rem; }
    .banner-slide__subtitle { font-size: 1rem; }
    .banner--vertical .banner-slide__title { font-size: 1.25rem; }
    .banner--vertical .banner-slide__subtitle { font-size: .9375rem; }
    .banner-dots { display: flex !important; position: relative; z-index: 2; }
    .banner-nav { display: none !important; }
    #banner-{{ module }}.banner-layout--stack { max-width: none !important; margin: 0; }
  }
</style>

{% set is_vertical = banner_height > banner_width %}
<div class="banner-slider{% if is_vertical %} banner--vertical{% else %} banner--horizontal{% endif %} banner-layout--{{ banner_layout|default('grid') }}{% if full_width %} banner-slider--full-width{% endif %}" id="banner-{{ module }}" data-autoplay="3500">
  <div class="banner-slides{% if banner_layout == 'stack' %} banner-slides--stack{% endif %}">
    {% for banner in banners %}
      <div class="banner-slide{% if loop.first %} active{% endif %}" style="--stack-index: {{ loop.index }};">
      <div class="banner-slide__media">
      {% if banner.video_type == 'youtube' and banner.video_url %}
      {% if banner.link %}<a href="{{ banner.link }}" class="banner-slide__link">{% endif %}
      <iframe src="{{ banner.video_url }}"
        class="banner-slide__iframe"
        frameborder="0" allow="autoplay; fullscreen" allowfullscreen
        style="pointer-events:none; width:100%; height:{{ banner_height ? banner_height ~ 'px' : 'auto' }}; object-fit:cover;"></iframe>
      {% if banner.link %}</a>{% endif %}
      {% elseif banner.video_type == 'mp4' and banner.video_url %}
      {% if banner.link %}<a href="{{ banner.link }}" class="banner-slide__link">{% endif %}
      <video autoplay muted loop playsinline
        class="banner-slide__video"
        poster="{{ banner.image }}"
        style="width:100%; height:{{ banner_height ? banner_height ~ 'px' : 'auto' }}; object-fit:cover;">
        <source src="{{ banner.video_url }}" type="video/mp4">
      </video>
      {% if banner.link %}</a>{% endif %}
      {% elseif banner.image %}
      {% if banner.link %}<a href="{{ banner.link }}" class="banner-slide__link">{% endif %}
      {# Use portrait variant when available, otherwise fall back to the landscape image for portrait orientation #}
      {% set portrait_src = banner.image_portrait ? banner.image_portrait : banner.image %}
      <picture>
        <source media="(orientation: portrait)" srcset="{{ portrait_src }}" />
        <source media="(orientation: landscape)" srcset="{{ banner.image }}" />
        <img src="{{ banner.image }}" alt="{{ banner.title }}" loading="lazy" />
      </picture>
      {% if banner.link %}</a>{% endif %}
      {% endif %}

      {% if banner.title_html or banner.subtitle or banner.accent_text or banner.primary_btn_text %}
      <div class="banner-slide__overlay banner-slide__overlay--{{ banner.content_position ?: 'left' }}">
        <div class="banner-slide__content">
          {% if banner.accent_text %}
          {%- set badge_color = banner.accent_color ? banner.accent_color : '' -%}
          <span class="banner-slide__badge"{% if badge_color or banner.accent_color or banner.accent_bg %} style="{% if badge_color %}background-color: {{ badge_color }};{% endif %}{% if banner.accent_color %} --accent: {{ banner.accent_color }};{% endif %}{% if banner.accent_bg %} --accent-bg: {{ banner.accent_bg }};{% endif %} color: {{ banner.badge_text_color }};"{% endif %}>{{ banner.accent_text }}</span>
          {% endif %}
          {% if banner.title_html %}
          <h2 class="banner-slide__title">{{ banner.title_html|raw }}</h2>
          {% endif %}
          {% if banner.subtitle %}
          <p class="banner-slide__subtitle">{{ banner.subtitle }}</p>
          {% endif %}
          {% if banner.primary_btn_text %}
          <div class="banner-slide__btns">
            <span class="banner-slide__btn banner-slide__btn--primary"{% if banner.accent_color %} style="--accent: {{ banner.accent_color }}; color: {{ banner.badge_text_color }};"{% endif %}>{{ banner.primary_btn_text }}</span>
          </div>
          {% endif %}
        </div>
      </div>
      {% endif %}
      </div>

    </div>
    {% endfor %}
  </div>

  {% if banners|length > 1 %}
  <button class="banner-nav banner-prev" aria-label="Previous slide"></button>
  <button class="banner-nav banner-next" aria-label="Next slide"></button>

  <div class="banner-dots">
    {% for banner in banners %}
    <button class="banner-dot{% if loop.first %} active{% endif %}"
            data-slide="{{ loop.index0 }}"
            aria-label="Go to slide {{ loop.index }}"></button>
    {% endfor %}
  </div>
  {% endif %}
</div>

<script>
  (() => {
    const root = document.getElementById('banner-{{ module }}');
    if (!root) return;

    const slides = root.querySelector('.banner-slides');
    const items = [...root.querySelectorAll('.banner-slide')];
    const dots = [...root.querySelectorAll('.banner-dot')];
    const prevBtn = root.querySelector('.banner-prev');
    const nextBtn = root.querySelector('.banner-next');
    const total = items.length;
    const autoplayMs = parseInt(root.dataset.autoplay) || 0;

    let current = 0;
    let timer = null;

    const goTo = (index) => {
      current = (index + total) % total;
      slides.scrollTo({ left: items[current].offsetLeft, behavior: 'smooth' });
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    };

    const startAutoplay = () => {
      if (autoplayMs > 0 && total > 1) {
        timer = setInterval(() => goTo(current + 1), autoplayMs);
      }
    };

    const resetAutoplay = () => {
      clearInterval(timer);
      startAutoplay();
    };

    let startX = 0;
    let startY = 0;
    let swiping = false;

    slides.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      swiping = true;
    }, { passive: true });

    slides.addEventListener('touchend', (e) => {
      if (!swiping) return;
      swiping = false;
      const dx = e.changedTouches[0].clientX - startX;
      const dy = e.changedTouches[0].clientY - startY;
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
        goTo(dx < 0 ? current + 1 : current - 1);
        resetAutoplay();
      }
    }, { passive: true });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        goTo(Number(dot.dataset.slide));
        resetAutoplay();
      });
    });

    prevBtn?.addEventListener('click', () => { goTo(current - 1); resetAutoplay(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); resetAutoplay(); });

    root.setAttribute('tabindex', '0');
    root.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { goTo(current - 1); resetAutoplay(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); resetAutoplay(); }
    });

    startAutoplay();
  })();
</script>
