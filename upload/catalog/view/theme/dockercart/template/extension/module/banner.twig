<style>
  /* Constrain banner blocks to module-configured dimensions */
  {% if banner_width %}
  .banner-layout--grid .banner-slide { max-width: {{ banner_width }}px; }
  {% endif %}
  /* Center slides and prevent small images from upscaling; center image inside the slide */
  :root { --banner-gap: 1rem; }
  .banner-slides { display: flex; gap: var(--banner-gap); flex-wrap: wrap; justify-content: center; }
  .banner-slide { position: relative; overflow: hidden; border-radius: 24px; flex: 1 1 auto; min-width: 0; }
  .banner-slide__media { position: relative; display:flex; align-items:center; justify-content:center; }
  {% if banner_height %}
    .banner-slide__media img { width: 100%; height: {{ banner_height }}px; object-fit: cover; }
  .banner-slide__media iframe,
  .banner-slide__media video { width: 100%; height: {{ banner_height }}px; object-fit: cover; }

  {% else %}
  .banner-slide__media img { max-width:100%; width:auto; height:auto; }
  .banner-slide__media iframe,
  .banner-slide__media video { max-width:100%; width:auto; height:auto; }
  {% endif %}
  .banner-slide__overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: flex-start; pointer-events: none; background: linear-gradient(to right, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 35%, rgba(0,0,0,0.1) 65%, transparent 100%); }
  .banner-slide__content { pointer-events: auto; color: #fff; text-align: left; padding: 1.75rem 1rem 1rem 2rem; max-width: 65%; }
  .banner-slide__title { font-size: 1.75rem; font-weight: 800; line-height: 1.2; margin: 0 0 .75rem; }
  .banner-slide__subtitle { margin: 0 0 .875rem; font-size: 1.125rem; line-height: 1.5; opacity: .95; }
  .banner-slide__badge { display: inline-block; padding: .25rem .5rem; font-weight:700; border-radius: .5rem; margin-bottom: .75rem; background: var(--accent, #2563eb); }
  .banner-slide__btns { margin-top: 0; display:flex; gap:.75rem; justify-content: flex-start; flex-wrap:wrap; }
  .banner-slide__btn { display:inline-flex; align-items:center; justify-content:center; gap:.5px; text-decoration:none; font-weight:700; border-radius: .75rem; padding: .5rem .85rem; font-size: .95rem; transition: transform .12s ease, box-shadow .12s ease, opacity .12s ease; }
  .banner-slide__btn--primary { background: var(--accent, #2563eb); color: #fff; border: 1px solid var(--accent, #2563eb); box-shadow: 0 6px 18px rgba(2,6,23,0.12); }
  .banner-slide__btn--primary:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(2,6,23,0.18); filter: brightness(0.92); }
  .banner-slide__btn--secondary { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.18); }
  .banner-slide__btn--secondary:hover { background: rgba(255,255,255,0.18); transform: translateY(-2px); }
  /* If template inlines accent color on primary, keep text white and add subtle shadow for contrast */
  .banner-slide__btn[style*="background-color"] { color: #fff; }
  /* Vertical banners (portrait): more compact text */
  .banner--vertical .banner-slide__title { font-size: 1.5rem; }
  .banner--vertical .banner-slide__subtitle { font-size: 1rem; }
  .banner--vertical .banner-slide__content { max-width: 80%; padding-left: 1.5rem; }
  /* Stack layout: banners in a column, constrained to configured width */
  .banner-layout--stack { {% if banner_width %} max-width: {{ banner_width }}px; margin-left: auto; margin-right: auto; {% endif %} }
  .banner-layout--stack .banner-slides { flex-direction: column; flex-wrap: nowrap; }
  .banner-layout--stack .banner-slide { max-width: none !important; width: 100%; }
  /* Mobile: simple vertical stack of banners */
  @media (max-width: 767px) {
    /* keep a small page gutter so images don't touch the screen edges */
    .banner-slider { padding-left: 0.75rem; padding-right: 0.75rem; box-sizing: border-box; }
    .banner-slides {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding-top: 0.5rem;
      padding-bottom: 1.25rem;
    }
    .banner-slide {
      max-width: none !important;
      width: 100% !important;
      border-radius: 12px;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.18);
    }
    .banner-slide__media img { width: 100%; {% if banner_height %}height: {{ banner_height }}px; max-height: {{ banner_height }}px;{% else %}height: auto; max-height: none;{% endif %} object-fit: cover; display: block; }
    .banner-slide__overlay { background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.3) 50%, transparent 100%); padding-left: 0.75rem; padding-right: 0.75rem; }
    .banner-slide__content { max-width: 100%; padding: 1.25rem 0.75rem; }
    .banner-slide__title { font-size: 1.375rem; }
    .banner-slide__subtitle { font-size: 1rem; }
    /* Vertical banners on mobile: even tighter */
    .banner--vertical .banner-slide__title { font-size: 1.25rem; }
    .banner--vertical .banner-slide__subtitle { font-size: .9375rem; }
    /* Mobile does not use slider controls */
    .banner-nav,
    .banner-dots { display: none !important; }
    /* Mobile: remove outer max-width constraint so banner fills the screen */
    .banner-layout--stack { max-width: none !important; margin-left: 0; margin-right: 0; }
  }
</style>

{% set is_vertical = banner_height > banner_width %}
<div class="banner-slider{% if is_vertical %} banner--vertical{% else %} banner--horizontal{% endif %} banner-layout--{{ banner_layout|default('grid') }}" id="banner-{{ module }}" data-autoplay="3500">
  <div class="banner-slides{% if banner_layout == 'stack' %} banner-slides--stack{% endif %}">
    {% for banner in banners %}
    <div class="banner-slide{% if loop.first %} active{% endif %}" style="--stack-index: {{ loop.index }};">
      {% if banner.link %}<a href="{{ banner.link }}" class="banner-slide__link">{% endif %}
      <div class="banner-slide__media">
      {% if banner.video_type == 'youtube' and banner.video_url %}
      <iframe src="{{ banner.video_url }}"
        class="banner-slide__iframe"
        frameborder="0" allow="autoplay; fullscreen" allowfullscreen
        style="pointer-events:none; width:100%; height:{{ banner_height ? banner_height ~ 'px' : 'auto' }}; object-fit:cover;"></iframe>
      {% elseif banner.video_type == 'mp4' and banner.video_url %}
      <video autoplay muted loop playsinline
        class="banner-slide__video"
        poster="{{ banner.image }}"
        style="width:100%; height:{{ banner_height ? banner_height ~ 'px' : 'auto' }}; object-fit:cover;">
        <source src="{{ banner.video_url }}" type="video/mp4">
      </video>
      {% elseif banner.image %}
      {# Use portrait variant when available, otherwise fall back to the landscape image for portrait orientation #}
      {% set portrait_src = banner.image_portrait ? banner.image_portrait : banner.image %}
      <picture>
        <source media="(orientation: portrait)" srcset="{{ portrait_src }}" />
        <source media="(orientation: landscape)" srcset="{{ banner.image }}" />
        <img src="{{ banner.image }}" alt="{{ banner.title }}" loading="lazy" />
      </picture>
      {% endif %}
      {% if banner.link %}</a>{% endif %}

      {% if banner.title_html or banner.subtitle or banner.accent_text or banner.primary_btn_text or banner.secondary_btn_text %}
      <div class="banner-slide__overlay">
        <div class="banner-slide__content">
          {% if banner.accent_text %}
          {%- set badge_color = banner.accent_color ? banner.accent_color : '' -%}
          <span class="banner-slide__badge"{% if badge_color or banner.accent_color or banner.accent_bg %} style="{% if badge_color %}background-color: {{ badge_color }};{% endif %}{% if banner.accent_color %} --accent: {{ banner.accent_color }};{% endif %}{% if banner.accent_bg %} --accent-bg: {{ banner.accent_bg }};{% endif %} color: {{ banner.badge_text_color }};"{% endif %}>{{ banner.accent_text }}</span>
          {% endif %}
          {% if banner.title_html %}
          <h2 class="banner-slide__title">{{ banner.title_html|raw }}</h2>
          {% endif %}
          {% if banner.subtitle %}
          <p class="banner-slide__subtitle">{{ banner.subtitle }}</p>
          {% endif %}
          {% if banner.primary_btn_text or banner.secondary_btn_text %}
          <div class="banner-slide__btns">
            {% if banner.primary_btn_text %}
            <a href="{{ banner.primary_btn_link }}" class="banner-slide__btn banner-slide__btn--primary"{% if banner.accent_color or banner.accent_bg or banner.primary_btn_bg_color or banner.primary_btn_text_color %} style="{% if banner.primary_btn_bg_color %}background-color: {{ banner.primary_btn_bg_color }}; border-color: {{ banner.primary_btn_bg_color }};{% elseif banner.accent_color %}--accent: {{ banner.accent_color }};{% endif %}{% if banner.primary_btn_text_color %} color: {{ banner.primary_btn_text_color }};{% endif %}"{% endif %}>{{ banner.primary_btn_text }}</a>
            {% endif %}
            {% if banner.secondary_btn_text %}
            <a href="{{ banner.secondary_btn_link }}" class="banner-slide__btn banner-slide__btn--secondary">{{ banner.secondary_btn_text }}</a>
            {% endif %}
          </div>
          {% endif %}
        </div>
      </div>
      {% endif %}
      </div>

    </div>
    {% endfor %}
  </div>

  {% if banners|length > 1 %}
  <button class="banner-nav banner-prev" aria-label="Previous slide"></button>
  <button class="banner-nav banner-next" aria-label="Next slide"></button>

  <div class="banner-dots">
    {% for banner in banners %}
    <button class="banner-dot{% if loop.first %} active{% endif %}"
            data-slide="{{ loop.index0 }}"
            aria-label="Go to slide {{ loop.index }}"></button>
    {% endfor %}
  </div>
  {% endif %}
</div>

<script>
  (function () {
    var root = document.getElementById('banner-{{ module }}');
    if (!root) return;

    // On mobile, banners are displayed as a simple vertical stack.
    // On desktop, banners are shown in a responsive flex row.
    var mobileQuery = window.matchMedia('(max-width: 767px)');

    // No special interactions needed on mobile with the simplified stack layout
    if (mobileQuery.matches) {
      return;
    }
  })();
</script>
