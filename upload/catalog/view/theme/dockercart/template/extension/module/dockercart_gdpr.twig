<style>
.dc-gdpr-banner { position: fixed; left: 0; right: 0; z-index: 9999; background: #fff; box-shadow: 0 -4px 20px rgba(0,0,0,0.12); border-top: 1px solid #e5e7eb; padding: 1rem 1.5rem; transform: translateY(100%); transition: transform 0.35s ease; }
.dc-gdpr-banner--visible { transform: translateY(0); }
.dc-gdpr-banner--hidden { transform: translateY(100%); }
.dc-gdpr-banner-top { top: 0; border-top: none; border-bottom: 1px solid #e5e7eb; transform: translateY(-100%); }
.dc-gdpr-banner-top.dc-gdpr-banner--visible { transform: translateY(0); }
.dc-gdpr-banner-top.dc-gdpr-banner--hidden { transform: translateY(-100%); }
.dc-gdpr-banner-bottom { bottom: 0; }
.dc-gdpr-banner-center { top: 50%; left: 50%; transform: translate(-50%,-50%) scale(0.95); max-width: 520px; border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 20px 60px rgba(0,0,0,0.2); }
.dc-gdpr-banner-center.dc-gdpr-banner--visible { transform: translate(-50%,-50%) scale(1); }
.dc-gdpr-banner-center.dc-gdpr-banner--hidden { transform: translate(-50%,-50%) scale(0.95); opacity: 0; }
.dc-gdpr-banner-inner { max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; }
.dc-gdpr-banner-content { flex: 1; min-width: 240px; }
.dc-gdpr-banner-title { font-size: 1rem; font-weight: 700; color: #111827; margin: 0 0 0.25rem; }
.dc-gdpr-banner-text { font-size: 0.875rem; color: #6b7280; margin: 0; line-height: 1.5; }
.dc-gdpr-banner-link { color: #3b82f6; text-decoration: underline; }
.dc-gdpr-banner-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; flex-shrink: 0; }
.dc-gdpr-btn { padding: 0.5rem 1.25rem; border-radius: 8px; font-size: 0.875rem; font-weight: 600; border: 1px solid #d1d5db; background: #fff; color: #374151; cursor: pointer; transition: all 0.15s; }
.dc-gdpr-btn:hover { border-color: #9ca3af; }
.dc-gdpr-btn-accept { background: #2563eb; color: #fff; border-color: #2563eb; }
.dc-gdpr-btn-accept:hover { background: #1d4ed8; border-color: #1d4ed8; }
.dc-gdpr-btn-dns { background: transparent; border: none; color: #6b7280; font-size: 0.8rem; text-decoration: underline; padding: 0.25rem 0.5rem; }
.dc-gdpr-btn-dns:hover { color: #111827; }
@media (max-width: 640px) {
  .dc-gdpr-banner-inner { flex-direction: column; align-items: stretch; text-align: center; }
  .dc-gdpr-banner-actions { justify-content: center; }
}
</style>

<div id="{{ module_id }}" class="dc-gdpr-banner dc-gdpr-banner-{{ position }}" data-expiry="{{ consent_expiry }}" data-framework="{{ framework }}" data-accept-url="{{ accept_url }}" data-reject-url="{{ reject_url }}" data-dns-url="{{ do_not_sell_url }}" role="alert" aria-live="polite">
  <div class="dc-gdpr-banner-inner">
    <div class="dc-gdpr-banner-content">
      <h3 class="dc-gdpr-banner-title">{{ banner_title }}</h3>
      <p class="dc-gdpr-banner-text">
        {{ banner_text }}
        {% if privacy_url %}
          <a href="{{ privacy_url }}" class="dc-gdpr-banner-link" target="_blank">{{ privacy_link_text }}</a>
        {% endif %}
      </p>
    </div>

    <div class="dc-gdpr-banner-actions">
      <button type="button" class="dc-gdpr-btn dc-gdpr-btn-reject" data-action="reject">{{ reject_text }}</button>
      <button type="button" class="dc-gdpr-btn dc-gdpr-btn-accept" data-action="accept">{{ accept_text }}</button>

      {% if do_not_sell_enabled and framework in ['us', 'both'] %}
        <button type="button" class="dc-gdpr-btn dc-gdpr-btn-dns" data-action="do-not-sell">{{ do_not_sell_text }}</button>
      {% endif %}
    </div>
  </div>
</div>

<script src="catalog/view/theme/dockercart/javascript/dockercart-gdpr.js?v={{ dockercart_version }}"></script>
