{# Special module for dockercart theme #}
{% if products|length %}
<section id="special" class="py-16 bg-white px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-red-500 text-sm font-semibold uppercase tracking-widest mb-1">{{ text_special }}</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">{{ heading_title }}</h2>
        </div>
        <div class="hidden sm:block">
          <a href="{{ section_href }}" class="text-sm font-semibold text-blue-600 hover:underline">{{ text_view_all }}</a>
        </div>
      </div>
    </div>

    <div id="special-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
      {% for product in products %}
        {% include 'dockercart/template/product/product_card_widget.twig' with {
          product: product,
          accent_color: 'red-600',
          btn_cart_classes: 'bg-red-600 text-white hover:bg-red-700',
          btn_quick_hover: 'hover:bg-red-600'
        } %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# Quick View modal is created dynamically by quick-view.js #}
