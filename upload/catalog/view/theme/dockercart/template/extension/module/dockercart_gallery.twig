{{ header }}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <nav class="text-sm text-gray-500 mb-6">
    <ul class="flex items-center gap-2 flex-wrap">
      {% for breadcrumb in breadcrumbs %}
        {% if loop.last %}
          <li class="text-gray-900 font-medium">{{ breadcrumb.text }}</li>
        {% else %}
          <li><a href="{{ breadcrumb.href }}" class="hover:text-blue-600 transition">{{ breadcrumb.text }}</a></li>
          <li class="text-gray-300">•</li>
        {% endif %}
      {% endfor %}
    </ul>
  </nav>

  <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-8">{{ heading_title }}</h1>

  {% if images %}
    <style>
      .dc-gallery-masonry {
        column-count: 1;
        column-gap: 1rem;
      }
      @media (min-width: 640px) {
        .dc-gallery-masonry { column-count: 2; }
      }
      @media (min-width: 1024px) {
        .dc-gallery-masonry { column-count: 3; }
      }
      .dc-gallery-masonry > .dc-gallery-item {
        break-inside: avoid;
        margin-bottom: 1rem;
      }
      .dc-gallery-item img {
        width: 100%;
        display: block;
        border-radius: 0.75rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .dc-gallery-item:hover img {
        transform: scale(1.02);
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.15);
      }
    </style>

    <div id="dc-gallery-grid" class="dc-gallery-masonry">
      {% for image in images %}
        {{ image.html|raw }}
      {% endfor %}
    </div>

    {% if has_more %}
    <div class="dc-load-more-wrap text-center mt-10">
      <button type="button" class="dc-load-more-btn inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gray-900 text-white text-sm font-semibold hover:bg-gray-800 transition disabled:opacity-50 disabled:cursor-not-allowed"
              data-url="{{ load_more_url }}"
              data-page="2"
              data-loaded="{{ images|length }}"
              data-total="{{ total_images }}">
        <span>{{ text_load_more }}</span>
        <i data-lucide="chevron-down" class="w-4 h-4"></i>
        <span class="dc-lm-count text-gray-400 font-normal">({{ images|length }} / {{ total_images }})</span>
      </button>
    </div>
    {% endif %}
  {% else %}
    <p class="text-gray-500 text-center py-20">{{ text_no_images }}</p>
  {% endif %}
</div>
{{ footer }}
