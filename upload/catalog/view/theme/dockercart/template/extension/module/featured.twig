{# Featured module for dockercart theme #}
{% if products|length %}
<section id="featured" class="py-16 bg-white px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-8">
      <p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-1">{{ text_section_small }}</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">{{ heading_title }}</h2>
    </div>

    {% if category_filter and categories|length > 0 %}
    <div class="dc-category-filter mb-6 flex flex-wrap justify-center gap-2" data-module="featured">
      {% set has_other = false %}
      {% for product in products %}
        {% if product.category_id == 0 %}
          {% set has_other = true %}
        {% endif %}
      {% endfor %}
      {% for cat in categories %}
      <button type="button" class="dc-cat-btn px-4 py-2 text-sm font-medium rounded-full border border-gray-300 text-gray-700 hover:bg-gray-50 hover:border-blue-500 transition-all duration-200" data-category-id="{{ cat.category_id }}">
        {{ cat.name }}
      </button>
      {% endfor %}
      {% if has_other %}
      <button type="button" class="dc-cat-btn px-4 py-2 text-sm font-medium rounded-full border border-gray-300 text-gray-700 hover:bg-gray-50 hover:border-blue-500 transition-all duration-200" data-category-id="0">
        {{ text_other }}
      </button>
      {% endif %}
    </div>
    {% endif %}

    <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
      {% for product in products %}
      <div class="dc-product-item" data-category-id="{{ product.category_id }}">
        {% include 'dockercart/template/product/product_card_widget.twig' with {
          product: product,
          accent_color: 'blue-600',
          btn_cart_classes: 'bg-blue-600 text-white hover:bg-blue-700',
          btn_quick_hover: 'hover:bg-blue-600'
        } %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if category_filter and categories|length > 0 %}
<style>
.dc-cat-btn.bg-blue-600 {
  border-color: rgb(37 99 235);
}
.dc-cat-btn.bg-blue-600:hover {
  background-color: rgb(29 78 216);
  border-color: rgb(29 78 216);
}
</style>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const filterContainer = document.querySelector('.dc-category-filter[data-module="featured"]');
  if (!filterContainer) return;
  
  const buttons = filterContainer.querySelectorAll('.dc-cat-btn');
  const productItems = document.querySelectorAll('#featured .dc-product-item');
  let activeBtn = null;
  
  buttons.forEach(btn => {
    btn.addEventListener('click', function() {
      const catId = this.dataset.categoryId;
      
      if (activeBtn === this) {
        this.classList.remove('bg-blue-600', 'text-white', 'border-blue-600');
        this.classList.add('border-gray-300', 'text-gray-700', 'hover:bg-gray-50');
        activeBtn = null;
        productItems.forEach(item => item.style.display = '');
        return;
      }
      
      buttons.forEach(b => {
        b.classList.remove('bg-blue-600', 'text-white', 'border-blue-600');
        b.classList.add('border-gray-300', 'text-gray-700', 'hover:bg-gray-50');
      });
      
      this.classList.remove('border-gray-300', 'text-gray-700', 'hover:bg-gray-50');
      this.classList.add('bg-blue-600', 'text-white', 'border-blue-600');
      activeBtn = this;
      
      productItems.forEach(item => {
        if (item.dataset.categoryId === catId) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
});
</script>
{% endif %}

{# Quick View modal is created dynamically by quick-view.js #}
