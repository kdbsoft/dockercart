{% if categories %}
{% if menu_type == 'vertical' %}
<div class="hidden lg:block bg-white border-b border-gray-200 h-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-10 flex items-center">
    <a href="{{ new_arrivals }}" class="flex items-center gap-1 px-3 h-8 text-sm font-bold text-teal-600 hover:text-teal-700 hover:bg-teal-50 transition whitespace-nowrap rounded-sm">
      <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
      {{ text_new_arrivals }}
    </a>
    <a href="{{ special }}" class="flex items-center gap-1 px-3 h-8 text-sm font-bold text-red-500 hover:text-red-600 hover:bg-red-50 transition whitespace-nowrap rounded-sm">
      <i data-lucide="tag" class="w-3.5 h-3.5"></i>
      {{ text_sale }}
    </a>
    {% if top_informations is defined and top_informations %}
      {% for info in top_informations %}
      <a href="{{ info.href }}" class="flex items-center gap-1 px-3 h-8 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50/70 transition whitespace-nowrap rounded-sm">
        {{ info.title }}
      </a>
      {% endfor %}
    {% endif %}
  </div>
</div>

{# ─── Two-panel hamburger (desktop) ──────────────────────────────────── #}
<div id="dc-vertical-menu-panel" class="dc-vertical-menu-panel hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="dc-vm-shell">

      {# LEFT: compact category list #}
      <nav class="dc-vm-left" aria-label="{{ text_catalog }}">
        {% for category in categories %}
        <div class="dc-vm-cat-row" data-vm-cat="{{ loop.index0 }}">
          <a href="{{ category.href }}" class="dc-vm-cat-link{% if category.is_active %} is-active{% endif %}">
            <span>{{ category.name }}</span>
            {% if category.children %}<i data-lucide="chevron-right" class="dc-vm-chevron w-3.5 h-3.5 flex-shrink-0"></i>{% endif %}
          </a>
        </div>
        {% endfor %}
      </nav>

      {# RIGHT: subcategory panel for each top-level category #}
      {# show right panels only if at least one top-level category has children #}
      {% set has_vm_children = false %}
      {% for category in categories %}
        {% if category.children %}
          {% set has_vm_children = true %}
        {% endif %}
      {% endfor %}

      {% if has_vm_children %}
      <div class="dc-vm-right">
        {% for category in categories %}
        <div class="dc-vm-panel" data-vm-panel="{{ loop.index0 }}">
          {% if category.children %}
          <div class="dc-vm-panel-grid" data-cols="{{ category.children|length }}">
            {% for child in category.children %}
            <div class="dc-vm-subcat-group">
              <a href="{{ child.href }}" class="dc-vm-subcat-parent">{{ child.name }}</a>
              {% if child.children %}
              <ul class="dc-vm-subcat-list">
                {% for grandchild in child.children %}
                <li><a href="{{ grandchild.href }}" class="dc-vm-subcat-child">{{ grandchild.name }}</a></li>
                {% endfor %}
              </ul>
              {% endif %}
            </div>
            {% endfor %}
          </div>
          {% endif %}

          {# Always show "See all" footer link even if no children exist #}
          <div class="dc-vm-panel-footer">
            <a href="{{ category.href }}" class="dc-vm-see-all">{{ text_all }} {{ category.name }} →</a>
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}

    </div>{# /.dc-vm-shell #}
  </div>
</div>

{% else %}
{# ─── Horizontal mega-nav (desktop) — scrollable with fade edges ──────── #}
<div class="hidden lg:block bg-white border-b border-gray-200">
  <div id="dc-hnav-wrap" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">

    {# Fade overlays — shown when content is scrolled #}
    <div id="dc-hnav-fade-left" class="dc-hnav-fade dc-hnav-fade-left"></div>
    <div id="dc-hnav-fade-right" class="dc-hnav-fade dc-hnav-fade-right"></div>

    {# Scroll buttons — appear on hover when content overflows #}
    <button id="dc-hnav-btn-left" class="dc-hnav-btn dc-hnav-btn-left" aria-label="Scroll left">
      <i data-lucide="chevron-left" class="w-4 h-4"></i>
    </button>
    <button id="dc-hnav-btn-right" class="dc-hnav-btn dc-hnav-btn-right" aria-label="Scroll right">
      <i data-lucide="chevron-right" class="w-4 h-4"></i>
    </button>

    <nav id="dc-hnav-scroll" class="dc-hnav-scroll flex items-center gap-0.5">

      {% for category in categories %}
      <div class="dc-cat-item flex-shrink-0{% if category.children %} has-children{% endif %}" data-dc-cat-idx="{{ loop.index0 }}">
        {% if category.children %}

        <a href="{{ category.href }}" class="flex items-center gap-1 px-3 h-10 text-sm {% if category.is_active %}font-bold text-blue-600 bg-blue-50/80{% else %}font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50/70{% endif %} transition rounded-sm whitespace-nowrap">
          {% if category.icon %}<img src="{{ category.icon }}" alt="" class="w-5 h-5 flex-shrink-0 object-contain" />{% endif %}{{ category.name }}
          <i data-lucide="chevron-down" class="w-3 h-3 opacity-50 flex-shrink-0 ml-0.5"></i>
        </a>

        {% else %}

        <a href="{{ category.href }}" class="flex items-center gap-1 px-3 h-10 text-sm {% if category.is_active %}font-bold text-blue-600 bg-blue-50/80{% else %}font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50/70{% endif %} transition rounded-sm whitespace-nowrap">
          {% if category.icon %}<img src="{{ category.icon }}" alt="" class="w-5 h-5 flex-shrink-0 object-contain" />{% endif %}{{ category.name }}
        </a>

        {% endif %}
      </div>
      {% endfor %}

    </nav>

    {# Dropdown portals — rendered outside scroll container #}
    {% for category in categories %}
      {% if category.children %}
    <div class="dc-dd-portal" data-dc-cat-portal="{{ loop.index0 }}">
      <div class="dc-cat-dropdown bg-white rounded-2xl shadow-2xl border border-gray-100 p-5 min-w-[240px]">
        <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-3">{{ category.name }}</p>
        <ul class="space-y-0.5">
          {% for child in category.children %}
          <li>
            <a href="{{ child.href }}" class="dc-cat-mega-parent">
              {% if child.icon %}<img src="{{ child.icon }}" alt="" class="w-4 h-4 inline-block mr-1 align-text-bottom" />{% endif %}{{ child.name }}
            </a>
          </li>
          {% endfor %}
          <li class="pt-2 border-t border-gray-100 mt-1">
            <a href="{{ category.href }}" class="dc-cat-mega-seeall dc-cat-mega-seeall-link">
              {{ text_all }} {{ category.name }} →
            </a>
          </li>
        </ul>
      </div>
    </div>
      {% endif %}
    {% endfor %}

    {# Right accent links — always visible over the scrollable area #}
    <div class="dc-hnav-accents">
      <a href="/product-new_arrivals" class="flex items-center gap-1 px-3 h-10 text-sm font-bold text-teal-600 hover:text-teal-700 hover:bg-teal-50 transition whitespace-nowrap rounded-sm">
        <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
        {{ text_new_arrivals }}
      </a>
      <a href="/product-special" class="flex items-center gap-1 px-3 h-10 text-sm font-bold text-red-500 hover:text-red-600 hover:bg-red-50 transition whitespace-nowrap rounded-sm">
        <i data-lucide="tag" class="w-3.5 h-3.5"></i>
        {{ text_sale }}
      </a>
      {% if menu_type == 'vertical' and top_informations is defined and top_informations %}
        {% for info in top_informations %}
          <a href="{{ info.href }}" class="flex items-center gap-1 px-3 h-10 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50/70 transition whitespace-nowrap rounded-sm">
            {{ info.title }}
          </a>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</div>
{% endif %}
{% endif %}
