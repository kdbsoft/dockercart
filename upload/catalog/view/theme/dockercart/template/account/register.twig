{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      {{ content_top }}

      {% if error_warning %}
      <div class="mb-6 bg-red-50 border border-red-200 text-red-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ error_warning }}</span>
      </div>
      {% endif %}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        {# ── Register Form ── #}
        <div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm">
          <h2 class="text-lg font-extrabold text-gray-900 mb-5">{{ text_register }}</h2>
          <form action="{{ action }}" method="post" enctype="multipart/form-data" id="account">

            {# Customer Groups #}
            {% if customer_groups|length > 1 %}
            <div class="mb-6">
              <label class="block text-sm font-medium text-gray-700 mb-2">{{ entry_customer_group }}</label>
              <div class="grid grid-cols-2 gap-2">
                {% for customer_group in customer_groups %}
                <label class="flex items-center gap-2 cursor-pointer border border-gray-200 rounded-xl p-3 hover:border-blue-300 transition">
                  <input type="radio" name="customer_group_id" value="{{ customer_group.customer_group_id }}"
                    {% if customer_group.customer_group_id == customer_group_id %}checked{% endif %}
                    class="w-4 h-4 text-blue-600 border-gray-300" />
                  <span class="text-sm text-gray-700">{{ customer_group.name }}</span>
                </label>
                {% endfor %}
              </div>
            </div>
            {% endif %}

            {# Name #}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-firstname">{{ entry_firstname }}</label>
                <input type="text" name="firstname" value="{{ firstname }}" placeholder="{{ entry_firstname }}" id="input-firstname"
                  class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
                {% if error_firstname %}<p class="text-sm text-red-500 mt-1">{{ error_firstname }}</p>{% endif %}
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-lastname">{{ entry_lastname }}</label>
                <input type="text" name="lastname" value="{{ lastname }}" placeholder="{{ entry_lastname }}" id="input-lastname"
                  class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
                {% if error_lastname %}<p class="text-sm text-red-500 mt-1">{{ error_lastname }}</p>{% endif %}
              </div>
            </div>

            {# Email #}
            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-email">{{ entry_email }}</label>
              <input type="email" name="email" value="{{ email }}" placeholder="you@example.com" id="input-email"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_email %}<p class="text-sm text-red-500 mt-1">{{ error_email }}</p>{% endif %}
            </div>

            {# Telephone #}
            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-telephone">{{ entry_telephone }}</label>
              <input type="tel" name="telephone" value="{{ telephone }}" placeholder="+380 __ ___ __ __" id="input-telephone"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_telephone %}<p class="text-sm text-red-500 mt-1">{{ error_telephone }}</p>{% endif %}
            </div>

            {# Custom Fields #}
            {% for custom_field in custom_fields %}
              <div id="custom-field{{ custom_field.custom_field_id }}" class="mb-4 custom-field" data-sort="{{ custom_field.sort_order }}">
              <label class="block text-sm font-medium text-gray-700 mb-1.5">{{ custom_field.name }}</label>
              {% if custom_field.type == 'select' %}
              <select name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">{{ text_select }}</option>
                {% for v in custom_field.custom_field_value %}
                <option value="{{ v.custom_field_value_id }}" {% if register_custom_field[custom_field.location][custom_field.custom_field_id] and v.custom_field_value_id == register_custom_field[custom_field.location][custom_field.custom_field_id] %}selected{% endif %}>{{ v.name }}</option>
                {% endfor %}
              </select>
              {% elseif custom_field.type == 'textarea' %}
              <textarea name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" rows="4"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">{% if register_custom_field[custom_field.custom_field_id] %}{{ register_custom_field[custom_field.custom_field_id] }}{% else %}{{ custom_field.value }}{% endif %}</textarea>
              {% elseif custom_field.type == 'radio' %}
              <div class="space-y-2">
                {% for v in custom_field.custom_field_value %}
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" value="{{ v.custom_field_value_id }}"
                    {% if register_custom_field[custom_field.custom_field_id] and v.custom_field_value_id == register_custom_field[custom_field.custom_field_id] %}checked{% endif %}
                    class="w-4 h-4 text-blue-600 border-gray-300" />
                  <span class="text-sm text-gray-700">{{ v.name }}</span>
                </label>
                {% endfor %}
              </div>
              {% elseif custom_field.type == 'checkbox' %}
              <div class="space-y-2">
                {% for v in custom_field.custom_field_value %}
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}][]" value="{{ v.custom_field_value_id }}"
                    {% if register_custom_field[custom_field.custom_field_id] and v.custom_field_value_id in register_custom_field[custom_field.custom_field_id] %}checked{% endif %}
                    class="w-4 h-4 text-blue-600 border-gray-300 rounded" />
                  <span class="text-sm text-gray-700">{{ v.name }}</span>
                </label>
                {% endfor %}
              </div>
              {% elseif custom_field.type == 'file' %}
              <button type="button" id="button-custom-field{{ custom_field.custom_field_id }}"
                class="border border-gray-200 hover:border-blue-300 text-gray-700 font-medium px-5 py-2.5 rounded-xl transition-colors text-sm flex items-center gap-2">
                <i data-lucide="upload" class="w-4 h-4"></i>
                {{ button_upload }}
              </button>
              <input type="hidden" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]"
                value="{% if register_custom_field[custom_field.custom_field_id] %}{{ register_custom_field[custom_field.custom_field_id] }}{% endif %}" />
              {% else %}
              <input type="text" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]"
                value="{% if register_custom_field[custom_field.custom_field_id] %}{{ register_custom_field[custom_field.custom_field_id] }}{% else %}{{ custom_field.value }}{% endif %}"
                placeholder="{{ custom_field.name }}"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% endif %}
              {% if error_custom_field[custom_field.custom_field_id] %}<p class="text-sm text-red-500 mt-1">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
            </div>
            {% endfor %}

            {# Password #}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-password">{{ entry_password }}</label>
                <div class="flex items-stretch rounded-xl border border-gray-200 focus-within:ring-2 focus-within:ring-blue-500 focus-within:border-transparent bg-white">
                  <input type="password" name="password" value="{{ password }}" placeholder="{{ entry_password }}" id="input-password"
                    class="w-full min-w-0 border-0 px-4 py-3 text-sm focus:outline-none focus:ring-0 bg-transparent" />
                  <button type="button" data-toggle="input-password" class="px-3 flex items-center text-gray-400 hover:text-gray-600">
                    <i data-lucide="eye" class="w-4 h-4 show-icon"></i>
                    <i data-lucide="eye-off" class="w-4 h-4 hide-icon hidden"></i>
                  </button>
                </div>
                {% if error_password %}<p class="text-sm text-red-500 mt-1">{{ error_password }}</p>{% endif %}
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-confirm">{{ entry_confirm }}</label>
                <div class="flex items-stretch rounded-xl border border-gray-200 focus-within:ring-2 focus-within:ring-blue-500 focus-within:border-transparent bg-white">
                  <input type="password" name="confirm" value="{{ confirm }}" placeholder="{{ entry_confirm }}" id="input-confirm"
                    class="w-full min-w-0 border-0 px-4 py-3 text-sm focus:outline-none focus:ring-0 bg-transparent" />
                  <button type="button" data-toggle="input-confirm" class="px-3 flex items-center text-gray-400 hover:text-gray-600">
                    <i data-lucide="eye" class="w-4 h-4 show-icon"></i>
                    <i data-lucide="eye-off" class="w-4 h-4 hide-icon hidden"></i>
                  </button>
                </div>
                {% if error_confirm %}<p class="text-sm text-red-500 mt-1">{{ error_confirm }}</p>{% endif %}
              </div>
            </div>

            {{ captcha }}

            {# Agree & Submit #}
            <div class="border-t border-gray-100 pt-6">
              {% if text_agree %}
              <div class="flex items-start gap-2 text-sm text-gray-600 mb-4">
                <input type="checkbox" name="agree" value="1" {% if agree %}checked{% endif %}
                  class="w-4 h-4 text-blue-600 border-gray-300 rounded mt-0.5" />
                <span>{{ text_agree }}</span>
              </div>
              {% endif %}

              <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
                {{ button_continue }}
              </button>
            </div>

          </form>
        </div>

        {# ── Promo: Login ── #}
        <div class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 rounded-3xl p-6 sm:p-8 flex flex-col items-center justify-center text-center">
          <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center mb-5">
            <i data-lucide="log-in" class="w-7 h-7 text-white"></i>
          </div>
          <h2 class="text-xl font-extrabold text-white mb-3">{{ text_already_have_account }}</h2>
          <p class="text-sm text-gray-300 mb-6 max-w-xs">{{ text_account_already }}</p>
          <a href="{{ action|replace({'register': 'login'}) }}" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-100 text-gray-900 font-semibold px-6 py-3 rounded-xl transition-colors">
            {{ text_login_link }}
          </a>
        </div>

      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>

{# ── Privacy Policy Modal ── #}
<div id="terms-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] flex flex-col">
    <div class="flex items-center justify-between p-5 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-900">{{ heading_title }}</h3>
      <button type="button" id="close-terms-modal" class="text-gray-400 hover:text-gray-600 transition flex items-center justify-center w-8 h-8 rounded-full hover:bg-gray-100">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>
    <div class="p-5 overflow-y-auto flex-1 text-sm text-gray-600 leading-relaxed" id="terms-content">
      <div class="flex items-center justify-center py-8">
        <svg class="animate-spin h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </div>
    </div>
    <div class="p-5 border-t border-gray-200 flex justify-end gap-3">
      <button type="button" id="decline-terms" class="px-5 py-2.5 rounded-xl border border-gray-200 text-gray-700 hover:bg-gray-50 transition text-sm font-medium">{{ text_no }}</button>
      <button type="button" id="accept-terms" class="px-5 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white transition text-sm font-medium">{{ button_continue }}</button>
    </div>
  </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
	// Sort custom fields by data-sort
	var container = document.querySelector('#account');
	var fields = container.querySelectorAll('.custom-field[data-sort]');

	Array.from(fields).sort(function(a, b) {
		return parseInt(a.getAttribute('data-sort'), 10) - parseInt(b.getAttribute('data-sort'), 10);
	}).forEach(function(field) {
		container.appendChild(field);
	});

	// Customer group change -> load custom fields
	var groupRadios = document.querySelectorAll('input[name="customer_group_id"]');

	groupRadios.forEach(function(radio) {
		radio.addEventListener('change', function() {
			fetch('index.php?route=account/register/customfield&customer_group_id=' + this.value)
				.then(function(r) { return r.json(); })
				.then(function(json) {
					document.querySelectorAll('.custom-field').forEach(function(el) {
						el.style.display = 'none';
					});

					for (var i = 0; i < json.length; i++) {
						var cf = json[i];
						var el = document.querySelector('.custom-field[id="custom-field' + cf['custom_field_id'] + '"]');
						if (el) el.style.display = '';
					}
				})
				.catch(function(err) {
					console.error('Failed to load custom fields:', err);
				});
		});
	});

	// Trigger initial load
	var checked = document.querySelector('input[name="customer_group_id"]:checked');
	if (checked) checked.dispatchEvent(new Event('change'));

	// Password toggle
	document.querySelectorAll('[data-toggle]').forEach(function(btn) {
		btn.addEventListener('click', function() {
			var targetId = this.getAttribute('data-toggle');
			var input = document.getElementById(targetId);
			if (!input) return;

			var showIcon = this.querySelector('.show-icon');
			var hideIcon = this.querySelector('.hide-icon');

			if (input.type === 'password') {
				input.type = 'text';
				showIcon.classList.add('hidden');
				hideIcon.classList.remove('hidden');
			} else {
				input.type = 'password';
				showIcon.classList.remove('hidden');
				hideIcon.classList.add('hidden');
			}
		});
	});

	// Terms modal
	var termsModal = document.getElementById('terms-modal');
	var closeBtn = document.getElementById('close-terms-modal');
	var declineBtn = document.getElementById('decline-terms');
	var acceptBtn = document.getElementById('accept-terms');
	var termsContent = document.getElementById('terms-content');
	var agreeCheckbox = document.querySelector('input[name="agree"]');

	document.querySelectorAll('#account .agree').forEach(function(link) {
		link.addEventListener('click', function(e) {
			e.preventDefault();
			var url = this.getAttribute('href');
			if (!url) return;

			termsContent.innerHTML =
				'<div class="flex items-center justify-center py-8">' +
				'<svg class="animate-spin h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">' +
				'<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>' +
				'<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>' +
				'</svg></div>';

			termsModal.classList.remove('hidden');

			fetch(url, { credentials: 'same-origin' })
				.then(function(r) { return r.text(); })
				.then(function(html) {
					var parser = new DOMParser();
					var doc = parser.parseFromString(html, 'text/html');
					var content = doc.querySelector('.content, .description, main, article, #content');
					termsContent.innerHTML = content && content.innerHTML.trim()
						? content.innerHTML
						: html;
				})
				.catch(function() {
					termsContent.innerHTML =
						'<p class="text-center py-8 text-gray-500">' +
						'Failed to load content. ' +
						'<a href="' + url + '" target="_blank" class="text-blue-600 underline">Open in new tab</a>' +
						'</p>';
				});
		});
	});

	if (closeBtn) {
		closeBtn.addEventListener('click', function() { termsModal.classList.add('hidden'); });
	}

	if (declineBtn) {
		declineBtn.addEventListener('click', function() {
			if (agreeCheckbox) agreeCheckbox.checked = false;
			termsModal.classList.add('hidden');
		});
	}

	if (acceptBtn) {
		acceptBtn.addEventListener('click', function() {
			if (agreeCheckbox) agreeCheckbox.checked = true;
			termsModal.classList.add('hidden');
		});
	}

	if (termsModal) {
		termsModal.addEventListener('click', function(e) {
			if (e.target === termsModal) termsModal.classList.add('hidden');
		});
	}
});
</script>
{% if phone_format %}
<script>
document.addEventListener('DOMContentLoaded', function() {
	var phoneInput = document.getElementById('input-telephone');
	if (phoneInput && typeof DockercartPhoneMask !== 'undefined') {
		DockercartPhoneMask.init(phoneInput, '{{ phone_format|e('js') }}');
	}
});
</script>
{% endif %}
{{ footer }}
