{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {{ content_top }}

      <div class="flex flex-col lg:flex-row gap-6 items-start">
        <aside class="lg:w-60 flex-shrink-0">
          {{ account_menu }}
        </aside>
        <div class="flex-1 min-w-0">

      {% if orders %}
      <div class="space-y-2 mb-6">
        {% for order in orders %}
        {% set s = order.status|lower %}
        {% if 'complet' in s or 'deliver' in s or 'shipped' in s %}
          {% set badge = 'bg-green-100 text-green-700' %}
        {% elseif 'cancel' in s or 'refund' in s or 'fail' in s or 'denied' in s or 'reversed' in s or 'chargeback' in s or 'void' in s or 'expired' in s %}
          {% set badge = 'bg-red-100 text-red-700' %}
        {% elseif 'pending' in s or 'awaiting' in s or 'on hold' in s %}
          {% set badge = 'bg-amber-100 text-amber-700' %}
        {% elseif 'process' in s or 'transit' in s or 'dispatch' in s %}
          {% set badge = 'bg-blue-100 text-blue-700' %}
        {% else %}
          {% set badge = 'bg-gray-100 text-gray-600' %}
        {% endif %}
        <a href="{{ order.view }}" class="flex items-center gap-4 bg-white border border-gray-100 hover:border-blue-200 rounded-2xl px-5 py-4 transition-all group shadow-sm hover:shadow-md">
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-3 mb-2">
              <div class="flex items-center gap-2">
                <span class="text-base font-bold text-gray-900">#{{ order.order_id }}</span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ badge }}">{{ order.status }}</span>
              </div>
              <span class="text-sm text-gray-400 whitespace-nowrap">{{ order.date_added }}</span>
            </div>
            <div class="flex flex-wrap items-center gap-x-1 gap-y-1 text-sm">
              <span class="text-gray-900 font-semibold mr-2">{{ order.total }}</span>
              <span class="text-gray-300 mr-2">·</span>
              <span class="text-gray-500">{{ order.products }} {{ order.products == 1 ? text_product : text_products }}</span>
              {% if order.tracking_number %}
              <span class="text-gray-300 mr-2">·</span>
              <span class="text-gray-400 font-mono text-xs">{{ order.tracking_number }}</span>
              {% endif %}
            </div>
          </div>
          <i data-lucide="chevron-right" class="w-5 h-5 text-gray-300 group-hover:text-blue-500 transition-colors flex-shrink-0"></i>
        </a>
        {% endfor %}
      </div>

      {% if pagination %}
      <div class="mb-6 flex flex-col sm:flex-row items-center justify-between gap-3">
        <div class="text-sm text-gray-400">{{ results }}</div>
        <div class="dc-pagination">{{ pagination }}</div>
      </div>
      {% endif %}

      {% else %}
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 text-center text-gray-400 text-sm mb-6">
        <i data-lucide="shopping-bag" class="w-8 h-8 mx-auto mb-2 opacity-30"></i>
        <p>{{ text_empty }}</p>
      </div>
      {% endif %}

      <div class="mt-6 flex justify-end">
        <a href="{{ continue }}" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
          {{ button_continue }}
        </a>
      </div>

        </div>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
<style>
  .dc-pagination ul { display:flex; gap:.5rem; list-style:none; padding:0; margin:0; flex-wrap:wrap; justify-content:center; }
  .dc-pagination ul li a,
  .dc-pagination ul li span {
    display:inline-flex; align-items:center; justify-content:center;
    width:2.25rem; height:2.25rem; padding:0;
    border-radius:.75rem; border:1px solid #e5e7eb;
    font-size:.875rem; font-weight:500; color:#6b7280;
    background:#fff; text-decoration:none; transition:all .15s ease;
  }
  .dc-pagination ul li a:hover { border-color:#93c5fd; color:#2563eb; }
  .dc-pagination ul li.active span { background:#2563eb; border-color:#2563eb; color:#fff; }
</style>
{{ footer }}
