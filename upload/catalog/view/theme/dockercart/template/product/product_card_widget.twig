{# Shared product card for widget modules (latest, bestseller, featured, special, related) #}
<div class="product-card group bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:scale-[1.02] transition-all duration-300 flex flex-col {{ card_extra|default('') }}" data-id="{{ product.product_id }}" data-href="{{ product.href }}" data-rating="{{ product.rating is defined ? product.rating : 0 }}" data-model="{{ product.model is defined ? product.model : '' }}" data-brand="{{ product.manufacturer is defined ? product.manufacturer : '' }}" data-description="{{ product.description|striptags|e('html_attr') }}" data-in-wishlist="{{ product.in_wishlist is defined ? product.in_wishlist : 0 }}" data-stock="{{ (product.stock is defined ? product.stock : '')|e('html_attr') }}" data-is-in-stock="{{ product.is_in_stock ? 1 : 0 }}" data-minimum="{{ product.minimum|default(1) }}" data-call-for-price="{{ (product.call_for_price is defined and product.call_for_price) or (call_for_price_status is defined and call_for_price_status and call_for_price_phone is defined and call_for_price_phone and product.price_raw is defined and product.price_raw <= 0) ? 1 : 0 }}">
  <div class="relative overflow-hidden aspect-square bg-gray-50">
    <a href="{{ product.href }}">
      <img src="{{ product.thumb is not empty ? product.thumb : 'image/no_image.png' }}" alt="{{ product.name }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    </a>
    {% set discount_pct = product.discount is defined ? product.discount : 0 %}
    {% if show_new_arrival|default(false) and product.new_arrival_badge is defined and product.new_arrival_badge %}
      <span class="absolute top-2 left-2 bg-gradient-to-r {{ product.new_arrival_badge_class|default('from-teal-500 to-emerald-500') }} text-white text-[10px] font-bold px-2 py-0.5 rounded-md">{{ product.new_arrival_badge }}</span>
    {% elseif product.has_gift is defined and product.has_gift %}
      <span class="absolute top-2 left-2 bg-amber-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-md flex items-center gap-1"><i data-lucide="gift" class="w-3 h-3"></i> {{ text_gift_badge|default('GIFT') }}</span>
    {% elseif discount_pct and discount_pct > 0 %}
      <span class="absolute top-2 left-2 bg-red-500 text-white px-1.5 py-0.5 rounded-lg text-[10px] font-bold">-{{ discount_pct }}%</span>
    {% elseif product.special is defined and product.special and text_sale is defined and text_sale %}
      <span class="absolute top-2 left-2 bg-red-500 text-white px-1.5 py-0.5 rounded-lg text-[10px] font-bold">{{ text_sale }}</span>
    {% endif %}
    <div class="absolute top-2 right-2">
      <button class="w-8 h-8 rounded-full bg-white shadow-md flex items-center justify-center hover:bg-rose-50 transition {% if product.in_wishlist is defined and product.in_wishlist %}bg-rose-50{% endif %} opacity-0 group-hover:opacity-100 group-hover:scale-100 scale-92 -translate-y-1 group-hover:translate-y-0 transition-all duration-200 {% if product.in_wishlist is defined and product.in_wishlist %}!opacity-100 !scale-100 !translate-y-0{% endif %}" onclick="dcAddToWishlist('{{ product.product_id }}', this); event.stopPropagation();" aria-label="{{ text_add_to_wishlist|default('Add to wishlist') }}">
        <i data-lucide="heart" class="w-3.5 h-3.5 {% if product.in_wishlist is defined and product.in_wishlist %}text-rose-500 fill-rose-400{% else %}text-gray-400{% endif %}"></i>
      </button>
    </div>
    <button class="absolute bottom-0 left-0 right-0 py-2.5 bg-gray-900/85 {{ btn_quick_hover|default('hover:bg-blue-600') }} text-white text-[11px] font-bold uppercase tracking-wide opacity-0 translate-y-full group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200" onclick="openQuickView({{ product.product_id }}); event.stopPropagation();">{{ text_quick_view }}</button>
  </div>
  <div class="p-3 sm:p-4 flex flex-col flex-1">
    {% if product.category is defined and product.category %}
    <p class="text-[10px] sm:text-xs text-gray-400 uppercase tracking-widest mb-1 font-medium">{{ product.category }}</p>
    {% endif %}
    <h3 class="text-xs sm:text-sm font-semibold text-gray-900 leading-snug mb-2 flex-1 line-clamp-2"><a href="{{ product.href }}" class="hover:text-{{ accent_color|default('blue-600') }} transition">{{ product.name }}</a></h3>
    {% if product.rating is defined and product.rating %}
    <div class="flex items-center gap-1 mb-3">
      <div class="flex text-xs">
        {% for i in 1..5 %}
          {% if product.rating >= i %}
            <span class="text-amber-400">★</span>
          {% else %}
            <span class="text-gray-300">★</span>
          {% endif %}
        {% endfor %}
      </div>
      {% if product.reviews is defined %}<span class="text-[10px] text-gray-400 ml-1">{{ product.reviews }} {{ text_reviews }}</span>{% endif %}
    </div>
    {% endif %}
    {% if product.stock is defined and product.stock %}
    <div class="mb-2 text-[11px] font-medium {% if product.is_preorder is defined and product.is_preorder %}text-amber-600{% elseif product.is_in_stock %}text-emerald-600{% else %}text-red-500{% endif %} flex items-center gap-1">
      {% if product.is_in_stock %}<i data-lucide="check" class="w-3.5 h-3.5"></i>{% endif %}
      <span>{{ product.stock }}</span>
    </div>
    {% endif %}
    <div class="flex items-end justify-between gap-2">
      <div class="flex items-baseline gap-1 flex-wrap">
        {% set cfp = (product.call_for_price is defined and product.call_for_price) or ((call_for_price_status is defined and call_for_price_status) and call_for_price_phone is defined and call_for_price_phone and product.price_raw is defined and product.price_raw <= 0) %}
        {% if cfp %}
          <a href="tel:{{ call_for_price_phone }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-600 text-white text-xs font-bold rounded-lg hover:bg-blue-700 transition shadow-sm">
            <i data-lucide="phone" class="w-3.5 h-3.5"></i>
            {{ text_call_for_price|default('Contact for price') }}
          </a>
        {% elseif product.special is defined and product.special %}
          <span class="text-base sm:text-lg font-extrabold text-gray-900">{{ product.special }}</span>
          <span class="text-xs text-red-400 line-through ml-1">{{ product.price }}</span>
        {% elseif product.price is defined and product.price %}
          <span class="text-base sm:text-lg font-extrabold text-gray-900">{{ product.price }}</span>
        {% endif %}
      </div>
      {% if not cfp and product.is_in_stock %}
      <button class="add-to-cart-btn flex-shrink-0 text-blue-600 hover:bg-blue-50 hover:text-blue-700 p-1.5 rounded-lg transition" onclick="cart.add('{{ product.product_id }}', '{{ product.minimum|default(1) }}');" aria-label="{{ button_cart }}">
        <i data-lucide="shopping-cart" class="w-5 h-5"></i>
      </button>
      {% endif %}
    </div>
  </div>
</div>
