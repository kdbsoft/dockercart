{#
  product_card.twig
  Shared product card partial for all listing views (grid / list / table).

  Required variables:
    product          — product data array
    view_mode        — 'grid' | 'list' | 'table'
    text_quick_view  — localised "Quick View" string
    text_reviews     — localised "reviews" word
    text_sale        — localised "SALE" badge text
    button_cart      — localised "Add to Cart" text

  Optional style variables:
    btn_quick_hover  — e.g. "hover:bg-blue-600"
    link_hover       — e.g. "hover:text-blue-600 transition"
    btn_cart_classes — e.g. "bg-blue-600 text-white hover:bg-blue-700"
#}
{% if view_mode == 'table' %}

<div class="product-card dc-table-row" data-id="{{ product.product_id }}" data-href="{{ product.href }}" data-description="{{ product.description }}" data-model="{{ product.model|default('') }}" data-in-wishlist="{{ product.in_wishlist|default(0) }}" data-rating="{{ product.rating|default(0) }}" data-stock="{{ (product.stock is defined ? product.stock : '')|e('html_attr') }}" data-is-in-stock="{{ product.is_in_stock ? 1 : 0 }}" data-minimum="{{ product.minimum|default(1) }}" data-call-for-price="{{ (product.call_for_price is defined and product.call_for_price) or (call_for_price_status is defined and call_for_price_status and call_for_price_phone is defined and call_for_price_phone and product.price_raw is defined and product.price_raw <= 0) ? 1 : 0 }}">
  <div class="w-[50px] h-[50px] rounded-lg overflow-hidden bg-gray-50 flex-shrink-0">
    <a href="{{ product.href }}">
      <img src="{{ product.thumb }}" alt="{{ product.name }}" class="w-full h-full object-cover" loading="lazy" />
    </a>
  </div>
  <div class="min-w-0">
    {% if product.category is defined and product.category %}
      <p class="text-[10px] text-gray-400 uppercase tracking-widest truncate">{{ product.category }}</p>
    {% endif %}
    <h3 class="text-sm font-semibold text-gray-900 leading-snug truncate">
      <a href="{{ product.href }}" class="{{ link_hover|default('hover:text-blue-600 transition') }}">{{ product.name }}</a>
    </h3>
    {% if product.model is defined and product.model %}
      <p class="text-[10px] text-gray-900 truncate">{{ text_model|default('Product Code:') }} {{ product.model }}</p>
    {% endif %}
  </div>
  <div class="flex items-baseline gap-1 whitespace-nowrap">
    {% set cfp = (product.call_for_price is defined and product.call_for_price) or ((call_for_price_status is defined and call_for_price_status) and call_for_price_phone is defined and call_for_price_phone and product.price_raw is defined and product.price_raw <= 0) %}
    {% if cfp %}
      <a href="tel:{{ call_for_price_phone }}" class="inline-flex items-center gap-1 px-2.5 py-1 bg-blue-600 text-white text-[11px] font-bold rounded-lg hover:bg-blue-700 transition">
        <i data-lucide="phone" class="w-3 h-3"></i>
        {{ text_call_for_price|default('Contact for price') }}
      </a>
    {% elseif product.special %}
      <span class="text-sm font-extrabold text-gray-900">{{ product.special }}</span>
      <span class="text-[11px] text-red-400 line-through">{{ product.price }}</span>
    {% elseif product.price %}
      <span class="text-sm font-extrabold text-gray-900">{{ product.price }}</span>
    {% endif %}
  </div>
  <div class="flex items-center gap-0.5">
    {% if product.rating %}
      {% for i in 1..5 %}
        <span class="text-[11px] {% if product.rating >= i %}text-amber-400{% else %}text-gray-200{% endif %}">★</span>
      {% endfor %}
    {% endif %}
  </div>
  <div class="text-[11px] font-medium {% if product.is_preorder is defined and product.is_preorder %}text-amber-600{% elseif product.is_in_stock %}text-emerald-600{% else %}text-red-500{% endif %} whitespace-nowrap">
    {% if product.is_in_stock %}
      <i data-lucide="check" class="w-3 h-3 inline-block"></i>
    {% endif %}
    <span>{{ product.stock is defined and product.stock ? product.stock : '' }}</span>
  </div>
  {% if not cfp and product.is_in_stock %}
  <div class="flex items-center gap-1">
    <input type="number" class="dc-qty-input w-12 text-[11px] text-center font-semibold border border-gray-200 rounded-lg py-1.5 px-1 focus:outline-none focus:border-blue-400" value="{{ product.minimum|default(1) }}" min="{{ product.minimum|default(1) }}" step="1" aria-label="{{ text_quantity|default('Qty:') }}" />
  </div>
  <div>
    <button class="text-blue-600 hover:bg-blue-50 hover:text-blue-700 p-1.5 rounded-lg transition" onclick="cart.add('{{ product.product_id }}', this.closest('.dc-table-row').querySelector('.dc-qty-input').value || '{{ product.minimum|default(1) }}');" aria-label="{{ button_cart }}">
      <i data-lucide="shopping-cart" class="w-5 h-5"></i>
    </button>
  </div>
  {% endif %}
</div>

{% elseif view_mode == 'list' %}

<div class="product-card dc-list-card group bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 flex flex-row" data-id="{{ product.product_id }}" data-href="{{ product.href }}" data-description="{{ product.description }}" data-model="{{ product.model|default('') }}" data-in-wishlist="{{ product.in_wishlist|default(0) }}" data-rating="{{ product.rating|default(0) }}" data-stock="{{ (product.stock is defined ? product.stock : '')|e('html_attr') }}" data-is-in-stock="{{ product.is_in_stock ? 1 : 0 }}" data-minimum="{{ product.minimum|default(1) }}" data-call-for-price="{{ (product.call_for_price is defined and product.call_for_price) or (call_for_price_status is defined and call_for_price_status and call_for_price_phone is defined and call_for_price_phone and product.price_raw is defined and product.price_raw <= 0) ? 1 : 0 }}">
  <div class="relative w-40 sm:w-48 flex-shrink-0 bg-gray-50 overflow-hidden">
    <a href="{{ product.href }}" class="block w-full h-full">
      <img src="{{ product.thumb }}" alt="{{ product.name }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    </a>
    {% if product.new_arrival_badge is defined and product.new_arrival_badge %}
      <span class="absolute top-2 left-2 bg-gradient-to-r {{ product.new_arrival_badge_class }} text-white text-[10px] font-bold px-2 py-0.5 rounded-md">{{ product.new_arrival_badge }}</span>
    {% elseif product.has_gift is defined and product.has_gift %}
      <span class="absolute top-2 left-2 bg-amber-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-md flex items-center gap-1"><i data-lucide="gift" class="w-3 h-3"></i> {{ text_gift_badge|default('GIFT') }}</span>
    {% elseif product.special %}
      {% set discount_pct = product.discount is defined ? product.discount : 0 %}
      {% if discount_pct > 0 %}
      <span class="absolute top-2 left-2 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-md">-{{ discount_pct }}%</span>
      {% else %}
      <span class="absolute top-2 left-2 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-md">{{ text_sale|default('SALE') }}</span>
      {% endif %}
    {% endif %}
    <div class="absolute top-2 right-2">
      <button class="wishlist-btn w-8 h-8 rounded-full bg-white shadow-md flex items-center justify-center hover:bg-rose-50 transition {% if product.in_wishlist %}bg-rose-50{% endif %}" onclick="dcAddToWishlist('{{ product.product_id }}', this); event.stopPropagation();" aria-label="Add to wishlist">
        <i data-lucide="heart" class="w-3.5 h-3.5 {% if product.in_wishlist %}text-rose-500 fill-rose-400{% else %}text-gray-400{% endif %}"></i>
      </button>
    </div>
  </div>
  <div class="flex-1 p-4 sm:p-5 flex flex-col min-w-0">
    {% if product.category is defined and product.category %}
      <p class="text-[10px] sm:text-xs text-gray-400 uppercase tracking-widest mb-1 font-medium">{{ product.category }}</p>
    {% endif %}
    <h3 class="text-sm sm:text-base font-bold text-gray-900 leading-snug mb-1">
      <a href="{{ product.href }}" class="{{ link_hover|default('hover:text-blue-600 transition') }}">{{ product.name }}</a>
    </h3>
    {% if product.model is defined and product.model %}
      <p class="text-xs text-gray-900 mb-1">{{ text_model|default('Product Code:') }} {{ product.model }}</p>
    {% endif %}
    {% if product.rating %}
      <div class="flex items-center gap-0.5 mb-2">
        {% for i in 1..5 %}
          <span class="text-xs {% if product.rating >= i %}text-amber-400{% else %}text-gray-200{% endif %}">★</span>
        {% endfor %}
        <span class="text-[10px] text-gray-400 ml-1">{{ product.reviews|default(0) }} {{ text_reviews }}</span>
      </div>
    {% endif %}
    {% if product.description is defined and product.description %}
      <p class="text-xs sm:text-sm text-gray-500 leading-relaxed mb-3 line-clamp-2">{{ product.description }}</p>
    {% endif %}
      <div class="mt-auto flex flex-wrap items-end justify-between gap-3">
        <div class="flex items-baseline gap-1 flex-wrap">
          {% set cfp = (product.call_for_price is defined and product.call_for_price) or ((call_for_price_status is defined and call_for_price_status) and call_for_price_phone is defined and call_for_price_phone and product.price_raw is defined and product.price_raw <= 0) %}
          {% if cfp %}
            <a href="tel:{{ call_for_price_phone }}" class="inline-flex items-center gap-1.5 px-4 py-2 bg-blue-600 text-white text-sm font-bold rounded-xl hover:bg-blue-700 transition shadow-sm">
              <i data-lucide="phone" class="w-4 h-4"></i>
              {{ text_call_for_price|default('Contact for price') }}
            </a>
          {% elseif product.special %}
            <span class="text-lg sm:text-xl font-extrabold text-gray-900">{{ product.special }}</span>
            <span class="text-xs text-red-400 line-through">{{ product.price }}</span>
          {% elseif product.price %}
            <span class="text-lg sm:text-xl font-extrabold text-gray-900">{{ product.price }}</span>
          {% endif %}
        </div>
      <div class="flex items-center gap-2">
        {% if product.stock is defined and product.stock %}
          <div class="text-[11px] font-medium {% if product.is_preorder is defined and product.is_preorder %}text-amber-600{% elseif product.is_in_stock %}text-emerald-600{% else %}text-red-500{% endif %} flex items-center gap-1">
            {% if product.is_in_stock %}
              <i data-lucide="check" class="w-3.5 h-3.5"></i>
            {% endif %}
            <span>{{ product.stock }}</span>
          </div>
        {% endif %}
        {% if not cfp and product.is_in_stock %}
        <button class="text-blue-600 hover:bg-blue-50 hover:text-blue-700 p-1.5 rounded-lg transition flex-shrink-0" onclick="cart.add('{{ product.product_id }}', '{{ product.minimum|default(1) }}');" aria-label="{{ button_cart }}">
          <i data-lucide="shopping-cart" class="w-5 h-5"></i>
        </button>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% else %}

{# --- grid view (default) --- #}
<div class="product-card group bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:scale-[1.02] transition-all duration-300 flex flex-col" data-id="{{ product.product_id }}" data-href="{{ product.href }}" data-description="{{ product.description }}" data-model="{{ product.model|default('') }}" data-in-wishlist="{{ product.in_wishlist|default(0) }}" data-rating="{{ product.rating|default(0) }}" data-stock="{{ (product.stock is defined ? product.stock : '')|e('html_attr') }}" data-is-in-stock="{{ product.is_in_stock ? 1 : 0 }}" data-minimum="{{ product.minimum|default(1) }}" data-call-for-price="{{ (product.call_for_price is defined and product.call_for_price) or (call_for_price_status is defined and call_for_price_status and call_for_price_phone is defined and call_for_price_phone and product.price_raw is defined and product.price_raw <= 0) ? 1 : 0 }}">
  <div class="relative overflow-hidden aspect-square bg-gray-50">
    <a href="{{ product.href }}">
      <img src="{{ product.thumb }}" alt="{{ product.name }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    </a>
    {% if product.new_arrival_badge is defined and product.new_arrival_badge %}
      <span class="absolute top-2 left-2 bg-gradient-to-r {{ product.new_arrival_badge_class }} text-white text-[10px] font-bold px-2 py-0.5 rounded-md">{{ product.new_arrival_badge }}</span>
    {% elseif product.has_gift is defined and product.has_gift %}
      <span class="absolute top-2 left-2 bg-amber-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-md flex items-center gap-1"><i data-lucide="gift" class="w-3 h-3"></i> {{ text_gift_badge|default('GIFT') }}</span>
    {% elseif product.special %}
      {% set discount_pct = product.discount is defined ? product.discount : 0 %}
      {% if discount_pct > 0 %}
      <span class="absolute top-2 left-2 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-md">-{{ discount_pct }}%</span>
      {% else %}
      <span class="absolute top-2 left-2 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-md">{{ text_sale|default('SALE') }}</span>
      {% endif %}
    {% endif %}
    <div class="absolute top-2 right-2">
      <button class="wishlist-btn w-8 h-8 rounded-full bg-white shadow-md flex items-center justify-center hover:bg-rose-50 transition {% if product.in_wishlist %}bg-rose-50{% endif %}" onclick="dcAddToWishlist('{{ product.product_id }}', this); event.stopPropagation();" aria-label="Add to wishlist">
        <i data-lucide="heart" class="w-3.5 h-3.5 {% if product.in_wishlist %}text-rose-500 fill-rose-400{% else %}text-gray-400{% endif %}"></i>
      </button>
    </div>
    <button class="quick-view-btn absolute bottom-0 left-0 right-0 py-2.5 bg-gray-900/85 {{ btn_quick_hover|default('hover:bg-blue-600') }} text-white text-[11px] font-bold uppercase tracking-widest backdrop-blur-sm transition-colors duration-200" onclick="openQuickView && openQuickView({{ product.product_id }}); event.stopPropagation();" aria-label="{{ text_quick_view }}">
      {{ text_quick_view }}
    </button>
  </div>
  <div class="p-3 sm:p-4 flex flex-col flex-1">
    {% if product.category is defined and product.category %}
      <p class="text-[10px] sm:text-xs text-gray-400 uppercase tracking-widest mb-1 font-medium">{{ product.category }}</p>
    {% endif %}
    <h3 class="text-xs sm:text-sm font-semibold text-gray-900 leading-snug mb-2 flex-1 line-clamp-2">
      <a href="{{ product.href }}" class="{{ link_hover|default('hover:text-blue-600 transition') }}">{{ product.name }}</a>
    </h3>
    {% if product.rating %}
      <div class="flex items-center gap-0.5 mb-2">
        {% for i in 1..5 %}
          <span class="text-xs {% if product.rating >= i %}text-amber-400{% else %}text-gray-200{% endif %}">★</span>
        {% endfor %}
        <span class="text-[10px] text-gray-400 ml-1">{{ product.reviews|default(0) }} {{ text_reviews }}</span>
      </div>
    {% endif %}
    {% if product.stock is defined and product.stock %}
      <div class="mb-2 text-[11px] font-medium {% if product.is_preorder is defined and product.is_preorder %}text-amber-600{% elseif product.is_in_stock %}text-emerald-600{% else %}text-red-500{% endif %} flex items-center gap-1">
        {% if product.is_in_stock %}
          <i data-lucide="check" class="w-3.5 h-3.5"></i>
        {% endif %}
        <span>{{ product.stock }}</span>
      </div>
    {% endif %}
    <div class="flex items-end justify-between gap-2">
      <div class="flex items-baseline gap-1 flex-wrap">
        {% set cfp = (product.call_for_price is defined and product.call_for_price) or ((call_for_price_status is defined and call_for_price_status) and call_for_price_phone is defined and call_for_price_phone and product.price_raw is defined and product.price_raw <= 0) %}
        {% if cfp %}
          <a href="tel:{{ call_for_price_phone }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-600 text-white text-xs font-bold rounded-lg hover:bg-blue-700 transition shadow-sm">
            <i data-lucide="phone" class="w-3.5 h-3.5"></i>
            {{ text_call_for_price|default('Contact for price') }}
          </a>
        {% elseif product.special %}
          <span class="text-base sm:text-lg font-extrabold text-gray-900">{{ product.special }}</span>
          <span class="text-xs text-red-400 line-through ml-1">{{ product.price }}</span>
        {% elseif product.price %}
          <span class="text-base sm:text-lg font-extrabold text-gray-900">{{ product.price }}</span>
        {% endif %}
      </div>
      {% if not cfp and product.is_in_stock %}
      <button class="add-to-cart-btn flex-shrink-0 text-blue-600 hover:bg-blue-50 hover:text-blue-700 p-1.5 rounded-lg transition" onclick="cart.add('{{ product.product_id }}', '{{ product.minimum|default(1) }}');" aria-label="{{ button_cart }}">
        <i data-lucide="shopping-cart" class="w-5 h-5"></i>
      </button>
      {% endif %}
    </div>
  </div>
</div>

{% endif %}
