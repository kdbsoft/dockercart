{{ header }}

<main class="bg-white min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-blue-950 to-gray-900 relative">
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-black/15"></div>
    <div class="relative z-10 py-12 sm:py-14 px-4 sm:px-6 lg:px-8 flex items-center">
      <div class="max-w-7xl mx-auto w-full">
        {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
          breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
          breadcrumbs_link_class: 'hover:text-white transition',
          breadcrumbs_last_class: 'text-white font-semibold'
        } %}
        <p class="text-xs font-bold uppercase tracking-widest text-blue-400 mb-1">{{ text_brand }}</p>
        <h1 class="text-2xl sm:text-4xl font-extrabold text-white leading-tight">{{ heading_title }}</h1>
        {% if description %}
        <p class="text-sm sm:text-base text-gray-200 mt-2 max-w-xl line-clamp-2">{{ description|striptags }}</p>
        {% endif %}
      </div>
    </div>
  </section>

  {% if refine_categories %}
  <section class="pt-8 pb-2 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="bg-white border border-gray-100 rounded-3xl p-5 sm:p-6 shadow-sm">
        <div class="flex flex-wrap items-end justify-between gap-3 mb-5">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-blue-500">{{ text_refine }}</p>
            <h2 class="text-xl sm:text-2xl font-extrabold text-gray-900 mt-1">
              {% if refine_category_name %}
                {{ refine_category_name }}
              {% else %}
                {{ text_refine_categories }}
              {% endif %}
            </h2>
            {% if refine_parent_href %}
            <a href="{{ refine_parent_href }}" class="inline-flex items-center gap-1 text-sm text-blue-600 hover:underline mt-1">
              <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i> {{ text_back_to|format(refine_parent_name) }}
            </a>
            {% endif %}
          </div>
        </div>

        {% set palette_bg = [ 'rgba(59,130,246,0.07)', 'rgba(99,102,241,0.07)', 'rgba(16,185,129,0.07)', 'rgba(236,72,153,0.07)', 'rgba(249,115,22,0.07)', 'rgba(234,179,8,0.07)' ] %}
        {% set palette_accent = [ 'rgba(59,130,246,0.18)', 'rgba(99,102,241,0.18)', 'rgba(16,185,129,0.18)', 'rgba(236,72,153,0.18)', 'rgba(249,115,22,0.18)', 'rgba(234,179,8,0.18)' ] %}

        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
          {% for category in refine_categories %}
          {% set bg = palette_bg[loop.index0 % palette_bg|length] %}
          {% set accent = palette_accent[loop.index0 % palette_accent|length] %}
          <a href="{{ category.href }}" class="group subcategory-card rounded-2xl p-4 transition-transform hover:scale-[1.02]" style="background: {{ bg }}; border: 1px solid rgba(15,23,42,0.04);">
            <div class="flex items-center gap-3">
              <div class="w-14 h-14 rounded-lg flex items-center justify-center flex-shrink-0" style="background: {{ accent }}; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);">
                {% if category.thumb %}
                <img src="{{ category.thumb }}" alt="{{ category.name }}" class="w-10 h-10 object-cover rounded-md shadow-sm" loading="lazy" />
                {% else %}
                <i data-lucide="layers" class="w-6 h-6 text-gray-700"></i>
                {% endif %}
              </div>
              <div class="flex-1 min-w-0">
                <span class="block text-sm font-semibold text-gray-900 leading-tight break-words">{{ category.name }}</span>
                {% if category.total is defined and category.total > 0 %}
                <span class="text-xs text-gray-500">{{ category.product_label }}</span>
                {% endif %}
              </div>
              <i data-lucide="chevron-right" class="w-4 h-4 text-gray-400"></i>
            </div>
          </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>
  {% elseif refine_parent_href %}
  <div class="px-4 sm:px-6 lg:px-8 pt-8 pb-2">
    <div class="max-w-7xl mx-auto">
      <a href="{{ refine_parent_href }}" class="inline-flex items-center gap-1.5 text-sm text-blue-600 hover:text-blue-800 font-medium">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> {{ text_back_to|format(refine_parent_name) }}
      </a>
    </div>
  </div>
  {% endif %}

  <section id="catalog" class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {{ content_top }}

      <div class="{% if column_left and column_right %}grid grid-cols-1 lg:grid-cols-[280px,1fr,280px] gap-6{% elseif column_left or column_right %}grid grid-cols-1 lg:grid-cols-[280px,1fr] gap-6{% endif %}">
        {% if column_left %}
        <aside class="hidden lg:block">
          <div class="bg-white border border-gray-100 rounded-3xl p-5 h-fit shadow-sm">
            {{ column_left }}
          </div>
        </aside>
        {% endif %}

        <div>
          {% if products %}
          <div class="bg-white border border-gray-100 rounded-3xl p-4 sm:p-5 mb-5 shadow-sm">
            <div class="flex flex-wrap gap-3 items-center justify-between">
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400">Brand</p>
                <h2 class="text-lg sm:text-xl font-extrabold text-gray-900 mt-0.5">{{ heading_title }}</h2>
              </div>
              <div class="flex items-center gap-3 flex-wrap">
                <span class="text-sm text-gray-500">{{ text_product_count }}</span>
                <select onchange="location = this.value;" class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:border-blue-400 bg-white cursor-pointer">
                  {% for sort_item in sorts %}
                  <option value="{{ sort_item.href }}" {% if sort_item.value == '%s-%s'|format(sort, order) %}selected{% endif %}>{{ sort_item.text }}</option>
                  {% endfor %}
                </select>
                <select onchange="location = this.value;" class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:border-blue-400 bg-white cursor-pointer">
                  {% for limit_item in limits %}
                  <option value="{{ limit_item.href }}" {% if limit_item.value == limit %}selected{% endif %}>{{ limit_item.text }}</option>
                  {% endfor %}
                </select>
                <div class="dc-view-toggle items-center gap-0.5 border border-gray-200 rounded-xl p-0.5 ml-2">
                  <button class="dc-view-btn{% if view_mode == 'grid' %} is-active{% endif %}" data-view="grid" title="{{ text_view_grid|default('Grid') }}" aria-pressed="{{ view_mode == 'grid' ? 'true' : 'false' }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  </button>
                  <button class="dc-view-btn{% if view_mode == 'list' %} is-active{% endif %}" data-view="list" title="{{ text_view_list|default('List') }}" aria-pressed="{{ view_mode == 'list' ? 'true' : 'false' }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                  </button>
                  <button class="dc-view-btn{% if view_mode == 'table' %} is-active{% endif %}" data-view="table" title="{{ text_view_table|default('Table') }}" aria-pressed="{{ view_mode == 'table' ? 'true' : 'false' }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div id="dc-product-grid" class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6 mb-8 dc-view-{{ view_mode|default('grid') }}">
            {% for product in products %}
            {% include 'dockercart/template/product/product_card.twig' with {
              product: product,
              view_mode: view_mode|default('grid'),
              text_quick_view: text_quick_view,
              text_reviews: text_reviews,
              text_sale: 'SALE',
              text_gift_badge: text_gift_badge|default('GIFT'),
              button_cart: button_cart,
              btn_quick_hover: 'hover:bg-blue-600',
              link_hover: 'hover:text-blue-600 transition',
              btn_cart_classes: 'bg-blue-600 text-white hover:bg-blue-700'
            } %}
            {% endfor %}
          </div>

          {% if has_more %}
          <div class="dc-load-more-wrap mt-6 flex flex-col items-center gap-2">
            <button class="dc-load-more-btn inline-flex items-center gap-2 px-7 py-3 rounded-2xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm shadow transition"
              data-url="{{ load_more_url }}"
              data-page="{{ page + 1 }}"
              data-total="{{ product_total }}"
              data-loaded="{{ products_loaded }}">
              <i data-lucide="chevron-down" class="w-4 h-4"></i>
              {{ text_load_more }}
              <span class="dc-lm-count text-xs font-normal opacity-70">({{ products_loaded }} / {{ product_total }})</span>
            </button>
          </div>
          {% endif %}

          {% if pagination %}
          <div class="mt-8 flex items-center justify-center">
            <div class="dc-pagination">{{ pagination }}</div>
          </div>
          {% endif %}

          {% if description %}
          <div class="mt-10 bg-gray-50 border border-gray-100 rounded-3xl p-6 sm:p-8">
                <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">{{ text_about_brand }}</p>
            <h2 class="text-xl sm:text-2xl font-extrabold text-gray-900 leading-tight mb-4">{{ heading_title }}</h2>
            <div class="text-sm sm:text-base text-gray-600 leading-relaxed">{{ description }}</div>

            <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-3">
              <div class="rounded-2xl border border-gray-200 bg-white p-4">
                <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400 mb-1">{{ text_products }}</p>
                <p class="text-sm font-semibold text-gray-900">{{ product_total }}+ {{ text_products|lower }}</p>
              </div>
              <div class="rounded-2xl border border-gray-200 bg-white p-4">
                <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400 mb-1">Quality</p>
                <p class="text-sm font-semibold text-gray-900">Verified and certified supplier</p>
              </div>
              <div class="rounded-2xl border border-gray-200 bg-white p-4">
                <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400 mb-1">Support</p>
                <p class="text-sm font-semibold text-gray-900">Expert guidance before and after purchase</p>
              </div>
            </div>
          </div>
          {% endif %}

          {% else %}
          <div class="flex flex-col items-center justify-center py-24 text-center">
            <i data-lucide="package-x" class="w-16 h-16 text-gray-200 mb-4"></i>
            <p class="text-lg font-semibold text-gray-500">{{ text_empty }}</p>
            <a href="{{ continue }}" class="mt-6 px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm rounded-xl transition">
              {{ button_continue }}
            </a>
          </div>
          {% endif %}
        </div>

        {% if column_right %}
        <aside class="hidden lg:block">
          <div class="bg-white border border-gray-100 rounded-3xl p-5 h-fit shadow-sm">
            {{ column_right }}
          </div>
        </aside>
        {% endif %}
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>

<style>
  .wishlist-btn { opacity: 0; transform: translateY(-4px) scale(.92); transition: opacity .18s ease, transform .18s ease, box-shadow .18s ease; }
  .product-card:hover .wishlist-btn { opacity: 1; transform: translateY(0) scale(1); }
  .wishlist-btn:focus-visible, .wishlist-btn.bg-rose-50 { opacity: 1; transform: translateY(0) scale(1); }

  .product-card:hover .quick-view-btn { opacity: 1 !important; transform: translateY(0) !important; }
  .quick-view-btn { opacity: 0; transform: translateY(100%); transition: opacity 0.25s ease, transform 0.25s ease; }

  .dc-pagination ul { display:flex; gap:.5rem; list-style:none; padding:0; margin:0; flex-wrap:wrap; justify-content:center; }
  .dc-pagination ul li a,
  .dc-pagination ul li span {
    display:inline-flex; align-items:center; justify-content:center;
    width:2.25rem; height:2.25rem; padding:0;
    border-radius:.75rem; border:1px solid #e5e7eb;
    font-size:.875rem; font-weight:500; color:#6b7280;
    background:#fff; text-decoration:none; transition:all .15s ease;
  }
  .dc-pagination ul li a:hover { border-color:#93c5fd; color:#2563eb; }
  .dc-pagination ul li.active span,
  .dc-pagination ul li.active a { background:#2563eb; border-color:#2563eb; color:#fff; }
</style>

{% include 'dockercart/template/common/partials/schema_item_list.twig' %}
{{ footer }}
