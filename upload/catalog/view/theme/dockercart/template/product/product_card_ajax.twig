{#
  product_card_ajax.twig
  Wrapper that delegates to the shared product_card.twig partial.
  Kept for backward compatibility with the load-more AJAX endpoint.

  Required variables:
    product
    text_quick_view, text_reviews, text_sale, button_cart

  Also accepts:
    view_mode      — 'grid' | 'list' | 'table' (defaults to 'grid')
    btn_quick_hover, link_hover, btn_cart_classes
#}
{% include 'dockercart/template/product/product_card.twig' with {
  product: product,
  view_mode: view_mode|default('grid'),
  text_quick_view: text_quick_view,
  text_reviews: text_reviews|default('reviews'),
  text_sale: text_sale|default(''),
  text_gift_badge: text_gift_badge|default('GIFT'),
  text_call_for_price: text_call_for_price|default('Contact for price'),
  button_cart: button_cart,
  btn_quick_hover: btn_quick_hover|default('hover:bg-blue-600'),
  link_hover: link_hover|default('hover:text-blue-600 transition'),
  btn_cart_classes: btn_cart_classes|default('bg-blue-600 text-white hover:bg-blue-700'),
  call_for_price_status: call_for_price_status|default(0),
  call_for_price_phone: call_for_price_phone|default('')
} %}
