# DockerCart Docker Environment Configuration
# Copy to .env and customize as needed

# Database Configuration
DB_HOSTNAME=mariadb
DB_USERNAME=dockercart
DB_PASSWORD=dockercart_password
DB_DATABASE=dockercart
DB_PORT=3306
DB_PREFIX=oc_

# MariaDB Root Password (for initial setup)
MARIADB_ROOT_PASSWORD=root_password

# MariaDB Database Settings
MARIADB_DATABASE=${DB_DATABASE}
MARIADB_USER=${DB_USERNAME}
MARIADB_PASSWORD=${DB_PASSWORD}
# Optional: expose MariaDB to host on this port. Leave unset to keep DB isolated.
# MARIADB_EXTERNAL_PORT=3306

# MariaDB config size: s (4GB RAM), m (8GB RAM), l (12GB RAM)
MARIADB_CONFIG_SIZE=s

# Container Names
DOCKERCART_CONTAINER_NAME=dockercart_web
MARIADB_CONTAINER_NAME=dockercart_mariadb
PHPMYADMIN_CONTAINER_NAME=dockercart_phpmyadmin
NGINX_CONTAINER_NAME=dockercart_nginx
APACHE_CONTAINER_NAME=dockercart_apache
MANTICORE_CONTAINER_NAME=dockercart_manticore
REDIS_CONTAINER_NAME=dockercart_redis
FTP_CONTAINER_NAME=dockercart_ftp
CERTBOT_CONTAINER_NAME=dockercart_certbot
SCHEDULER_CONTAINER_NAME=dockercart_scheduler

# Cache Configuration
CACHE_ENGINE=redis
SESSION_ENGINE=redis
CACHE_PREFIX=oc_
# Redis
REDIS_HOSTNAME=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAXMEMORY=256mb

# Traefik Router Names
DOCKERCART_ROUTER_NAME=dockercart

DOCKERCART_NETWORK=dockercart-network

# Restart Policy
RESTART_POLICY=unless-stopped

# Application Configuration
DOCKERCART_URL=http://dockercart.local
# Keep HTTP unless SSL/TLS is actually enabled on your ingress.
DOCKERCART_HTTPS_URL=http://dockercart.local
DOCKERCART_SSL_ENABLED=false
DOCKERCART_DOMAIN=dockercart.local
# Secret key for custom XML orders export endpoint:
# /index.php?route=extension/module/dockercart_custom_orders_xml&secret=...
DOCKERCART_CUSTOM_ORDERS_XML_SECRET=secret_key_here

# Default admin account (used on first database initialization)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# Standalone HTTP port (docker-compose.yml)
DOCKERCART_HTTP_PORT=80
# Standalone HTTPS port (docker-compose.ssl.yml / docker-compose.le.yml)
DOCKERCART_HTTPS_PORT=443
TZ=UTC
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_POST_MAX_SIZE=100M
PHP_MAX_EXECUTION_TIME=300

# Built-in scheduler for periodic tasks
SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL=60
SCHEDULER_MEM_LIMIT=512M
SCHEDULER_CPUS=1.0
SCHEDULER_WORKER_TIMEOUT=3600

# ============================================================================
# Backup to S3 (optional, off by default)
# ============================================================================
# When enabled, the scheduler runs `bin/dockercart_backup_s3.php` on the
# configured cron schedule. The worker dumps the database (mariadb-dump) and
# tars ./upload/image + ./storage/download + ./storage/modification into a
# single .tar.gz, uploads it via rclone, then deletes local staging files.
# Old S3 objects older than BACKUP_S3_RETENTION_DAYS are deleted automatically.
#
# Toggle the task itself (enable / schedule) in admin: System → Scheduler.
# Credentials stay here in .env (never written to the database).
BACKUP_S3_ENABLED=false
# rclone S3 provider: AWS, Ceph, Minio, Cloudflare, Other, etc.
# (see https://rclone.org/s3/#standard-options)
BACKUP_S3_PROVIDER=
# For S3-compatible storage: https://s3.example.com (leave empty for AWS)
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
# Object key prefix inside the bucket
BACKUP_S3_PATH=dockercart/backups
# Delete S3 objects older than N days (retention policy)
BACKUP_S3_RETENTION_DAYS=7
# Set true only for self-signed / internal CAs (skips TLS verification)
BACKUP_S3_INSECURE=false

# Image optimisation: uploaded images with a longer side > this value (px) will be
# proportionally resized and recompressed.  In-addition, JPEG/PNG/WebP files will
# always be re-saved with optimised encoder settings (JPEG 95, PNG level 9, WebP 95).
# Set 0 to disable completely.  Can be overridden in admin Settings → Image tab.
IMAGE_MAX_DIMENSION=2560

# phpMyAdmin Settings
PMA_HOST=mariadb
PMA_PORT=3306

# Optional FTP server (profile: ftp). Access is limited to ./upload/image
FTP_PORT=21
FTP_USER=images
FTP_PASS=change_me_please
# FTP root will be /home/vsftpd/${FTP_USER} -> host ./upload/image
# Extended privileges inside /upload/image (write/delete/rename)
FTP_WRITE_ENABLE=YES
FTP_ALLOW_WRITEABLE_CHROOT=YES
FTP_LOCAL_UMASK=000
FTP_FILE_OPEN_MODE=0777
# IMPORTANT: must be reachable by FTP client (public IP or domain), never 127.0.0.1
FTP_PASV_ADDRESS=dockercart.docker.localhost
FTP_PASV_ADDR_RESOLVE=YES
FTP_PASV_MIN_PORT=21100
FTP_PASV_MAX_PORT=21110

# ============================================================================
# SSL / Let's Encrypt (optional, for production)
# ============================================================================
# Used by standalone LE mode and Traefik LE mode.
# Standalone LE requires inbound ports 80 and 443 and a real public DNS record.
SSL_DOMAIN=example.com
SSL_EMAIL=admin@example.com
LETSENCRYPT_ENABLED=false

# Persist Let's Encrypt ACME account/certificate state between rebuilds/deploys.
# For CI or ephemeral deploys, point these to a stable host path outside the repo.
LETSENCRYPT_DATA_DIR=./docker/letsencrypt
LETSENCRYPT_WEBROOT_DIR=./docker/letsencrypt/www

# Standalone certbot renewal check cadence (renews only when certificate is due).
CERTBOT_RENEW_INTERVAL=24h
